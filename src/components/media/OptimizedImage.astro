---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  layout?: "constrained" | "fixed" | "full-width" | "none";
  width?: number;
  height?: number;
  quality?: number;
  priority?: boolean;
  class?: string;
  sizes?: string;
}

const {
  src,
  alt,
  layout = "constrained",
  width,
  height,
  quality = 80,
  priority = false,
  class: className,
  sizes,
} = Astro.props;
---

<Image
  src={src}
  alt={alt}
  layout={layout}
  width={width}
  height={height}
  quality={quality}
  priority={priority}
  class={className}
  sizes={sizes}
/>
