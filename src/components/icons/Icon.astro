---
import "./Icon.css";

import type { IconName } from "./types";

interface Props {
  name: IconName;
  label?: string;
  size?: number;
}

const { name, label, size = 24 } = Astro.props;
const hidden = label ? undefined : "true";
---

<svg
  class="icon"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden={hidden}
  aria-label={label}
  role={label ? "img" : undefined}
>
  {
    name === "location" && (
      <>
        <path
          d="M12 21s6-5.7 6-11a6 6 0 1 0-12 0c0 5.3 6 11 6 11Z"
          stroke="currentColor"
          stroke-linejoin="round"
        />
        <circle cx="12" cy="10" r="2.2" stroke="currentColor" />
      </>
    )
  }
  {
    name === "phone" && (
      <path
        d="M7.4 3.5 4.8 5.2c-.8.5-1.2 1.5-.9 2.4 1.7 5.8 6.3 10.4 12.1 12.1.9.3 1.9-.1 2.4-.9l1.7-2.6-4.6-2.2-1.4 1.8a12.8 12.8 0 0 1-5.9-5.9L10 8.5 7.4 3.5Z"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "facebook" && (
      <path
        d="M13.8 21v-8h2.7l.4-3h-3.1V8.1c0-.9.3-1.5 1.6-1.5H17V4a22 22 0 0 0-2.5-.2c-2.5 0-4.2 1.5-4.2 4.3V10H7.5v3h2.8v8h3.5Z"
        fill="currentColor"
      />
    )
  }
  {
    name === "instagram" && (
      <>
        <rect x="4" y="4" width="16" height="16" rx="5" stroke="currentColor" />
        <circle cx="12" cy="12" r="3.5" stroke="currentColor" />
        <circle cx="17.2" cy="6.8" r=".8" fill="currentColor" />
      </>
    )
  }
  {
    name === "image" && (
      <>
        <rect
          x="3.5"
          y="4.5"
          width="17"
          height="15"
          rx="2.5"
          stroke="currentColor"
        />
        <circle cx="15.5" cy="9" r="1.5" stroke="currentColor" />
        <path
          d="m5.5 17 4.3-4.3 3.1 3.1 2-2 3.6 3.2"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </>
    )
  }
  {
    name === "arrowRight" && (
      <path
        d="M5 12h14m-6-6 6 6-6 6"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "book" && (
      <path
        d="M5 5.5c2.4 0 4.2.5 7 2.2 2.8-1.7 4.6-2.2 7-2.2v13c-2.4 0-4.2.5-7 2.2-2.8-1.7-4.6-2.2-7-2.2v-13Z"
        stroke="currentColor"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "calendar" && (
      <>
        <path
          d="M7 3v3m10-3v3M4.5 9.5h15"
          stroke="currentColor"
          stroke-linecap="round"
        />
        <rect
          x="4.5"
          y="5.5"
          width="15"
          height="15"
          rx="3"
          stroke="currentColor"
        />
        <path
          d="M8 13h2m4 0h2m-8 4h2m4 0h2"
          stroke="currentColor"
          stroke-linecap="round"
        />
      </>
    )
  }
  {
    name === "chat" && (
      <path
        d="M5 7.5a5 5 0 0 1 5-5h4a5 5 0 0 1 2 9.6v4.4l-4.4-4H10a5 5 0 0 1-5-5Z"
        stroke="currentColor"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "clock" && (
      <>
        <circle cx="12" cy="12" r="8.5" stroke="currentColor" />
        <path
          d="M12 7v5l3.5 2.2"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </>
    )
  }
  {
    name === "close" && (
      <path
        d="m6 6 12 12M18 6 6 18"
        stroke="currentColor"
        stroke-linecap="round"
      />
    )
  }
  {
    name === "heart" && (
      <path
        d="M12 20s-7-4.3-8.7-9.1C2 7.2 4.3 4.5 7.4 4.5c1.8 0 3.3 1 4.1 2.3.8-1.3 2.3-2.3 4.1-2.3 3.1 0 5.4 2.7 4.1 6.4C19 15.7 12 20 12 20Z"
        stroke="currentColor"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "heartSmile" && (
      <>
        <path
          d="M12 20s-7-4.3-8.7-9.1C2 7.2 4.3 4.5 7.4 4.5c1.8 0 3.3 1 4.1 2.3.8-1.3 2.3-2.3 4.1-2.3 3.1 0 5.4 2.7 4.1 6.4C19 15.7 12 20 12 20Z"
          stroke="currentColor"
          stroke-linejoin="round"
        />
        <path
          d="M8.8 10.8h.1m6.2 0h.1M8.8 14c1.8 1.6 4.6 1.6 6.4 0"
          stroke="currentColor"
          stroke-linecap="round"
        />
      </>
    )
  }
  {
    name === "mail" && (
      <>
        <rect
          x="3.5"
          y="6"
          width="17"
          height="12"
          rx="2.5"
          stroke="currentColor"
        />
        <path
          d="m5 8 7 5 7-5"
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </>
    )
  }
  {
    name === "palette" && (
      <>
        <path
          d="M12 3.5a8.5 8.5 0 0 0 0 17h1.2a2 2 0 0 0 1.4-3.4l-.3-.3a1.6 1.6 0 0 1 1.1-2.8H17a4 4 0 0 0 4-4c0-3.6-4-6.5-9-6.5Z"
          stroke="currentColor"
          stroke-linejoin="round"
        />
        <path
          d="M7.7 11h.1m2.7-3h.1m4.8.7h.1"
          stroke="currentColor"
          stroke-linecap="round"
        />
      </>
    )
  }
  {
    name === "person" && (
      <>
        <circle cx="12" cy="8" r="3.5" stroke="currentColor" />
        <path
          d="M5.5 20a6.5 6.5 0 0 1 13 0"
          stroke="currentColor"
          stroke-linecap="round"
        />
      </>
    )
  }
  {
    name === "star" && (
      <path
        d="m12 3.8 2.5 5 5.5.8-4 3.9.9 5.5-4.9-2.6L7.1 19l.9-5.5-4-3.9 5.5-.8 2.5-5Z"
        stroke="currentColor"
        stroke-linejoin="round"
      />
    )
  }
  {
    name === "users" && (
      <>
        <circle cx="9" cy="8.5" r="3" stroke="currentColor" />
        <path
          d="M3.8 19a5.2 5.2 0 0 1 10.4 0"
          stroke="currentColor"
          stroke-linecap="round"
        />
        <path
          d="M15.5 11.5a2.6 2.6 0 1 0-.9-5M16 14c2.5.4 4.2 2.2 4.2 5"
          stroke="currentColor"
          stroke-linecap="round"
        />
      </>
    )
  }
</svg>
