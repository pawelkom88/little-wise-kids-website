---
import Image from "astro/components/Image.astro";
import envelopeIcon from "../../assets/images/icon-envelope.png";
import flowerIcon from "../../assets/images/flower-icon.png";
import Section from "../layout/Section.astro";
import PortableContent from "../content/PortableContent.astro";
import "./FaqSection.css";
import type { HomePage } from "../../lib/types";

interface Props {
  homePage: HomePage;
}

const { homePage } = Astro.props;
---

<svg
  class="faq-wave faq-wave--top"
  viewBox="0 0 1448 120"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"
  ></path>
</svg>

<Section class="faq-section" width="wide" aria-labelledby="faq-title">
  <div class="faq-shell">
    <header class="faq-header">
      <h2 class="faq-title" id="faq-title">
        {homePage.faqHeading.prefix} <span>{homePage.faqHeading.accentedPhrase}</span>
      </h2>

      <p class="faq-intro">
        {homePage.faqIntro}
      </p>
    </header>

    <div class="faq-list">
      {
        homePage.faqs.map((faq: import("../../lib/types").FaqItem, index: number) => (
          <details class="faq-item" name="little-wise-kids-faq" open={index === 0}>
            <summary>
              <span class="faq-question">{faq.question}</span>
              <span class="faq-control" aria-hidden="true" />
            </summary>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                <div class="faq-answer-content">
                  <PortableContent value={faq.answer} />
                </div>
              </div>
            </div>
          </details>
        ))
      }
    </div>

    <aside class="faq-contact" aria-labelledby="faq-contact-title">
      <Image
        width={82}
        height={82}
        class="faq-contact__envelope"
        src={envelopeIcon}
        alt=""
        aria-hidden="true"
      />

      <div class="faq-contact__content">
        <h2 class="faq-contact__title" id="faq-contact-title">
          {homePage.helpPanelTitle}
        </h2>

        <p class="faq-contact__text">
          {homePage.helpPanelCopy}
          <!--TODO: scroll to the form-->
          <a class="faq-contact__link" href="/contact/#contact-form">{homePage.helpPanelCtaLabel}</a>
        </p>
      </div>

      <Image
        width={82}
        height={82}
        class="faq-contact__flower"
        src={flowerIcon}
        alt=""
        aria-hidden="true"
      />
    </aside>
  </div>
</Section>

<svg
  class="faq-wave faq-wave--rotated"
  viewBox="0 0 1448 120"
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"
  ></path>
</svg>
