---
import Image from "astro/components/Image.astro";
import envelopeIcon from "../../../assets/icons/icon-envelope.png";
import flowerIcon from "../../../assets/icons/flower-icon.png";
import Section from "../layout/Section.astro";
import "./FaqSection.css";

const faqs = [
  {
    question: "What age range do you care for?",
    answer:
      "We care for children from <strong>6 months to 5 years old</strong>, providing a safe, nurturing and engaging early years environment tailored to each stage of development.",
    open: true,
  },
  {
    question: "What languages are part of the curriculum?",
    answer:
      "Portuguese and Spanish are introduced through songs, stories, play and everyday routines, so children experience language in a natural and enjoyable way.",
  },
  {
    question: "What are your opening hours?",
    answer:
      "We are open Monday to Friday from <strong>7:00 to 18:00</strong>. We are open through school holidays and closed on bank holidays.",
  },
  {
    question: "Where are you located?",
    answer:
      "Little Wise Kids Childminding is based in a home setting just behind Cabot Circus car park, with easy access to town and the M32.",
  },
  {
    question: "What is your childminding approach?",
    answer:
      "Our approach combines traditional Early Years learning with modern languages and cultures. We focus on play, care, confidence, curiosity and strong partnerships with families.",
  },
] as const;
---

<svg class="faq-wave faq-wave--top" viewBox="0 0 1448 120" preserveAspectRatio="none" aria-hidden="true">
  <path d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"></path>
</svg>

<Section class="faq-section" width="wide">
  <div class="faq-shell" aria-labelledby="faq-title">
    <header class="faq-header">
      <h2 class="faq-title" id="faq-title">
        Got <span>Questions?</span>
      </h2>

      <p class="faq-intro">
        Clear answers to the things parents most often ask before joining Little Wise Kids.
      </p>
    </header>

    <div class="faq-list">
      {
        faqs.map((faq) => (
          <details class="faq-item" name="little-wise-kids-faq" open={faq.open}>
            <summary>
              <span class="faq-question">{faq.question}</span>
              <span class="faq-control" aria-hidden="true"></span>
            </summary>
            <div class="faq-answer">
              <div class="faq-answer-inner">
                <div class="faq-answer-content">
                  <p set:html={faq.answer}></p>
                </div>
              </div>
            </div>
          </details>
        ))
      }
    </div>

    <aside class="faq-contact" aria-labelledby="faq-contact-title">
      <Image
        width={82}
        height={82}
        class="faq-contact__envelope"
        src={envelopeIcon}
        alt="Envelope icon"
        aria-hidden="true"
      />

      <div class="faq-contact__content">
        <h2 class="faq-contact__title" id="faq-contact-title">
          Have another question? We’re here to help!
        </h2>

        <p class="faq-contact__text">
          Our team is happy to help with anything you need.
          <a class="faq-contact__link" href="/#contact">Contact us</a>
          — we’d love to hear from you.
        </p>
      </div>

      <Image
        width={82}
        height={82}
        class="faq-contact__flower"
        src={flowerIcon}
        alt="Flower icon"
        aria-hidden="true"
      />
    </aside>
  </div>
</Section>

<svg class="faq-wave faq-wave--rotated" viewBox="0 0 1448 120" preserveAspectRatio="none" aria-hidden="true">
  <path d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"></path>
</svg>
