---
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
import SanityImage from "../media/SanityImage.astro";
import "./GallerySection.css";
import type { HomePage, GalleryPhoto, StrictImage } from "../../lib/types";

interface HomeGalleryImage {
  image: StrictImage;
  alt: string;
  label: string;
}

interface Props {
  homePage: HomePage;
  photos?: GalleryPhoto[];
}

const { homePage, photos = [] } = Astro.props;

const inlineImages: HomeGalleryImage[] = (homePage.galleryImages ?? []).map((img) => ({
  image: img,
  alt: img.altText,
  label: img.caption ?? "",
}));

const hasInline = inlineImages.length > 0;
const sourcePhotos = hasInline ? inlineImages : photos.map((p) => ({
  image: p.image,
  alt: p.image.altText ?? "",
  label: p.publicCaption ?? "",
}));

const toneOptions = ["green", "purple", "blue", "yellow"] as const;
const iconOptions = ["heart", "palette", "star", "book", "users"] as const;

const pageSize = 3;
const galleryPages = Array.from({ length: Math.ceil(sourcePhotos.length / pageSize) }, (_, i) => ({
  photos: sourcePhotos.slice(i * pageSize, i * pageSize + pageSize).map((photo, idx) => ({
    ...photo,
    tone: toneOptions[(i * pageSize + idx) % toneOptions.length],
    icon: iconOptions[(i * pageSize + idx) % iconOptions.length],
  })),
}));

const flatPhotos = galleryPages.flatMap((p) => p.photos);
const hasPhotos = flatPhotos.length > 0;
---

{hasPhotos ? (
<Section
  id="parents"
  class="lwk-gallery-section"
  width="wide"
  aria-labelledby="gallery-title"
>
  <div
    id="gallery"
    class="lwk-gallery"
    data-gallery
    role="group"
    aria-labelledby="gallery-title"
    aria-roledescription="carousel"
  >
    <header class="lwk-gallery__header">
      <div class="lwk-gallery-icon"><Icon name="sun" size={54} /></div>
      <h2 id="gallery-title">{homePage.galleryIntroTitle}</h2>

      <p>
        {homePage.galleryIntro}
      </p>
    </header>

    <div class="lwk-gallery__viewport">
      <div
        class="lwk-gallery__track"
        data-gallery-track
        tabindex="0"
        aria-label="Little Wise Kids photo gallery"
      >
        {
          galleryPages.map((page, pageIndex) => (
            <article
              class="lwk-gallery__page"
              id={`gallery-page-${pageIndex + 1}`}
              data-gallery-page
              role="group"
              aria-roledescription="slide"
              aria-label={`Gallery slide ${pageIndex + 1} of ${galleryPages.length}`}
            >
              {page.photos.map((photo, photoIndex) => {
                const globalIndex = pageIndex * pageSize + photoIndex;

                return (
                  <figure
                    class:list={[
                      "lwk-gallery__card",
                      photoIndex === 0 && "lwk-gallery__card--large",
                      `lwk-gallery__card--${photo.tone}`,
                    ]}
                    id={`gallery-photo-${globalIndex + 1}`}
                    data-gallery-card
                    aria-label={`${photo.label}, photo ${globalIndex + 1} of ${flatPhotos.length}`}
                  >
                    <SanityImage
                      image={photo.image}
                      alt={photo.alt}
                      widths={[480, 640, 800, 1200]}
                      sizes="(min-width: 72rem) 360px, (min-width: 48rem) 50vw, 100vw"
                      layout="constrained"
                    />

                    {photo.label && (
                    <figcaption class="lwk-gallery__label">
                      <span
                        class={`lwk-gallery__label-icon lwk-gallery__label-icon--${photo.tone}`}
                        aria-hidden="true"
                      >
                        <Icon name={photo.icon} size={21} />
                      </span>

                      <span>{photo.label}</span>
                    </figcaption>
                    )}
                  </figure>
                );
              })}
            </article>
          ))
        }
      </div>
    </div>

    <div class="lwk-gallery__controls" aria-label="Gallery controls">
      <button
        class="lwk-gallery__arrow lwk-gallery__arrow--previous"
        type="button"
        data-gallery-previous
        aria-label="Previous gallery slide"
      >
        <Icon name="arrowRight" size={24} />
      </button>

      <div
        class="lwk-gallery__dots lwk-gallery__dots--desktop"
        aria-label="Choose a gallery slide"
      >
        {
          galleryPages.map((_, index) => (
            <button
              class="lwk-gallery__dot"
              type="button"
              data-gallery-dot
              data-gallery-index={index}
              aria-label={`Go to gallery slide ${index + 1}`}
              aria-current={index === 0 ? "true" : undefined}
            />
          ))
        }
      </div>

      <div
        class="lwk-gallery__dots lwk-gallery__dots--mobile"
        aria-label="Choose a gallery photo"
      >
        {
          flatPhotos.map((_, index) => (
            <button
              class="lwk-gallery__dot"
              type="button"
              data-gallery-mobile-dot
              data-gallery-index={index}
              aria-label={`Go to gallery photo ${index + 1}`}
              aria-current={index === 0 ? "true" : undefined}
            />
          ))
        }
      </div>

      <p class="lwk-gallery__count" aria-live="polite" aria-atomic="true">
        <span data-gallery-current>1</span>
        <span aria-hidden="true">/</span>
        <span data-gallery-total>{galleryPages.length}</span>
      </p>

      <button
        class="lwk-gallery__arrow lwk-gallery__arrow--next"
        type="button"
        data-gallery-next
        aria-label="Next gallery slide"
      >
        <Icon name="arrowRight" size={24} />
      </button>
    </div>
  </div>
</Section>
) : null}

<script src="./GallerySection.ts"></script>
