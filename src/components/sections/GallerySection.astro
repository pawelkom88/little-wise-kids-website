<!-- src/components/sections/GallerySection.astro -->
---
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
import "../../styles/gallery-section.css";

const galleryPages = [
{
    photos: [
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/cminder_table1-pzej258v3czl2144padkre67zd10ydplgpms3uml1c.jpg",
        alt: "Children enjoying outdoor play at Little Wise Kids",
        label: "Outdoor Play",
        tone: "green",
        icon: "heart",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/artgallery2_o-pzgcyj2id2lpvh3en9iif8b6qdulcwwsmx7m2b2io0.jpg",
        alt: "A child exploring creative activities",
        label: "Creative Discovery",
        tone: "purple",
        icon: "palette",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/child_car-pzej1zltycrv4dcbm7xtcflgf1sto737fxpv86uy2o.jpg",
        alt: "Children sharing a happy moment together",
        label: "Happy Moments",
        tone: "blue",
        icon: "heart",
        },
    ],
    },
{
    photos: [
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/child_play3-pzej21hic0ufrl9lb8r2hf4dltjk3lao470u6qs5q8.jpg",
        alt: "A child learning through hands-on play",
        label: "Hands-on Play",
        tone: "yellow",
        icon: "star",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/girl_read-pzej05t4ny9sjnzwafhxhw76u2t4pdtzuw1vmtki68.jpg",
        alt: "A child enjoying story time",
        label: "Story Time",
        tone: "purple",
        icon: "book",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/girl_grass2-pzeizvgwkrvmzyewyt118gt4au83cpoy5gvjcrzu2o.jpg",
        alt: "A child exploring outdoors",
        label: "Outdoor Adventures",
        tone: "green",
        icon: "heart",
        },
    ],
    },
{
    photos: [
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/run_grass-pzeiyc0fdjrpyyngyn21ncsx93tfqkks9udw1ga29s.jpg",
        alt: "Children running and playing outside",
        label: "Fresh Air",
        tone: "blue",
        icon: "users",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/kitchen5-pzej0x2g65b3wcwav9a407bk292rwlu7mmyyjug35s.jpg",
        alt: "A child discovering new activities",
        label: "Curious Minds",
        tone: "yellow",
        icon: "star",
        },
    {
        src: "https://littlewisekids.co.uk/wp-content/uploads/elementor/thumbs/kitchen2-pzej1exdrzzk0y6cyz00tktbckmqyut413d6o3plvk.jpg",
        alt: "A child enjoying imaginative play",
        label: "Play to Learn",
        tone: "purple",
        icon: "palette",
        },
    ],
    },
] as const;

const galleryPhotos = galleryPages.flatMap((page) => page.photos);
---

<Section
    id="parents"
    class="lwk-gallery-section"
    width="wide"
    aria-labelledby="gallery-title"
>
  <div
      id="gallery"
      class="lwk-gallery"
      data-gallery
      aria-roledescription="carousel"
  >
    <span
        class="lwk-gallery__trail lwk-gallery__trail--left"
        aria-hidden="true"
    >
      <span>☆</span>
    </span>

    <span
        class="lwk-gallery__trail lwk-gallery__trail--right"
        aria-hidden="true"
    >
      <span>♡</span>
    </span>

    <header class="lwk-gallery__header">
      <span class="lwk-gallery__camera" aria-hidden="true">
        <span class="lwk-gallery__camera-body"></span>
      </span>

      <h2 id="gallery-title">Photo Gallery</h2>

      <p>
        A glimpse into the everyday wonder, growth, and joy at Little Wise Kids.
      </p>
    </header>

    <div class="lwk-gallery__viewport">
      <div
          class="lwk-gallery__track"
          data-gallery-track
          tabindex="0"
          aria-label="Little Wise Kids photo gallery"
      >
        {
          galleryPages.map((page, pageIndex) => (
              <article
                  class="lwk-gallery__page"
                  id={`gallery-page-${pageIndex + 1}`}
                  data-gallery-page
                  role="group"
                  aria-roledescription="slide"
                  aria-label={`Gallery slide ${pageIndex + 1} of ${galleryPages.length}`}
              >
                {page.photos.map((photo, photoIndex) => {
                  const globalIndex = pageIndex * page.photos.length + photoIndex;

                  return (
                      <figure
                          class:list={[
                            "lwk-gallery__card",
                            photoIndex === 0 && "lwk-gallery__card--large",
                            `lwk-gallery__card--${photo.tone}`,
                          ]}
                          id={`gallery-photo-${globalIndex + 1}`}
                          data-gallery-card
                          aria-label={`${photo.label}, photo ${globalIndex + 1} of ${galleryPhotos.length}`}
                      >
                        <img
                            src={photo.src}
                            alt={photo.alt}
                            width="1200"
                            height="900"
                            loading="lazy"
                            decoding="async"
                        />

                        <figcaption class="lwk-gallery__label">
                      <span
                          class={`lwk-gallery__label-icon lwk-gallery__label-icon--${photo.tone}`}
                          aria-hidden="true"
                      >
                        <Icon name={photo.icon} size={21} />
                      </span>

                          <span>{photo.label}</span>
                        </figcaption>
                      </figure>
                  );
                })}
              </article>
          ))
        }
      </div>
    </div>

    <div class="lwk-gallery__controls" aria-label="Gallery controls">
      <button
          class="lwk-gallery__arrow lwk-gallery__arrow--previous"
          type="button"
          data-gallery-previous
          aria-label="Previous gallery slide"
      >
        <Icon name="arrowRight" size={24} />
      </button>

      <div
          class="lwk-gallery__dots lwk-gallery__dots--desktop"
          aria-label="Choose a gallery slide"
      >
        {
          galleryPages.map((_, index) => (
              <button
                  class="lwk-gallery__dot"
                  type="button"
                  data-gallery-dot
                  data-gallery-index={index}
                  aria-label={`Go to gallery slide ${index + 1}`}
                  aria-current={index === 0 ? "true" : undefined}
              />
          ))
        }
      </div>

      <div
          class="lwk-gallery__dots lwk-gallery__dots--mobile"
          aria-label="Choose a gallery photo"
      >
        {
          galleryPhotos.map((_, index) => (
              <button
                  class="lwk-gallery__dot"
                  type="button"
                  data-gallery-mobile-dot
                  data-gallery-index={index}
                  aria-label={`Go to gallery photo ${index + 1}`}
                  aria-current={index === 0 ? "true" : undefined}
              />
          ))
        }
      </div>

      <p class="lwk-gallery__count" aria-live="polite" aria-atomic="true">
        <span data-gallery-current>1</span>
        <span aria-hidden="true">/</span>
        <span data-gallery-total>{galleryPages.length}</span>
      </p>

      <button
          class="lwk-gallery__arrow lwk-gallery__arrow--next"
          type="button"
          data-gallery-next
          aria-label="Next gallery slide"
      >
        <Icon name="arrowRight" size={24} />
      </button>
    </div>
  </div>
</Section>

<script>
  const initialiseGalleries = () => {
    document.querySelectorAll("[data-gallery]").forEach((gallery) => {
      if (gallery.dataset.galleryInitialised === "true") return;

      gallery.dataset.galleryInitialised = "true";

      const track = gallery.querySelector("[data-gallery-track]");
      const previousButton = gallery.querySelector("[data-gallery-previous]");
      const nextButton = gallery.querySelector("[data-gallery-next]");
      const currentElement = gallery.querySelector("[data-gallery-current]");
      const totalElement = gallery.querySelector("[data-gallery-total]");
      const desktopDots = Array.from(
          gallery.querySelectorAll("[data-gallery-dot]"),
      );
      const mobileDots = Array.from(
          gallery.querySelectorAll("[data-gallery-mobile-dot]"),
      );

      if (
          !track ||
          !previousButton ||
          !nextButton ||
          !currentElement ||
          !totalElement
      ) {
        return;
      }

      const mobileQuery = window.matchMedia("(max-width: 48rem)");
      const reducedMotionQuery = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
      );

      let activeIndex = 0;
      let scrollFrame = 0;

      const getTargets = () =>
          Array.from(
              gallery.querySelectorAll(
                  mobileQuery.matches
                      ? "[data-gallery-card]"
                      : "[data-gallery-page]",
              ),
          );

      const getActiveDots = () =>
          mobileQuery.matches ? mobileDots : desktopDots;

      const getTargetLeft = (target) => {
        const trackBounds = track.getBoundingClientRect();
        const targetBounds = target.getBoundingClientRect();

        return targetBounds.left - trackBounds.left + track.scrollLeft;
      };

      const updateControls = (index) => {
        const targets = getTargets();
        const dots = getActiveDots();

        activeIndex = Math.max(0, Math.min(index, targets.length - 1));

        currentElement.textContent = String(activeIndex + 1);
        totalElement.textContent = String(targets.length);

        previousButton.disabled = activeIndex === 0;
        nextButton.disabled = activeIndex === targets.length - 1;

        [...desktopDots, ...mobileDots].forEach((dot) => {
          dot.removeAttribute("aria-current");
        });

        dots[activeIndex]?.setAttribute("aria-current", "true");
      };

      const findClosestTarget = () => {
        const targets = getTargets();
        const trackLeft = track.getBoundingClientRect().left;

        return targets.reduce(
            (closest, target, index) => {
              const distance = Math.abs(
                  target.getBoundingClientRect().left - trackLeft,
              );

              return distance < closest.distance
                  ? { index, distance }
                  : closest;
            },
            { index: 0, distance: Number.POSITIVE_INFINITY },
        ).index;
      };

      const scrollToIndex = (index) => {
        const targets = getTargets();
        const nextIndex = Math.max(0, Math.min(index, targets.length - 1));
        const target = targets[nextIndex];

        if (!target) return;

        track.scrollTo({
          left: getTargetLeft(target),
          behavior: reducedMotionQuery.matches ? "auto" : "smooth",
        });

        updateControls(nextIndex);
      };

      previousButton.addEventListener("click", () => {
        scrollToIndex(activeIndex - 1);
      });

      nextButton.addEventListener("click", () => {
        scrollToIndex(activeIndex + 1);
      });

      [...desktopDots, ...mobileDots].forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.dataset.galleryIndex);

          if (Number.isFinite(index)) {
            scrollToIndex(index);
          }
        });
      });

      track.addEventListener("scroll", () => {
        window.cancelAnimationFrame(scrollFrame);

        scrollFrame = window.requestAnimationFrame(() => {
          updateControls(findClosestTarget());
        });
      });

      track.addEventListener("keydown", (event) => {
        if (event.key === "ArrowLeft") {
          event.preventDefault();
          scrollToIndex(activeIndex - 1);
        }

        if (event.key === "ArrowRight") {
          event.preventDefault();
          scrollToIndex(activeIndex + 1);
        }

        if (event.key === "Home") {
          event.preventDefault();
          scrollToIndex(0);
        }

        if (event.key === "End") {
          event.preventDefault();
          scrollToIndex(getTargets().length - 1);
        }
      });

      mobileQuery.addEventListener("change", () => {
        activeIndex = 0;
        track.scrollTo({ left: 0, behavior: "auto" });
        updateControls(0);
      });

      const resizeObserver = new ResizeObserver(() => {
        scrollToIndex(activeIndex);
      });

      resizeObserver.observe(track);
      updateControls(0);
    });
  };

  initialiseGalleries();
  document.addEventListener("astro:page-load", initialiseGalleries);
</script>