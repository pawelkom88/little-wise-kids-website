---
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
---

<Section id="approach" class="future-section" width="wide">
  <div class="future-grid">
    <div class="future-visual" aria-label="Little Wise Kids highlights">
      <div class="visual-card">
        <!-- TODO: Add image -->
        Image here
      </div>

      <div class="visual-card-grid">
        <div class="visual-card-small">
          <!-- TODO: Add image -->
          Image here
        </div>

        <div class="visual-card-small">
          <!-- TODO: Add image -->
          Image here
        </div>
      </div>
    </div>

    <div class="future-copy">
      <h2 class="future-title" id="future-title">
        A Place to
        <span class="tone-purple">Feel Safe</span>,
        <span class="tone-green">Seen</span>
        and
        <span class="tone-blue">Celebrated</span>
      </h2>

      <p class="future-lead">
        We created Little Wise Kids with one heartfelt intention: to offer the
        kind of environment we would want for our own children. Our setting is
        calm, loving and rich with purpose, designed to feel like an extension
        of family life.
      </p>

      <p class="future-lead">
        Here, children are encouraged to explore their interests, develop
        confidence and form meaningful relationships. We believe the early
        years are precious, and every day is an opportunity to support a
        child’s sense of wonder.
      </p>

      <div class="future-points" aria-label="About Little Wise Kids">
        <article class="future-point future-point--home">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="sun" size={25} />
          </span>

          <p>
            Screen-free learning, with meaningful real-world and tactile
            experiences
          </p>
        </article>

        <article class="future-point future-point--talent">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="star" size={25} />
          </span>

          <p>
            English and Portuguese language exposure for now, subject to
            change
          </p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>

          <p>A balance of indoor and outdoor learning</p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>

          <p>Child-led play that develops confidence and independence</p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>

          <p>Wholesome nutrition that supports growing bodies and minds</p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>

          <p>A warm, family-style environment in Bristol BS5</p>
        </article>
      </div>
    </div>
  </div>
<br>
<br>
</Section>
<Section
    class="closing-cta"
    width="wide"
    aria-labelledby="closing-cta-title"
>
  <svg
      class="closing-cta__wave"
      viewBox="0 0 1440 90"
      preserveAspectRatio="none"
      aria-hidden="true"
  >
    <path
        d="M0 38C189 4 340 67 568 42C822 14 1037 63 1240 42C1325 33 1387 35 1440 41V90H0V38Z"
        fill="currentColor"
    />
  </svg>

  <div class="closing-cta__inner">
    <div class="closing-cta__copy">
      <h2 class="closing-cta__title" id="closing-cta-title">
        Come See the <span>Magic</span> for Yourself
      </h2>

      <div class="closing-cta__text">
        <p>
          The best way to understand what makes Little Wise Kids special is to
          visit us. We would love to welcome you, introduce our team and help
          your child explore our calm, engaging space.
        </p>

        <p>
          Whether you are looking for nurturing childcare, a screen-free
          nursery in Bristol, or a setting that truly feels like a second home,
          we are here to help.
        </p>
      </div>

      <a class="closing-cta__button" href="/contact">
        Contact Us
      </a>
    </div>

    <div class="closing-cta__media" aria-label="Nursery image placeholder">
      <!-- TODO: Replace with image -->
      <span>Image here</span>
    </div>
  </div>
</Section>

<style>
  :global(.closing-cta) {
    position: relative;
    background: var(--color-cream);
    padding-top: var(--space-xl);
  }

  .closing-cta__wave {
    position: absolute;
    top: 1px;
    left: 0;
    width: 100%;
    height: clamp(3rem, 6vw, 5.5rem);
    color: var(--color-cream);
    pointer-events: none;
    transform: translateY(-99%);
  }

  .closing-cta__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(20rem, 0.8fr);
    gap: clamp(3rem, 8vw, 8rem);
    align-items: center;
    width: 100%;
    margin-inline: auto;
  }

  .closing-cta__copy {
    max-width: 48rem;
  }

  .closing-cta__title {
    margin: 0;
  }

  .closing-cta__title span {
    color: var(--color-green);
  }

  .closing-cta__text p {
    margin: 0;
  }

  .closing-cta__text p + p {
    margin-top: 1.25rem;
  }

  .closing-cta__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2rem;
    text-decoration: none;
  }

  .closing-cta__media {
    display: grid;
    width: min(100%, 32rem);
    min-height: clamp(25rem, 42vw, 36rem);
    place-items: center;
    justify-self: end;
    overflow: hidden;
    border-radius: 999px 999px 1.75rem 1.75rem;
    background: #eee9e1;
  }

  .closing-cta__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 64rem) {
    .closing-cta__inner {
      grid-template-columns: 1fr;
      max-width: 48rem;
    }

    .closing-cta__copy {
      max-width: none;
    }

    .closing-cta__media {
      width: 100%;
      max-width: 38rem;
      justify-self: start;
    }
  }

  @media (max-width: 40rem) {
    :global(.closing-cta) {
      padding-inline: 1.25rem;
    }

    .closing-cta__title {
      font-size: clamp(2.75rem, 13vw, 4rem);
    }

    .closing-cta__button {
      width: 100%;
      min-height: 4.25rem;
    }

    .closing-cta__media {
      min-height: 25rem;
      border-radius: 999px 999px 1.5rem 1.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .closing-cta__button {
      transition: none;
    }
  }
</style>