---
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
---

<Section id="approach" class="future-section" width="wide">
  <div class="future-grid">

    <div class="future-visual" aria-label="Little Wise Kids highlights">
      <div class="visual-card">
        <!--todo: give img-->
        image here
      </div>
<br>
      <div class="visual-card-grid">
      <div class="visual-card-small">
        <!--todo: give img-->
        image here
      </div>
      <div class="visual-card-small">
        <!--todo: give img-->
        image here
      </div>
      </div>
    </div>


    <div class="future-copy">
      <h2 class="future-title" id="future-title">
        A Place to <span class="tone-purple">Feel Safe</span>, <span class="tone-green">Seen</span> and <span class="tone-blue">Celebrated</span>
      </h2>

      <p class="future-lead">
        We created Little Wise Kids with one heartfelt intention: to offer the kind of environment we would want for our own children.
        Our setting is calm, loving and rich with purpose, designed to feel like an extension of family life.
      </p>
      <p class="future-lead">
        Here, children are encouraged to explore their interests, develop confidence and form meaningful relationships. We believe
        the early years are precious, and every day is an opportunity to support a child’s sense of wonder.
      </p>

      <div class="future-points" aria-label="About Little Wise Kids">
        <article class="future-point future-point--home">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="sun" size={25} />
          </span>
          <p>
            Screen-free learning, with meaningful real-world and tactile experiences
          </p>
        </article>

        <article class="future-point future-point--talent">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="star" size={25} />
          </span>
          <p>
            English and Portuguese language exposure for now, subject to change
          </p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>
          <p>
            A balance of indoor and outdoor learning
          </p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>
          <p>
            Child-led play that develops confidence and independence
          </p>
        </article>


        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>
          <p>
            Wholesome nutrition that supports growing bodies and minds
          </p>
        </article>

        <article class="future-point future-point--language">
          <span class="future-point__icon" aria-hidden="true">
            <Icon name="chat" size={25} />
          </span>
          <p>
            A warm, family-style environment in Bristol BS5
          </p>
        </article>

      </div>
    </div>


  </div>
</Section>
