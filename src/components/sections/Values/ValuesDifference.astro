---
import multilingualBubble from "../../../../assets/icons/bubble-multilingual.png";
import heartBubble from "../../../../assets/icons/bubble-heart-with-smile.png";
import artBubble from "../../../../assets/icons/bubble-art.png";
import peopleBubble from "../../../../assets/icons/bubble-people.png";
import outdoorBubble from "../../../../assets/icons/bubble-outdoor.png";
import nutritionBubble from "../../../../assets/icons/bubble-nutrition.png";
import "./ValuesDifference.css";

interface Props {
  homePage: any;
}

const { homePage } = Astro.props;

const cards = [
  {
    tone: "blue",
    image: artBubble,
    title: homePage.screenFreeCard.title,
    copy: homePage.screenFreeCard.description,
  },
  {
    tone: "purple",
    image: multilingualBubble,
    title: homePage.multilingualCard.title,
    copy: homePage.multilingualCard.description,
  },
  {
    tone: "green",
    image: outdoorBubble,
    title: homePage.indoorOutdoorCard.title,
    copy: homePage.indoorOutdoorCard.description,
  },
  {
    tone: "yellow",
    image: peopleBubble,
    title: homePage.childLedCard.title,
    copy: homePage.childLedCard.description,
  },
  {
    tone: "orange",
    image: nutritionBubble,
    title: homePage.nutritionCard.title,
    copy: homePage.nutritionCard.description,
  },
  {
    tone: "pink",
    image: heartBubble,
    title: homePage.familySettingCard.title,
    copy: homePage.familySettingCard.description,
  },
] as const;
---

<section
  class="lwk-values-difference"
  aria-labelledby="difference-title"
  data-values-difference
>
  <header class="lwk-values-heading" data-values-difference-heading>
    <span
      class="lwk-values-heading__rays
        lwk-values-heading__rays--left"
      aria-hidden="true"
    >
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
    </span>

    <h2 id="difference-title">{homePage.valuesDifferenceTitle}</h2>

    <span
      class="lwk-values-heading__rays
        lwk-values-heading__rays--right"
      aria-hidden="true"
    >
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
    </span>
  </header>

  <div class="lwk-values-heading__dots" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="lwk-values-grid">
    {
      cards.map((card) => (
        <article class={`lwk-value-card lwk-value-card--${card.tone}`}>
          <div class="lwk-value-card__image" aria-hidden="true">
            <img
              src={card.image.src}
              alt=""
              width="176"
              height="176"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="lwk-value-card__content">
            <h3
              class={`lwk-value-card__title lwk-value-card__title--${card.tone}`}
            >
              {card.title}
            </h3>

            <p>{card.copy}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<script src="./ValuesDifference.ts"></script>
