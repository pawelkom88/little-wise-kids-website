---
import multilingualBubble from "../../../../assets/icons/bubble-multilingual.png";
import heartBubble from "../../../../assets/icons/bubble-heart-with-smile.png";
import artBubble from "../../../../assets/icons/bubble-art.png";
import peopleBubble from "../../../../assets/icons/bubble-people.png";
import { site } from "../../../data/site";
import "./ValuesDifference.css";

const formatLanguages = (languages: readonly string[]) => {
  if (languages.length === 0) return "";
  if (languages.length === 1) return languages[0];
  return `${languages.slice(0, -1).join(", ")} and ${languages[languages.length - 1]}`;
};

const cards = [
  {
    tone: "purple",
    image: multilingualBubble,
    title: "Multilingual Learning",
    copy: `We currently introduce ${formatLanguages(site.languages)} through songs, stories and everyday moments, helping children communicate, connect and enjoy language naturally.`,
  },
  {
    tone: "green",
    image: heartBubble,
    title: "Safe & Caring",
    copy: "In our warm, family-style setting in Bristol BS5, children feel secure, loved and respected, with wholesome food supporting growing bodies and minds.",
  },
  {
    tone: "blue",
    image: artBubble,
    title: "Creative Play",
    copy: "Through screen-free, child-led play and tactile real-world experiences, children build confidence, independence, curiosity and a love of learning.",
  },
  {
    tone: "yellow",
    image: peopleBubble,
    title: "Parent Partnership",
    copy: "We work closely with families to create a balanced rhythm of indoor and outdoor learning, supporting each child’s unique needs and development.",
  },
] as const;
---

<section
  class="lwk-values-difference"
  aria-labelledby="difference-title"
  data-values-difference
>
  <header class="lwk-values-heading" data-values-difference-heading>
    <span
      class="lwk-values-heading__rays
        lwk-values-heading__rays--left"
      aria-hidden="true"
    >
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
    </span>

    <h2 id="difference-title">What Makes Us Different</h2>

    <span
      class="lwk-values-heading__rays
        lwk-values-heading__rays--right"
      aria-hidden="true"
    >
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
      <span class="lwk-values-heading__ray"></span>
    </span>
  </header>

  <div class="lwk-values-heading__dots" aria-hidden="true">
    <span></span>
    <span></span>
    <span></span>
    <span></span>
  </div>

  <div class="lwk-values-grid">
    {
      cards.map((card) => (
        <article class={`lwk-value-card lwk-value-card--${card.tone}`}>
          <div class="lwk-value-card__image" aria-hidden="true">
            <img
              src={card.image.src}
              alt=""
              width="176"
              height="176"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="lwk-value-card__content">
            <h3
              class={`lwk-value-card__title lwk-value-card__title--${card.tone}`}
            >
              {card.title}
            </h3>

            <p>{card.copy}</p>
          </div>
        </article>
      ))
    }
  </div>
</section>

<script src="./ValuesDifference.ts"></script>
