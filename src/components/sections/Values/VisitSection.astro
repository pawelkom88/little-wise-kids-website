---
import Icon from "../../icons/Icon.astro";
import Button from "../../ui/Button.astro";
import "./VisitSection.css";
---

<section class="lwk-visit" aria-labelledby="visit-title">
  <div class="lwk-visit__layout">
    <div class="lwk-visit__content">
      <h2 class="lwk-visit__title" id="visit-title">
        Come See the <span>Magic</span>
        <br />
        for Yourself
      </h2>

      <div class="lwk-title-rule lwk-title-rule--left" aria-hidden="true">
        <span></span><i></i><span></span>
      </div>

      <div class="lwk-visit__copy">
        <p>
          The best way to understand what makes Little Wise Kids special is to
          visit us. We would love to welcome you, introduce our team and help
          your child explore our calm, engaging space.
        </p>

        <p>
          Whether you are looking for nurturing childcare, a screen-free nursery
          in Bristol, or a setting that truly feels like a second home, we are
          here to help.
        </p>
      </div>

      <div class="lwk-visit__actions">
        <Button href="/#contact" class="lwk-visit__primary">
          Contact us
        </Button>
      </div>
    </div>

    <figure class="lwk-visit-media">
      <div class="lwk-visit-media__decor" aria-hidden="true">
        <span class="lwk-visit-media__blob"></span>
        <span class="lwk-visit-media__dots"></span>
        <span class="lwk-visit-media__heart"
          ><Icon name="heart" size={42} /></span
        >
        <span class="lwk-visit-media__star"><Icon name="star" size={46} /></span
        >
      </div>

      <div class="lwk-visit-media__image">
        <img
          src=""
          alt="???"
          width="1200"
          height="800"
          loading="lazy"
          decoding="async"
        />
      </div>

      <figcaption class="lwk-visit-testimonial">
        <blockquote>
          “From the moment we walked in, we felt at ease. Our daughter loves it
          here, and so do we.”
        </blockquote>
        <p>— Little Wise Kids parent</p>
      </figcaption>
    </figure>
  </div>
</section>
