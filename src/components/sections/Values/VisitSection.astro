---
import Icon from "../../icons/Icon.astro";
import Button from "../../ui/Button.astro";
import PortableContent from "../../content/PortableContent.astro";
import SanityImage from "../../media/SanityImage.astro";
import "./VisitSection.css";

import type { HomePage } from "../../../lib/types";

interface Props {
  homePage: HomePage;
}

const { homePage } = Astro.props;
---

<section class="lwk-visit" aria-labelledby="visit-title">
  <div class="lwk-visit__layout">
    <div class="lwk-visit__content">
      <h2 class="lwk-visit__title" id="visit-title">
        {homePage.visitHeading.lineOnePrefix} <span>{homePage.visitHeading.accentedPhrase}</span>
        <br />
        {homePage.visitHeading.lineTwo}
      </h2>

      <div class="lwk-title-rule lwk-title-rule--left" aria-hidden="true">
        <span></span><i></i><span></span>
      </div>

      <div class="lwk-visit__copy">
        <PortableContent value={homePage.visitParagraphs} />
      </div>
<br>
        <Button href="/contact#contact-form"> {homePage.visitCtaLabel} </Button>
    </div>
<br>
    <figure class="lwk-visit-media">
      <div class="lwk-visit-media__decor" aria-hidden="true">
        <span class="lwk-visit-media__dots"></span>
        <span class="lwk-visit-media__heart"
          ><Icon name="heart" size={42} /></span
        >
        <span class="lwk-visit-media__star"><Icon name="star" size={46} /></span
        >
      </div>

      <div class="lwk-visit-media__image">
        {
          homePage.visitImage?.asset?._ref ? (
            <SanityImage
              image={homePage.visitImage}
              alt={homePage.visitImage.isDecorative ? "" : homePage.visitImage.altText ?? ""}
              widths={[480, 640, 800, 1200]}
              sizes="(min-width: 72rem) 560px, 100vw"
              layout="constrained"
            />
          ) : (
            <div class="image-placeholder" aria-hidden="true" />
          )
        }
      </div>

      <figcaption class="lwk-visit-testimonial">
        <blockquote>
          “{homePage.testimonialQuote}”
        </blockquote>
        <p>— {homePage.testimonialAttribution}</p>
      </figcaption>
    </figure>
  </div>
</section>
