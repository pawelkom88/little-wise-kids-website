---
import Section from "../layout/Section.astro";
import multilingualBubble from "../../../assets/icons/bubble-multilingual.png";
import heartBubble from "../../../assets/icons/bubble-heart-with-smile.png";
import artBubble from "../../../assets/icons/bubble-art.png";
import peopleBubble from "../../../assets/icons/bubble-people.png";

const cards = [
  {
    tone: "purple",
    image: multilingualBubble,
    title: ["Multilingual", "Learning"],
    copy:
      "We introduce languages through songs, stories and everyday moments, helping children connect, communicate and celebrate the world around them.",
  },
  {
    tone: "green",
    image: heartBubble,
    title: ["Safe & Caring"],
    copy:
      "Your child’s wellbeing comes first. We provide secure, nurturing environments where children feel loved, respected and free to be themselves.",
  },
  {
    tone: "blue",
    image: artBubble,
    title: ["Creative Play"],
    copy:
      "Through imaginative play, art, music and hands-on exploration, children build confidence, spark curiosity and develop a love for learning.",
  },
  {
    tone: "yellow",
    image: peopleBubble,
    title: ["Parent Partnership"],
    copy:
      "We believe strong partnerships create the best outcomes. We work closely with families to support each child’s unique journey.",
  },
] as const;
---
<br>
<Section id="activities" class="values-section" width="wide">
  <div class="values-shell" aria-labelledby="values-title">
    <header class="values-section__header">
      <h2 class="values-section__title" id="values-title">
        <span class="values-section__title-line">
          Nurturing <span class="is-purple">Little Minds,</span>
        </span>
        <span class="values-section__title-line">
          Inspiring <span class="is-blue">Bright Futures</span>
        </span>
      </h2>
      <p class="values-section__subtitle">
        Every day is a chance to learn, grow and shine at Little Wise Kids.
      </p>
    </header>

    <div class="values-grid">
      {
        cards.map((card) => (
          <article class={`value-card value-card--${card.tone}`}>
            <div class={`value-card__badge value-card__badge--${card.tone}`} aria-hidden="true">
              <img src={card.image.src} alt="" loading="lazy" />
            </div>

            <div class="value-card__content">
              <h3 class={`value-card__heading value-card__heading--${card.tone}`}>
                {card.title.map((line) => <span>{line}</span>)}
              </h3>
              <p class="value-card__copy">{card.copy}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Section>
<br>

<style>
  .values-shell {
    position: relative;
    overflow: hidden;
    margin: 0 auto;
  }

  .values-section__header {
    position: relative;
    z-index: 1;
    max-width: 850px;
    margin: 0 auto 36px;
    text-align: center;
  }

  .values-section__title {
    margin: 14px 0 16px;
    color: var(--color-ink);
    letter-spacing: -0.045em;
  }

  .values-section__title-line {
    display: block;
  }

  .values-section__title .is-purple {
    color: var(--color-purple);
  }

  .values-section__title .is-blue {
    color: var(--color-blue);
  }

  .values-section__subtitle {
    margin: 0;
  }

  .values-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 30px;
    background: var(--color-page);
  }

  .values-grid .value-card {
    position: relative;
    display: grid;
    grid-template-columns: 186px 1fr;
    gap: 22px;
    align-items: center;
    min-height: 302px;
    padding: 34px 34px 30px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-l);
  }

  .value-card--purple {
    background: var(--color-purple-soft);
  }

  .value-card--green {
    background: var(--color-green-soft);
  }

  .value-card--blue {
    background: var(--color-blue-soft);
  }

  .value-card--yellow {
    background: var(--color-yellow-soft);
  }

  .value-card__badge {
    position: relative;
    display: grid;
    width: 176px;
    height: 176px;
    flex-shrink: 0;
    place-items: center;
    overflow: hidden;
    border-radius: 50%;
  }

  .value-card__badge img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .value-card__content {
    min-width: 0;
    align-self: center;
  }

  .value-card__heading {
    margin: 0 0 12px;
    letter-spacing: -0.035em;
  }

  .value-card__heading span {
    display: block;
  }

  .value-card__heading--purple {
    color: var(--color-purple-dark);
  }

  .value-card__heading--green {
    color: var(--color-green-dark);
  }

  .value-card__heading--blue {
    color: var(--color-blue-dark);
  }

  .value-card__heading--yellow {
    color: color-mix(in srgb, var(--color-yellow), black 18%);
  }

  .values-grid .value-card__copy {
    max-width: 420px;
    margin: 0;
    color: var(--color-ink-soft);
  }

  @media (width < 64rem) {
    .values-grid {
      gap: 22px;
    }

    .values-grid .value-card {
      grid-template-columns: 150px 1fr;
      min-height: 280px;
      padding: 28px 28px 26px;
    }

    .value-card__badge {
      width: 144px;
      height: 144px;
    }

  }

  @media (width < 48rem) {
    .values-shell {
      padding-inline: 12px;
    }

    .values-section__blob--top-left {
      width: 112px;
      height: 74px;
    }

    .values-section__blob--right {
      right: -22px;
      width: 78px;
      height: 160px;
    }

    .values-section__decor--left-line {
      top: 94px;
      left: -18px;
      width: 150px;
    }

    .values-section__decor--star-left {
      top: 128px;
      left: 122px;
      width: 34px;
      height: 34px;
    }

    .values-section__decor--plane {
      top: 62px;
      right: 24px;
      width: 108px;
      height: 88px;
    }

    .values-section__header {
      margin-bottom: 28px;
      padding-inline: 10px;
    }

    .values-section__title {
      margin-top: 12px;
      margin-bottom: 12px;
    }

    .values-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .values-grid .value-card {
      grid-template-columns: 1fr;
      gap: 20px;
      min-height: 0;
      padding: 24px 22px;
    }

    .value-card__badge {
      width: 124px;
      height: 124px;
      margin-left: 8px;
    }

    .value-card__content {
      padding-right: 22px;
    }

    .value-card__heading {
      margin-bottom: 10px;
    }

    .values-grid .value-card__copy {
      max-width: none;
    }

    .value-card__doodle--purple-burst,
    .value-card__doodle--green-burst,
    .value-card__doodle--blue-burst,
    .value-card__doodle--yellow-burst {
      top: 22px;
      left: 14px;
      width: 40px;
      height: 40px;
    }

    .value-card__doodle--purple-corner,
    .value-card__doodle--green-corner,
    .value-card__doodle--blue-corner,
    .value-card__doodle--yellow-corner {
      right: 16px;
      bottom: 14px;
    }
  }
</style>
