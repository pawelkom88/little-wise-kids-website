---
import Section from "../layout/Section.astro";
import Icon from "../icons/Icon.astro";
import Button from "../ui/Button.astro";

import visitImage from "../../../assets/images/hero-image.png";
import multilingualBubble from "../../../assets/icons/bubble-multilingual.png";
import heartBubble from "../../../assets/icons/bubble-heart-with-smile.png";
import artBubble from "../../../assets/icons/bubble-art.png";
import peopleBubble from "../../../assets/icons/bubble-people.png";
import planeIcon from "../../../assets/icons/plane-icon.svg";

const cards = [
  {
    tone: "purple",
    image: multilingualBubble,
    title: "Multilingual Learning",
    copy:
      "We currently introduce English and Portuguese through songs, stories and everyday moments, helping children communicate, connect and enjoy language naturally.",
  },
  {
    tone: "green",
    image: heartBubble,
    title: "Safe & Caring",
    copy:
      "In our warm, family-style setting in Bristol BS5, children feel secure, loved and respected, with wholesome food supporting growing bodies and minds.",
  },
  {
    tone: "blue",
    image: artBubble,
    title: "Creative Play",
    copy:
      "Through screen-free, child-led play and tactile real-world experiences, children build confidence, independence, curiosity and a love of learning.",
  },
  {
    tone: "yellow",
    image: peopleBubble,
    title: "Parent Partnership",
    copy:
      "We work closely with families to create a balanced rhythm of indoor and outdoor learning, supporting each child’s unique needs and development.",
  },
] as const;

const visitHighlights = [
  {
    tone: "purple",
    icon: "heartSmile",
    title: "Warm Welcome",
    copy: "A friendly hello from our caring team.",
  },
  {
    tone: "green",
    icon: "users",
    title: "Meet the Team",
    copy: "Get to know the people who care for your child.",
  },
  {
    tone: "blue",
    icon: "book",
    title: "Calm Setting",
    copy: "Explore our peaceful, inspiring environment.",
  },
] as const;
---

<Section id="activities" class="lwk-values" width="wide">
  <div class="lwk-values__stack">
    <section class="lwk-values-intro" aria-labelledby="values-title">
      <div class="lwk-values-intro__decor" aria-hidden="true">
        <span class="lwk-values-intro__icon lwk-values-intro__icon--star">
          <Icon name="star" size={54} />
        </span>

        <span class="lwk-values-intro__icon lwk-values-intro__icon--heart">
          <Icon name="heart" size={42} />
        </span>

        <span class="lwk-values-intro__spark"></span>
        <span class="lwk-values-intro__cloud"></span>
        <span class="lwk-values-intro__blob"></span>
        <span class="lwk-values-intro__dots"></span>

        <span class="lwk-values-intro__flight">
          <span class="lwk-values-intro__flight-line"></span>
          <img src={planeIcon.src} alt="" width="130" height="66" />
        </span>
      </div>

      <div class="lwk-values-intro__content">
        <p class="lwk-pill">
          <Icon name="heart" size={16} />
          Little Wise Kids
        </p>

        <h2 class="lwk-values-intro__title" id="values-title">
          <span>A Place to</span>
          <span>
            <span class="lwk-tone-purple">Feel Safe,</span>
            <span class="lwk-tone-green">Seen</span>
          </span>
          <span>
            and <span class="lwk-tone-blue">Celebrated</span>
          </span>
        </h2>

        <div class="lwk-title-rule" aria-hidden="true">
          <span></span><i></i><span></span>
        </div>

        <div class="lwk-values-intro__copy">
          <p>
            We created Little Wise Kids with one heartfelt intention: to offer
            the kind of environment we would want for our own children. Our
            setting is calm, loving and rich with purpose, designed to feel like
            an extension of family life.
          </p>

          <span class="lwk-values-intro__copy-heart" aria-hidden="true">
            <Icon name="heart" size={18} />
          </span>

          <p>
            Here, children are encouraged to explore their interests, develop
            confidence and form meaningful relationships. We believe the early
            years are precious, and every day is an opportunity to support a
            child’s sense of wonder.
          </p>
        </div>
      </div>
    </section>

    <section class="lwk-values-difference" aria-labelledby="difference-title">
      <header class="lwk-values-heading">
        <span class="lwk-values-heading__rays" aria-hidden="true"></span>
        <h2 id="difference-title">What Makes Us Different</h2>
        <span class="lwk-values-heading__rays lwk-values-heading__rays--right" aria-hidden="true"></span>
      </header>

      <div class="lwk-values-heading__dots" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>

      <div class="lwk-values-grid">
        {
          cards.map((card) => (
            <article class={`lwk-value-card lwk-value-card--${card.tone}`}>
              <div class="lwk-value-card__image" aria-hidden="true">
                <img
                  src={card.image.src}
                  alt=""
                  width="176"
                  height="176"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="lwk-value-card__content">
                <h3 class={`lwk-value-card__title lwk-value-card__title--${card.tone}`}>
                  {card.title}
                </h3>
                <p>{card.copy}</p>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="lwk-visit" aria-labelledby="visit-title">
      <div class="lwk-visit__wave" aria-hidden="true"></div>

      <div class="lwk-visit__layout">
        <div class="lwk-visit__content">
          <p class="lwk-pill lwk-pill--left">
            <Icon name="heart" size={16} />
            Visit Little Wise Kids
          </p>

          <h2 class="lwk-visit__title" id="visit-title">
            Come See the <span>Magic</span>
            <br />
            for Yourself
          </h2>

          <div class="lwk-title-rule lwk-title-rule--left" aria-hidden="true">
            <span></span><i></i><span></span>
          </div>

          <div class="lwk-visit__copy">
            <p>
              The best way to understand what makes Little Wise Kids special is
              to visit us. We would love to welcome you, introduce our team and
              help your child explore our calm, engaging space.
            </p>

            <p>
              Whether you are looking for nurturing childcare, a screen-free
              nursery in Bristol, or a setting that truly feels like a second
              home, we are here to help.
            </p>
          </div>

          <div class="lwk-visit-highlights" aria-label="What to expect during your visit">
            {
              visitHighlights.map((item) => (
                <article class={`lwk-visit-highlight lwk-visit-highlight--${item.tone}`}>
                  <span class="lwk-visit-highlight__icon" aria-hidden="true">
                    <Icon name={item.icon} size={24} />
                  </span>

                  <div>
                    <h3>{item.title}</h3>
                    <p>{item.copy}</p>
                  </div>
                </article>
              ))
            }
          </div>

          <div class="lwk-visit__actions">
            <Button href="/contact" icon="calendar" class="lwk-visit__primary">
              Book a Visit
            </Button>

            <a class="lwk-visit__secondary" href="/contact">
              Get in Touch
              <span aria-hidden="true"><Icon name="arrowRight" size={18} /></span>
            </a>
          </div>

          <p class="lwk-visit__note">Spots are limited — book your visit today.</p>
        </div>

        <figure class="lwk-visit-media">
          <div class="lwk-visit-media__decor" aria-hidden="true">
            <span class="lwk-visit-media__blob"></span>
            <span class="lwk-visit-media__dots"></span>
            <span class="lwk-visit-media__heart"><Icon name="heart" size={42} /></span>
            <span class="lwk-visit-media__star"><Icon name="star" size={46} /></span>
          </div>

          <div class="lwk-visit-media__image">
            <img
              src={visitImage.src}
              alt="A child learning through play at Little Wise Kids"
              width={visitImage.width}
              height={visitImage.height}
              loading="lazy"
              decoding="async"
            />
          </div>

          <figcaption class="lwk-visit-testimonial">
            <blockquote>
              “From the moment we walked in, we felt at ease. Our daughter loves
              it here, and so do we.”
            </blockquote>
            <p>— Little Wise Kids parent</p>
          </figcaption>
        </figure>
      </div>
    </section>
  </div>
</Section>
