---
import Section from "../layout/Section.astro";
import multilingualBubble from "../../../assets/icons/bubble-multilingual.png";
import heartBubble from "../../../assets/icons/bubble-heart-with-smile.png";
import artBubble from "../../../assets/icons/bubble-art.png";
import peopleBubble from "../../../assets/icons/bubble-people.png";

const cards = [
  {
    tone: "purple",
    image: multilingualBubble,
    title: ["Multilingual", "Learning"],
    copy:
      "We currently introduce English and Portuguese through songs, stories and everyday moments, helping children communicate, connect and enjoy language naturally.",
  },
  {
    tone: "green",
    image: heartBubble,
    title: ["Safe & Caring"],
    copy:
      "In our warm, family-style setting in Bristol BS5, children feel secure, loved and respected, with wholesome food supporting growing bodies and minds.",
  },
  {
    tone: "blue",
    image: artBubble,
    title: ["Creative Play"],
    copy:
      "Through screen-free, child-led play and tactile real-world experiences, children build confidence, independence, curiosity and a love of learning.",
  },
  {
    tone: "yellow",
    image: peopleBubble,
    title: ["Parent Partnership"],
    copy:
      "We work closely with families to create a balanced rhythm of indoor and outdoor learning, supporting each child’s unique needs and development.",
  },
] as const;
---
<Section id="activities" class="values-section" width="wide">
  <div class="values-shell" aria-labelledby="values-title">
    <header class="values-section__header">
      <h2 class="values-section__title" id="values-title">
        <span class="values-section__title-line">
          A Place to <span class="is-purple">Feel Safe,</span>
        </span>
        <span class="is-green">Seen</span> and
           <span class="is-blue">Celebrated</span>
      </h2>
      <br>
      <p class="values-section__subtitle">
        We created Little Wise Kids with one heartfelt intention: to offer the kind of environment we would want for our own children.
        Our setting is calm, loving and rich with purpose, designed to feel like an extension of family life.
        </p>
      <br>
      <p class="values-section__subtitle">
        Here, children are encouraged to explore their interests, develop confidence and form meaningful relationships. We believe
        the early years are precious, and every day is an opportunity to support a child’s sense of wonder.
      </p>
    </header>
<br>
    <h2 class="values-section__title">What Makes Us Different</h2>
    <br>
    <div class="values-grid">
      {
        cards.map((card) => (
          <article class={`value-card value-card--${card.tone}`}>
            <div class={`value-card__badge value-card__badge--${card.tone}`} aria-hidden="true">
              <img src={card.image.src} alt="" loading="lazy" />
            </div>

            <div class="value-card__content">
              <h3 class={`value-card__heading value-card__heading--${card.tone}`}>
                {card.title.map((line) => <span>{line}</span>)}
              </h3>
              <p class="value-card__copy">{card.copy}</p>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</Section>
  <svg class="wave" viewBox="0 0 1448 120" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"></path>
  </svg>
<br>
<br>




<Section
    class="closing-cta"
    width="wide"
    aria-labelledby="closing-cta-title"
>
  <svg
      class="closing-cta__wave"
      viewBox="0 0 1440 90"
      preserveAspectRatio="none"
      aria-hidden="true"
  >
    <path
        d="M0 38C189 4 340 67 568 42C822 14 1037 63 1240 42C1325 33 1387 35 1440 41V90H0V38Z"
        fill="currentColor"
    />
  </svg>

  <div class="closing-cta__inner">
    <div class="closing-cta__copy">
      <h2 class="closing-cta__title" id="closing-cta-title">
        Come See the <span>Magic</span> for Yourself
      </h2>

      <div class="closing-cta__text">
        <p>
          The best way to understand what makes Little Wise Kids special is to
          visit us. We would love to welcome you, introduce our team and help
          your child explore our calm, engaging space.
        </p>

        <p>
          Whether you are looking for nurturing childcare, a screen-free
          nursery in Bristol, or a setting that truly feels like a second home,
          we are here to help.
        </p>
      </div>

      <a class="closing-cta__button" href="/contact">
        Contact Us
      </a>
    </div>

    <div class="closing-cta__media" aria-label="Nursery image placeholder">
      <!-- TODO: Replace with image -->
      <span>Image here</span>
    </div>
  </div>
</Section>


<style>
  .wave-container {
    position: relative;
    overflow: hidden;
  }

  .wave {
    z-index: 1;
    left: 0;
    top: 0;
    width: 100%;
    fill: var(--color-cream);
    transform: rotate(180deg);
  }

  .values-section {
    background: var(--color-cream);
    position: relative;
  }

  .values-shell {
    position: relative;
    overflow: hidden;
    margin: 0 auto;
  }

  .values-section__header {
    position: relative;
    z-index: 1;
    max-width: 850px;
    margin: 0 auto var(--space-l);
    text-align: center;
  }

  .values-section__title {
    letter-spacing: -0.045em;
    text-align: center;
  }

  .values-section__title-line {
    display: block;
  }

  .values-section__title .is-purple {
    color: var(--color-purple);
  }

  .values-section__title .is-blue {
    color: var(--color-blue);
  }

  .values-section__title .is-green {
    color: var(--color-green);
  }

  .values-section__subtitle {
    text-wrap: pretty;
  }

  .values-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px 30px;
    background: inherit;
  }

  .values-grid .value-card {
    position: relative;
    display: grid;
    grid-template-columns: 186px 1fr;
    gap: 22px;
    align-items: center;
    min-height: 302px;
    padding: 34px 34px 30px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-l);
  }

  .value-card--purple {
    background: var(--color-purple-soft);
  }

  .value-card--green {
    background: var(--color-green-soft);
  }

  .value-card--blue {
    background: var(--color-blue-soft);
  }

  .value-card--yellow {
    background: var(--color-yellow-soft);
  }

  .value-card__badge {
    position: relative;
    display: grid;
    width: 176px;
    height: 176px;
    flex-shrink: 0;
    place-items: center;
    overflow: hidden;
    border-radius: 50%;
  }

  .value-card__badge img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .value-card__content {
    min-width: 0;
    align-self: center;
  }

  .value-card__heading {
    margin: 0 0 12px;
    letter-spacing: -0.035em;
  }

  .value-card__heading span {
    display: block;
  }

  .value-card__heading--purple {
    color: var(--color-purple-dark);
  }

  .value-card__heading--green {
    color: var(--color-green-dark);
  }

  .value-card__heading--blue {
    color: var(--color-blue-dark);
  }

  .value-card__heading--yellow {
    color: color-mix(in srgb, var(--color-yellow), black 18%);
  }

  .values-grid .value-card__copy {
    max-width: 420px;
    margin: 0;
    color: var(--color-ink-soft);
  }

  @media (width < 64rem) {
    .values-grid {
      gap: 22px;
    }

    .values-grid .value-card {
      place-items: center;
      text-align: center;
      grid-template-columns: 1fr;
    }

    .value-card__badge {
      width: 144px;
      height: 144px;
    }

  }

  @media (width < 48rem) {
    .values-shell {
      padding-inline: 12px;
    }

    .values-section__blob--top-left {
      width: 112px;
      height: 74px;
    }

    .values-section__blob--right {
      right: -22px;
      width: 78px;
      height: 160px;
    }

    .values-section__decor--left-line {
      top: 94px;
      left: -18px;
      width: 150px;
    }

    .values-section__decor--star-left {
      top: 128px;
      left: 122px;
      width: 34px;
      height: 34px;
    }

    .values-section__decor--plane {
      top: 62px;
      right: 24px;
      width: 108px;
      height: 88px;
    }

    .values-section__header {
      margin-bottom: 28px;
      padding-inline: 10px;
    }

    .values-section__title {
      margin-top: 12px;
      margin-bottom: 12px;
    }

    .values-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .values-grid .value-card {
      grid-template-columns: 1fr;
      gap: 20px;
      min-height: 0;
      padding: 24px 22px;
    }

    .value-card__badge {
      width: 124px;
      height: 124px;
      margin-left: 8px;
    }

    .value-card__heading {
      margin-bottom: 10px;
    }

    .values-grid .value-card__copy {
      max-width: none;
    }

    .value-card__doodle--purple-burst,
    .value-card__doodle--green-burst,
    .value-card__doodle--blue-burst,
    .value-card__doodle--yellow-burst {
      top: 22px;
      left: 14px;
      width: 40px;
      height: 40px;
    }

    .value-card__doodle--purple-corner,
    .value-card__doodle--green-corner,
    .value-card__doodle--blue-corner,
    .value-card__doodle--yellow-corner {
      right: 16px;
      bottom: 14px;
    }
  }
</style>
