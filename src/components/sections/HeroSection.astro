---
import Container from "../layout/Container.astro";
import Button from "../ui/Button.astro";
import PortableContent from "../content/PortableContent.astro";
import { Image } from "astro:assets";
import heroBgImage from "../../assets/images/littlewisekids-outdoor-hero-image.webp";
import heroVideoMp4 from "../../assets/videos/littlewisekids-hero-mobile.mp4?url";
import heroVideoWebm from "../../assets/videos/littlewisekids-hero-mobile.webm?url";
import "../media/VideoModal.css";
import "./HeroSection.css";
import type { HomePage, BusinessDetails } from "../../lib/types";

interface Props {
  homePage: HomePage;
  businessDetails: BusinessDetails;
}

const { homePage } = Astro.props;
---

<section class="hero-section" aria-labelledby="hero-title">
  <Image 
    src={heroBgImage} 
    alt="" 
    class="hero-section__bg-image"
    loading="eager"
    fetchpriority="high"
    aria-hidden="true"
  />
  <Container size="wide">
    <div class="hero">
      <!-- Left Column: Content -->
      <div class="hero__text-column">
        <h1 id="hero-title">
          <span>{homePage.heroHeading.introduction}</span>{' '}
          <span class="tone-purple">{homePage.heroHeading.purplePhrase}</span>{' '}
          <span class="tone-green">{homePage.heroHeading.greenPhrase}</span>{' '}
          <span class="tone-blue">{homePage.heroHeading.bluePhrase}</span>
        </h1>
        <br>
        <p class="hero-subtitle">
          {homePage.heroSubtitle}
        </p>
        
        <div class="hero-paragraphs">
          <PortableContent value={homePage.heroParagraphs} />
        </div>

        <div class="hero__actions">
          <Button href="/contact#contact-form" icon="heart">{homePage.primaryCtaLabel}</Button>
          <Button href="/about-us" variant="secondary">{homePage.secondaryCtaLabel}</Button>
        </div>
      </div>

      <!-- Right Column: Video Preview Card -->
      <div class="hero__video-column" data-home-video-modal>
        <div
          class="video-card"
          role="button"
          aria-label="Play video full screen"
          tabindex="0"
          data-video-trigger
        >
          <video
            class="hero-video-preview"
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            poster="/images/littlewisekids-hero-poster.jpg"
            data-preview-video
          >
            <source src={heroVideoWebm} type="video/webm" />
            <source src={heroVideoMp4} type="video/mp4" />
          </video>
          <div class="video-card__overlay"></div>
          <div class="hero-play-btn" aria-hidden="true">
            <span class="play-icon-pulse"></span>
            <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
          </div>
        </div>

        <!-- Full-screen Video Dialog (Modal) -->
        <dialog
          id="video-dialog"
          class="video-dialog"
          aria-label="Little Wise Kids video"
          data-video-dialog
        >
          <div class="video-dialog__content">
            <button
              class="video-dialog__close"
              type="button"
              aria-label="Close video"
              data-video-close
            >
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                aria-hidden="true"
              >
                <path d="M18 6L6 18M6 6l12 12" />
              </svg>
            </button>

            <video
              class="video-dialog__video"
              controls
              playsinline
              preload="metadata"
              data-modal-video
            >
              <source src={heroVideoWebm} type="video/webm" />
              <source src={heroVideoMp4} type="video/mp4" />
              Your browser does not support embedded video.
            </video>
          </div>
        </dialog>
      </div>
    </div>
  </Container>
  <svg
    class="hero-wave"
    viewBox="0 0 1448 120"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"
    ></path>
  </svg>
</section>

<div class="hero-testimonial">
</div>

<script src="./HeroSection.ts"></script>

