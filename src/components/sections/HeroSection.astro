---
import Section from "../layout/Section.astro";
import Button from "../ui/Button.astro";
import PortableContent from "../content/PortableContent.astro";
import "./HeroSection.css";
import type { HomePage, BusinessDetails } from "../../lib/types";

interface Props {
  homePage: HomePage;
  businessDetails: BusinessDetails;
}

const { homePage, businessDetails } = Astro.props;
---

<Section class="hero-section" width="wide" aria-labelledby="hero-title">
  <div class="hero">
    <div class="hero__content">
      <h1 id="hero-title">
        <!--TODO: no psacing between words!-->
        <span>{homePage.heroHeading.introduction}</span>
        <span class="tone-purple">{homePage.heroHeading.purplePhrase}</span><br />
        <span class="tone-green">{homePage.heroHeading.greenPhrase}</span>
        <span class="tone-blue">{homePage.heroHeading.bluePhrase}</span><br />
      </h1>
      <br>
      <p class="hero-subtitle">
        {homePage.heroSubtitle}
      </p>
      
      <div class="hero-paragraphs">
        <PortableContent value={homePage.heroParagraphs} />
      </div>

      <div class="hero-facts" style="margin-top: 1rem; font-size: 0.9rem;">
        <p>
          <strong>Age range:</strong> {businessDetails.ageRange.minimum} to {businessDetails.ageRange.maximum} years | 
          <strong>Hours:</strong> {businessDetails.openingTime} - {businessDetails.closingTime} | 
          <strong>Languages:</strong> {businessDetails.languages.join(", ")} | 
          <strong>Ofsted:</strong> {businessDetails.ofstedRegistrationType || 'Registered'}
        </p>
        <p>Our dedicated early years setting is on Stapleton Road in Easton, within easy reach of Lawrence Hill and Bristol city centre.</p>
      </div>

      <div class="hero__actions">
        <Button href="/contact/#contact-form" icon="heart">{homePage.primaryCtaLabel}</Button>
        <Button href="/about-us" variant="secondary"
          >{homePage.secondaryCtaLabel}</Button
        >
      </div>
    </div>
  </div>
</Section>
<div class="hero-testimonial">
  <svg
    class="hero-wave"
    viewBox="0 0 1448 120"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"
    ></path>
  </svg>
</div>
