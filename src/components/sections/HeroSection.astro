---
import { heroFeatures, site } from "../../data/site";
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="hero-section" width="wide">
  <div class="hero" aria-labelledby="hero-title">
    <div class="hero__content">
      <h1 id="hero-title">
        <span class="tone-purple">Nurturing</span> <span class="tone-green">curious</span><br />
        <span class="tone-green">minds,</span> <span class="tone-purple">creating</span><br />
        <span class="tone-blue">bright futures.</span>
      </h1>
      <p>{site.description}</p>
      <div class="hero__actions">
        <Button href="#approach" icon="heart">Our Approach</Button>
        <Button href="#contact" variant="secondary">Book a Visit</Button>
      </div>
    </div>
    <div class="hero__media" aria-hidden="true">
      <img class="hero__photo" src="/assets/images/hero-image.png" alt="" width="1426" height="1103" />
    </div>
  </div>

  <div class="feature-strip">
    {
      heroFeatures.map((feature) => (
        <article class="feature-strip__item">
          <span class={`feature-strip__icon tone-${feature.tone}`}>
            <Icon name={feature.icon} size={34} />
          </span>
          <div>
            <p class={`feature-strip__title tone-${feature.tone}`}>{feature.title}</p>
            <p>{feature.text}</p>
          </div>
        </article>
      ))
    }
  </div>
</Section>
<div class="testimonial">
  <svg class="wave" viewBox="0 0 1448 120" preserveAspectRatio="none" aria-hidden="true">
    <path d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"></path>
  </svg>
</div>

<style>
  .testimonial {
    position: relative;
    min-height: 150px;
    display: grid;
    place-items: center;
    text-align: center;
    overflow: hidden;
    background: var(--color-purple-soft);
  }

  @media (max-width: 680px) {
    .testimonial {
      min-height: 25px;
    }
  }

  .testimonial::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .wave {
    position: absolute;
    z-index: 1;
    left: 0;
    top: 0;
    width: 100%;
    fill: var(--color-surface);
    transform: rotate(180deg);
  }
</style>