---
import { Picture } from "astro:assets";
import Icon from "../icons/Icon.astro";
import Section from "../layout/Section.astro";
import Button from "../ui/Button.astro";
import PortableContent from "../content/PortableContent.astro";
import SanityImage from "../media/SanityImage.astro";
import heroFallback from "../../assets/images/hero-image.png";
import "./HeroSection.css";
import type { HomePage, BusinessDetails } from "../../lib/types";

interface Props {
  homePage: HomePage;
  businessDetails: BusinessDetails;
}

const { homePage } = Astro.props;

const heroIsDecorative = homePage.heroImage?.isDecorative === true;

const featureStrip = [
  { ...homePage.multilingualFeature, icon: 'globe', tone: 'blue' },
  { ...homePage.childCentredFeature, icon: 'heart', tone: 'purple' },
  { ...homePage.playToLearnFeature, icon: 'star', tone: 'green' }
];
---

<Section class="hero-section" width="wide" aria-labelledby="hero-title">
  <div class="hero">
    <div class="hero__content">
      {homePage.heroEyebrow && <span class="hero-eyebrow">{homePage.heroEyebrow}</span>}
      <h1 id="hero-title">
        <!--TODO: no psacing between words!-->
        <span>{homePage.heroHeading.introduction}</span>
        <span class="tone-purple">{homePage.heroHeading.purplePhrase}</span><br />
        <span class="tone-green">{homePage.heroHeading.greenPhrase}</span>
        <span class="tone-blue">{homePage.heroHeading.bluePhrase}</span><br />
      </h1>
      <p class="hero-subtitle">
        {homePage.heroSubtitle}
      </p>
      
      <div class="hero-paragraphs">
        <PortableContent value={homePage.heroParagraphs} />
      </div>

      <div class="hero__actions">
        <Button href="#approach" icon="heart">{homePage.primaryCtaLabel}</Button>
        <Button href="#contact" variant="secondary"
          >{homePage.secondaryCtaLabel}</Button
        >
      </div>
    </div>
    <div class="hero__media" aria-hidden={heroIsDecorative ? "true" : undefined}>
      {homePage.heroImage?.asset?._ref ? (
        <SanityImage
          image={homePage.heroImage}
          alt={heroIsDecorative ? "" : homePage.heroImage?.altText ?? ""}
          class="hero__photo"
          widths={[480, 640, 800, 1200, 1600]}
          sizes="(min-width: 72rem) 560px, 50vw"
          layout="constrained"
          priority
        />
      ) : (
        <Picture
          class="hero__photo"
          src={heroFallback}
          formats={["avif", "webp"]}
          fallbackFormat="png"
          alt=""
          width={1426}
          height={1103}
          priority
          layout="constrained"
        />
      )}
    </div>
  </div>

  <!--<div class="feature-strip">-->
  <!--  {-->
  <!--    featureStrip.map((feature) => (-->
  <!--      <article class="feature-strip__item">-->
  <!--        <span class={`feature-strip__icon tone-${feature.tone}`}>-->
  <!--          <Icon name={feature.icon} size={34} />-->
  <!--        </span>-->
  <!--        <div>-->
  <!--          <p class={`feature-strip__title tone-${feature.tone}`}>-->
  <!--            {feature.title}-->
  <!--          </p>-->
  <!--          <p class="feature-strip__text">{feature.description}</p>-->
  <!--        </div>-->
  <!--      </article>-->
  <!--    ))-->
  <!--  }-->
  <!--</div>-->
</Section>
<div class="hero-testimonial">
  <svg
    class="hero-wave"
    viewBox="0 0 1448 120"
    preserveAspectRatio="none"
    aria-hidden="true"
  >
    <path
      d="M0 26c105 38 193 38 292 8 107-32 190-36 304-1 115 35 199 31 305-5 110-37 197-31 308 4 93 29 161 30 239-4v92H0V26Z"
    ></path>
  </svg>
</div>
