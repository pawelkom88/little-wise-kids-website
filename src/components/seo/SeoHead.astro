---
import type { SeoConfig } from "../../lib/seo/types";
import type { BusinessDetails } from "../../lib/types";
import { defaultSeoImage, defaultSeoConfig, themeColor } from "../../config/seo";

interface Props {
  seo: SeoConfig;
  businessDetails?: BusinessDetails;
}

const { seo, businessDetails } = Astro.props;

if (!Astro.site) {
  throw new Error("Astro.site is not defined. SEO requires an absolute domain.");
}

// Ensure the canonical URL does not have a trailing slash unless it's just the root
const siteUrl = Astro.site.toString().replace(/\/$/, "");
let canonicalUrl = `${siteUrl}${seo.canonicalPath}`;
if (canonicalUrl.length > siteUrl.length + 1 && canonicalUrl.endsWith("/")) {
  canonicalUrl = canonicalUrl.slice(0, -1);
}

const ogType = seo.type || defaultSeoConfig.type;
const bdImage = businessDetails?.ogImage?.url
  ? { url: businessDetails.ogImage.url, alt: businessDetails.ogImage.altText || defaultSeoImage.alt, width: businessDetails.ogImage.width, height: businessDetails.ogImage.height }
  : undefined;
const ogImage = seo.image || bdImage || defaultSeoImage;
const mdUrl = seo.canonicalPath === "/" || !seo.canonicalPath ? `${siteUrl}/index.md` : `${canonicalUrl}.md`;
const txtUrl = seo.canonicalPath === "/" || !seo.canonicalPath ? `${siteUrl}/index.txt` : `${canonicalUrl}.txt`;
const ogImageUrl = ogImage?.url
  ? ogImage.url.startsWith("http") ? ogImage.url : `${siteUrl}${ogImage.url}`
  : undefined;
---

<title>{seo.title}</title>
<meta name="description" content={seo.description} />
<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
<link rel="shortcut icon" href="/favicon.ico" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content={themeColor} />
{seo.canonicalPath !== "omit" && (
  <>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="text/markdown" href={mdUrl} title="Markdown version" />
    <link rel="alternate" type="text/plain" href={txtUrl} title="Plain text version" />
  </>
)}
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" title="Little Wise Kids Blog RSS Feed" href={`${siteUrl}/rss.xml`} />
<link rel="api-catalog" href={`${siteUrl}/.well-known/api-catalog`} />
<link rel="service-desc" type="application/json" href={`${siteUrl}/.well-known/mcp/server-card.json`} />

{seo.robots && <meta name="robots" content={seo.robots} />}

<meta property="og:site_name" content={defaultSeoConfig.siteName} />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
{seo.canonicalPath !== "omit" && (
  <meta property="og:url" content={canonicalUrl} />
)}
{ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
{ogImage?.alt && <meta property="og:image:alt" content={ogImage.alt} />}
{ogImage?.width && <meta property="og:image:width" content={ogImage.width.toString()} />}
{ogImage?.height && <meta property="og:image:height" content={ogImage.height.toString()} />}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={seo.title} />
<meta name="twitter:description" content={seo.description} />
{ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}

{ogType === "article" && seo.publishedTime && (
  <meta property="article:published_time" content={seo.publishedTime} />
)}
{ogType === "article" && seo.modifiedTime && (
  <meta property="article:modified_time" content={seo.modifiedTime} />
)}
{ogType === "article" && seo.articleSection && (
  <meta property="article:section" content={seo.articleSection} />
)}
