---
import "./Container.css";

interface Props {
  size?: "default" | "narrow" | "wide" | "full";
  class?: string;
}

const { size = "default", class: className = "" } = Astro.props;
const classes = ["container", `container--${size}`, className]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  <slot />
</div>
