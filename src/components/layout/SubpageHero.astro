---
import "./SubpageHero.css";

interface Props {
  title?: string;
  eyebrow?: string;
  tone?: "purple" | "green" | "blue" | "yellow";
  align?: "left" | "center";
  id?: string;
  class?: string;
  itemprop?: string;
}

const {
  title,
  eyebrow,
  tone = "purple",
  align = "center",
  id,
  class: className,
  itemprop,
} = Astro.props;

const wrapperClasses = [
  "subpage-hero",
  `subpage-hero--tone-${tone}`,
  `subpage-hero--align-${align}`,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<header class={wrapperClasses}>
  <div class="subpage-hero__content">
    {eyebrow && <p class="subpage-hero__eyebrow">{eyebrow}</p>}

    <h1 id={id} class="subpage-hero__title" itemprop={itemprop}>
      <slot name="title">{title}</slot>
    </h1>

    <div class="subpage-hero__copy">
      <slot />
    </div>
  </div>

  <span class="subpage-hero__wave-highlight" aria-hidden="true"></span>

  <div class="subpage-hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 220" preserveAspectRatio="none">
      <path
        d="M0 58C130 118 272 116 413 86C560 55 655 63 805 112C975 168 1102 119 1258 69C1330 46 1392 39 1440 52V220H0V58Z"
      ></path>
    </svg>
  </div>
</header>
