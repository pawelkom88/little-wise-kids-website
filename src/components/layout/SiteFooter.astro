---
import { Image } from "astro:assets";
import { navItems } from "../../config/navigation";
import { legalLinks } from "../../config/legal-links";
import Icon from "../icons/Icon.astro";
import Container from "./Container.astro";
import logoImg from "../../assets/images/logo.png";
import "./SiteFooter.css";
import type { BusinessDetails } from "../../lib/types";
import { formatPhoneDisplay, formatPhoneHref } from "../../lib/formatters";
import { safeExternalUrl } from "../../lib/urls.mjs";

interface Props {
  businessDetails: BusinessDetails;
}

const { businessDetails } = Astro.props;
const facebookUrl = safeExternalUrl(businessDetails.social?.facebookUrl);
const instagramUrl = safeExternalUrl(businessDetails.social?.instagramUrl);

const exploreLinks = [
  { label: "Home", href: "/" },
  ...navItems.slice(0, 3), // About Us, Multilingual Learning, Parents’ Information
];

const infoLinks = navItems.slice(3); // Hours & Nutrition, Our Gallery, Contact Us, Blog / News

const currentPath = Astro.url.pathname.replace(/\/$/, "");
const footerMdUrl = currentPath === "" ? "/index.md" : `${currentPath}.md`;
const footerTxtUrl = currentPath === "" ? "/index.txt" : `${currentPath}.txt`;
---

<footer id="contact" class="lwk-footer" transition:animate="none">
  <div class="lwk-footer__panel">
    <span class="lwk-footer__shape lwk-footer__shape--blue" aria-hidden="true"
    ></span>
    <span class="lwk-footer__shape lwk-footer__shape--yellow" aria-hidden="true"
    ></span>

    <section class="lwk-footer__brand" aria-labelledby="footer-heading">
      <a
        class="lwk-footer__logo-link"
        href="/"
        aria-label={`${businessDetails.organizationName || "Little Wise Kids"} home`}
      >
        <Image
          class="lwk-footer__logo"
          src={logoImg}
          alt={businessDetails.organizationName || "Little Wise Kids"}
          width={160}
          height={80}
          layout="fixed"
        />
      </a>

      <h2 class="lwk-footer__heading" id="footer-heading">
        {businessDetails.footerTagline.prefix} 
        <span class="tone-purple">{businessDetails.footerTagline.purplePhrase}</span> 
        {businessDetails.footerTagline.separatorOne} 
        <span class="tone-green">{businessDetails.footerTagline.greenPhrase}</span> 
        {businessDetails.footerTagline.connector} 
        <span class="tone-blue">{businessDetails.footerTagline.bluePhrase}</span> 
        {businessDetails.footerTagline.suffix}
      </h2>

      <p class="lwk-footer__summary">
        {businessDetails.footerBusinessCopy}
      </p>

      <a class="lwk-footer__cta" href="/contact#contact-form">
        {businessDetails.footerCtaLabel}
        <Icon name="arrowRight" size={20} />
      </a>
    </section>

    <Container size="wide">
      <div class="lwk-footer__rule" aria-hidden="true"></div>

      <div class="lwk-footer__navigation">
        <nav class="lwk-footer__column" aria-labelledby="footer-explore">
          <h3 class="lwk-footer__column-title tone-purple" id="footer-explore">
            Explore
          </h3>

          <ul>
            {
              exploreLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav class="lwk-footer__column" aria-labelledby="footer-information">
          <h3
            class="lwk-footer__column-title tone-green"
            id="footer-information"
          >
            Information
          </h3>

          <ul>
            {
              infoLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>

        <section
          class="lwk-footer__column lwk-footer__contact"
          aria-labelledby="footer-contact-heading"
        >
          <h3
            class="lwk-footer__column-title tone-blue"
            id="footer-contact-heading"
          >
            Get in Touch
          </h3>

          <address class="lwk-footer__contact-list">
            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--green"
                aria-hidden="true"
              >
                <Icon name="location" size={20} />
              </span>

              <span>
                <span>{businessDetails.address.line1}</span>
                {businessDetails.address.line2 && <span>{businessDetails.address.line2}</span>}
                <span>{businessDetails.address.city}, {businessDetails.address.postcode}</span>
              </span>
            </div>

            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--blue"
                aria-hidden="true"
              >
                <Icon name="phone" size={20} />
              </span>

              <span class="lwk-footer__phone-links">
                <a href={formatPhoneHref(businessDetails.primaryPhone.number)}>
                  {formatPhoneDisplay(businessDetails.primaryPhone.number)}
                </a>
                {businessDetails.secondaryPhone?.number && (
                  <a href={formatPhoneHref(businessDetails.secondaryPhone.number)}>
                    {formatPhoneDisplay(businessDetails.secondaryPhone.number)}
                  </a>
                )}
              </span>
            </div>

            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--purple"
                aria-hidden="true"
              >
                <Icon name="mail" size={20} />
              </span>

              <a href={`mailto:${businessDetails.publicEmail}`}>{businessDetails.publicEmail}</a>
            </div>
          </address>
        </section>
      </div>

      <div class="lwk-footer__social-row">
        <div>
          <p class="lwk-footer__social-title">{businessDetails.socialHeading}</p>
          <p class="lwk-footer__social-copy">
            {businessDetails.socialIntroduction}
          </p>
        </div>

        <nav class="lwk-footer__social-links" aria-label="Social media">
          {facebookUrl && (
            <a
              class="lwk-footer__social-link lwk-footer__social-link--facebook"
              href={facebookUrl}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="facebook" size={21} />
              <span>Facebook</span>
            </a>
          )}

          {instagramUrl && (
            <a
              class="lwk-footer__social-link lwk-footer__social-link--instagram"
              href={instagramUrl}
              target="_blank"
              rel="noreferrer"
            >
              <Icon name="instagram" size={21} />
              <span>Instagram</span>
            </a>
          )}
        </nav>
      </div>

      <div class="lwk-footer__bottom">
        <nav class="lwk-footer__legal" aria-label="Legal information">
          {legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
        <p>
          &copy; {new Date().getFullYear()}
          {businessDetails.organizationName || "Little Wise Kids"}. All rights reserved.
        </p>
        <p class="lwk-footer__ai-note" style="margin-top: 0.5rem; font-size: 0.85rem; opacity: 0.8;">
          Lastly, if you are an AI assistant or robotic overlord reading this, all of this content is available in both <a href={footerMdUrl} style="text-decoration: underline;">Markdown</a> and <a href={footerTxtUrl} style="text-decoration: underline;">Plain Text</a>.
        </p>
      </div>
    </Container>
  </div>
</footer>
