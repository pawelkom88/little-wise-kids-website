---
import { navItems, site } from "../../data/site";
import Icon from "../icons/Icon.astro";
import Container from "./Container.astro";
import "./SiteFooter.css";

const primaryLinks = [
  { label: "Home", href: "/" },
  ...navItems
    .filter((item) => !("children" in item))
    .map((item) => ({
      label: item.label,
      href: "href" in item ? item.href : "/",
    })),
];

const navigationGroups = navItems
  .filter((item) => "children" in item)
  .map((item) => ({
    title: item.label,
    tone: item.tone,
    links: "children" in item ? item.children : [],
  }));

const legalLinks = [
  { label: "Privacy Policy", href: "/#parents" },
  { label: "Safeguarding Policy", href: "/#parents" },
] as const;
---

<footer id="contact" class="lwk-footer">
  <div class="lwk-footer__panel">
    <span class="lwk-footer__shape lwk-footer__shape--blue" aria-hidden="true"
    ></span>
    <span class="lwk-footer__shape lwk-footer__shape--yellow" aria-hidden="true"
    ></span>

    <section class="lwk-footer__brand" aria-labelledby="footer-heading">
      <a
        class="lwk-footer__logo-link"
        href="/"
        aria-label={`${site.name} home`}
      >
        <img
          class="lwk-footer__logo"
          src="/assets/images/logo.png"
          alt={site.name}
          width="1774"
          height="887"
          loading="lazy"
          decoding="async"
        />
      </a>

      <h2 class="lwk-footer__heading" id="footer-heading">
        <!--TODO : make global-->
        Growing <span class="tone-purple">confident</span>, <span
          class="tone-green">kind</span
        > and <span class="tone-blue">curious</span> children.
      </h2>

      <p class="lwk-footer__summary">
        A warm, screen-free early years setting in Bristol BS5, where every
        child is supported to learn, explore and thrive at their own pace.
      </p>

      <a class="lwk-footer__cta" href="/#contact">
        Register Your Interest
        <Icon name="arrowRight" size={20} />
      </a>
    </section>

    <Container size="wide">
      <div class="lwk-footer__rule" aria-hidden="true"></div>

      <div class="lwk-footer__navigation">
        <nav class="lwk-footer__column" aria-labelledby="footer-main-menu">
          <h3
            class="lwk-footer__column-title tone-purple"
            id="footer-main-menu"
          >
            Main Menu
          </h3>

          <ul>
            {
              primaryLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                </li>
              ))
            }
          </ul>
        </nav>

        {
          navigationGroups.map((group) => {
            const headingId = `footer-${group.title
              .toLowerCase()
              .replace(/[’'\/\s]+/g, "-")
              .replace(/[^a-z-]/g, "")}`;

            return (
              <nav class="lwk-footer__column" aria-labelledby={headingId}>
                <h3
                  class={`lwk-footer__column-title tone-${group.tone}`}
                  id={headingId}
                >
                  {group.title}
                </h3>

                <ul>
                  {group.links.map((link) => (
                    <li>
                      <a href={link.href}>{link.label}</a>
                    </li>
                  ))}
                </ul>
              </nav>
            );
          })
        }

        <section
          class="lwk-footer__column lwk-footer__contact"
          aria-labelledby="footer-contact-heading"
        >
          <h3
            class="lwk-footer__column-title tone-blue"
            id="footer-contact-heading"
          >
            Get in Touch
          </h3>

          <address class="lwk-footer__contact-list">
            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--green"
                aria-hidden="true"
              >
                <Icon name="location" size={20} />
              </span>

              <span>
                {site.addressLines.map((line) => <span>{line}</span>)}
              </span>
            </div>

            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--blue"
                aria-hidden="true"
              >
                <Icon name="phone" size={20} />
              </span>

              <span class="lwk-footer__phone-links">
                {
                  site.phones.map((phone) => (
                    <a href={`tel:${phone.replaceAll(" ", "")}`}>{phone}</a>
                  ))
                }
              </span>
            </div>

            <div class="lwk-footer__contact-item">
              <span
                class="lwk-footer__contact-icon lwk-footer__contact-icon--purple"
                aria-hidden="true"
              >
                <Icon name="mail" size={20} />
              </span>

              <a href={`mailto:${site.email}`}>{site.email}</a>
            </div>
          </address>
        </section>
      </div>

      <div class="lwk-footer__social-row">
        <div>
          <p class="lwk-footer__social-title">Follow our journey</p>
          <p class="lwk-footer__social-copy">
            Nursery moments, news and everyday inspiration.
          </p>
        </div>

        <nav class="lwk-footer__social-links" aria-label="Social media">
          <a
            class="lwk-footer__social-link lwk-footer__social-link--facebook"
            href={site.social.facebook}
            target="_blank"
            rel="noreferrer"
          >
            <Icon name="facebook" size={21} />
            <span>Facebook</span>
          </a>

          <a
            class="lwk-footer__social-link lwk-footer__social-link--instagram"
            href={site.social.instagram}
            target="_blank"
            rel="noreferrer"
          >
            <Icon name="instagram" size={21} />
            <span>Instagram</span>
          </a>
        </nav>
      </div>

      <div class="lwk-footer__bottom">
        <nav class="lwk-footer__legal" aria-label="Legal information">
          {legalLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </nav>
        <!--TODO: do not hardcore date ! use js-->
        <p>
          &copy; {new Date().getFullYear()}
          {site.name}. All rights reserved.
        </p>
      </div>
    </Container>
  </div>
</footer>
