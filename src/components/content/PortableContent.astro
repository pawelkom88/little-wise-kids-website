---
import { PortableText } from "astro-portabletext";
import InlineBusinessDetail from "./portable/InlineBusinessDetail.astro";
import ContentImageBlock from "./portable/ContentImageBlock.astro";
import StrictImageBlock from "./portable/StrictImageBlock.astro";
import ExternalLink from "./portable/ExternalLink.astro";
import InternalLink from "./portable/InternalLink.astro";
import type { PortableTextBlock } from "@portabletext/types";

interface Props {
  value: PortableTextBlock | PortableTextBlock[];
  class?: string;
}

const { value } = Astro.props;

const components = {
  type: {
    inlineBusinessDetail: InlineBusinessDetail,
    contentImage: ContentImageBlock,
    strictImage: StrictImageBlock,
  },
  mark: {
    link: ExternalLink,
    internalLink: InternalLink,
  },
} as any;
---

<PortableText value={value} components={components} />
