---
import SanityImage from "../../media/SanityImage.astro";
import type { ContentImage } from "../../../lib/types";

interface Props {
  node: ContentImage;
}
const { node } = Astro.props;
---

{node?.asset?._ref ? (
  <figure class="content-image">
    <SanityImage
      image={node}
      alt={node.isDecorative ? "" : node.altText ?? ""}
      widths={[640, 800, 1200]}
      sizes="(min-width: 72rem) 800px, 100vw"
      layout="constrained"
    />
    {node.caption && <figcaption>{node.caption}</figcaption>}
  </figure>
) : null}
