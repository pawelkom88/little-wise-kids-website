---
interface ExternalLinkDef {
  _type: "link";
  href: string;
  blank?: boolean;
}

interface Props {
  node: { markDef: ExternalLinkDef };
}

import { safeExternalUrl } from "../../../lib/urls.mjs";

const { node } = Astro.props;
const { blank } = node.markDef;
const href = safeExternalUrl(node.markDef.href);
---

{href ? (
  <a href={href} target={blank ? "_blank" : undefined} rel={blank ? "noopener noreferrer" : undefined}>
    <slot />
  </a>
) : <slot />}
