---
import { formatTimeRange, formatPhoneDisplay, formatLanguages, getAgeRangeDisplay } from "../../../lib/formatters";
import { ensureBusinessDetails } from "../../../lib/context";
import type { BusinessDetails } from "../../../lib/types";

interface Props {
  node: { field: string };
}

const { node } = Astro.props;
const bd = await ensureBusinessDetails();

function formatAddress(bd: BusinessDetails): string {
  const parts = [bd.address.organisation, bd.address.line1];
  if (bd.address.line2) parts.push(bd.address.line2);
  parts.push(bd.address.city, bd.address.postcode);
  return parts.join(", ");
}

function resolve(field: string, bd: BusinessDetails): string {
  switch (field) {
    case "organisationName": return bd.organisationName;
    case "ageRange": return getAgeRangeDisplay(bd);
    case "languages": return formatLanguages(bd.languages);
    case "openingDays": return bd.openingDays;
    case "openingHours": return formatTimeRange(bd.openingTime, bd.closingTime);
    case "weeksOpen": return String(bd.weeksOpen);
    case "publicEmail": return bd.publicEmail;
    case "primaryPhone": return formatPhoneDisplay(bd.primaryPhone.number);
    case "fullAddress": return formatAddress(bd);
    case "shortLocation": return bd.address.shortLocation;
    default: return `[Unknown: ${field}]`;
  }
}
---

{resolve(node.field, bd)}
