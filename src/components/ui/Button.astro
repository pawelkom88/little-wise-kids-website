---
import Icon from "../icons/Icon.astro";
import "./Button.css";

interface Props {
  href?: string;
  variant?: "primary" | "secondary";
  icon?: "arrowRight" | "heart" | "calendar" | "none";
  class?: string;
  type?: "button" | "submit" | "reset";
}

const {
  href,
  variant = "primary",
  icon = "arrowRight",
  class: className = "",
  type = "button",
} = Astro.props;

const classes = ["button", `button--${variant}`, className]
  .filter(Boolean)
  .join(" ");
---

{
  href ? (
    <a class={classes} href={href}>
      <slot />
      {icon !== "none" && <Icon name={icon as "arrowRight" | "heart" | "calendar"} size={20} />}
    </a>
  ) : (
    <button class={classes} type={type}>
      <slot />
      {icon !== "none" && <Icon name={icon as "arrowRight" | "heart" | "calendar"} size={20} />}
    </button>
  )
}
