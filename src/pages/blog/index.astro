---
export const prerender = true;
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import Icon from "../../components/icons/Icon.astro";
import SubpageHero from "../../components/layout/SubpageHero.astro";
import PortableContent from "../../components/content/PortableContent.astro";
import SanityImage from "../../components/media/SanityImage.astro";
import { getBlogPage, getBlogPosts } from "../../utils/sanity";
import { mapBlogPost, blogCategories } from "../../lib/blog";
import "./blog.css";

const blogPage = await getBlogPage();
const posts = await getBlogPosts();
const articles = posts.map(mapBlogPost);

const primaryFeaturedArticle = articles.find((a) => a.featured) ?? null;
const standardArticles = primaryFeaturedArticle
  ? articles.filter((a) => a.slug !== primaryFeaturedArticle.slug)
  : articles;
---

<BaseLayout
 
  title="Nursery News and Early Years Advice | Little Wise Kids"
  description="Read nursery news, early years guidance, parenting ideas, nutrition advice and community updates from Little Wise Kids in Bristol BS5."
>
  <article class="blog-page">
    <SubpageHero id="blog-page-title" eyebrow={blogPage.heroEyebrow} tone="purple">
      <Fragment slot="title">
        <span>{blogPage.heroTitleLineOne}</span>
        <span>{blogPage.heroTitleLineTwo}</span>
      </Fragment>

      <PortableContent value={blogPage.heroParagraphs} />
    </SubpageHero>

    <div class="blog-page__content">
      <Container size="wide">
        <section class="blog-index" aria-labelledby="latest-articles-title">
          <header class="blog-index__header">
            <div class="blog-index__heading">
              {blogPage.latestArticlesEyebrow && (
                <p class="blog-index__eyebrow">{blogPage.latestArticlesEyebrow}</p>
              )}

              <h2 id="latest-articles-title">{blogPage.latestArticlesHeading}</h2>

              {blogPage.latestArticlesIntroduction && (
                <PortableContent value={blogPage.latestArticlesIntroduction} />
              )}
            </div>

            <div
              class="blog-filters"
              role="group"
              aria-label="Filter articles by category"
            >
              {
                blogCategories.map((category, index) => (
                  <button
                    class="blog-filter"
                    type="button"
                    data-blog-filter={category.id}
                    aria-pressed={index === 0 ? "true" : "false"}
                  >
                    <span class="blog-filter__icon" aria-hidden="true">
                      <Icon name={category.icon} size={18} />
                    </span>

                    <span>{category.label}</span>
                  </button>
                ))
              }
            </div>
          </header>

          <p class="blog-visually-hidden" data-blog-status aria-live="polite">
          </p>

          <div class="blog-grid">
            {primaryFeaturedArticle && (() => {
              const article = primaryFeaturedArticle;
              return (
                <article
                  class={`blog-card blog-card--featured blog-card--${article.tone}`}
                  data-blog-card
                  data-category={article.category}
                  data-article-index={0}
                >
                  <a class="blog-card__link" href={`/blog/${article.slug}`}>
                    <div class="blog-card__media">
                      {article.image ? (
                        <SanityImage
                          image={article.image.sanityImage}
                          alt={article.image.alt}
                          widths={[640, 900, 1200]}
                          sizes="(min-width: 72rem) 560px, 100vw"
                          layout="constrained"
                        />
                      ) : (
                        <div class="blog-card__placeholder" aria-hidden="true" />
                      )}
                      <span class="blog-card__featured">
                        <Icon name="star" size={16} />
                        Featured
                      </span>
                    </div>
                    <div class="blog-card__body">
                      <span class="blog-card__category">
                        <span aria-hidden="true"><Icon name={article.icon as import("../../components/icons/types").IconName} size={17} /></span>
                        {article.categoryLabel}
                      </span>
                      <h3>{article.title}</h3>
                      <p class="blog-card__excerpt">{article.excerpt}</p>
                      <footer class="blog-card__footer">
                        <div class="blog-card__meta">
                          <time datetime={article.published}>{article.displayDate}</time>
                          <span aria-hidden="true">·</span>
                          <span>{article.readTime}</span>
                        </div>
                        <span class="blog-card__read">Read Article<span aria-hidden="true">→</span></span>
                      </footer>
                    </div>
                  </a>
                </article>
              );
            })()}
            {
              standardArticles.map((article, idx) => {
                const displayIndex = (primaryFeaturedArticle ? 1 : 0) + idx;
                return (
                <article
                  class={`blog-card blog-card--${article.tone}`}
                  data-blog-card
                  data-category={article.category}
                  data-article-index={displayIndex}
                  hidden={displayIndex >= 6}
                >
                  <a class="blog-card__link" href={`/blog/${article.slug}`}>
                    <div class="blog-card__media">
                      {article.image ? (
                        <SanityImage
                          image={article.image.sanityImage}
                          alt={article.image.alt}
                          widths={[320, 480, 640, 900]}
                          sizes="(min-width: 72rem) 360px, (min-width: 48rem) 50vw, 100vw"
                          layout="constrained"
                          priority={displayIndex < 1}
                        />
                      ) : (
                        <div class="blog-card__placeholder" aria-hidden="true" />
                      )}
                    </div>
                    <div class="blog-card__body">
                      <span class="blog-card__category">
                        <span aria-hidden="true"><Icon name={article.icon as import("../../components/icons/types").IconName} size={17} /></span>
                        {article.categoryLabel}
                      </span>
                      <h3>{article.title}</h3>
                      <p class="blog-card__excerpt">{article.excerpt}</p>
                      <footer class="blog-card__footer">
                        <div class="blog-card__meta">
                          <time datetime={article.published}>{article.displayDate}</time>
                          <span aria-hidden="true">·</span>
                          <span>{article.readTime}</span>
                        </div>
                        <span class="blog-card__read">Read Article<span aria-hidden="true">→</span></span>
                      </footer>
                    </div>
                  </a>
                </article>
                );
              })
            }
          </div>

          <div class="blog-index__actions">
            <button class="blog-load-more" type="button" data-blog-load-more>
              <span class="blog-load-more__icon" aria-hidden="true"> ↓ </span>

              <span data-blog-load-more-label> Load More Articles </span>
            </button>
          </div>
        </section>
      </Container>
    </div>
  </article>
</BaseLayout>

<script>
  const blogCards = Array.from(
    document.querySelectorAll("[data-blog-card]")
  ).filter((card) => card instanceof HTMLElement);

  const filterButtons = Array.from(
    document.querySelectorAll("[data-blog-filter]")
  ).filter((button) => button instanceof HTMLButtonElement);

  const loadMoreButton = document.querySelector("[data-blog-load-more]");

  const loadMoreLabel = document.querySelector("[data-blog-load-more-label]");

  const status = document.querySelector("[data-blog-status]");

  const pageSize = 6;
  let activeCategory = "all";
  let expanded = false;

  const getMatchingCards = () => {
    return blogCards.filter((card) => {
      return (
        activeCategory === "all" || card.dataset.category === activeCategory
      );
    });
  };

  const updateArticles = () => {
    const matchingCards = getMatchingCards();

    blogCards.forEach((card) => {
      const matches =
        activeCategory === "all" || card.dataset.category === activeCategory;

      const matchingIndex = matchingCards.indexOf(card);
      const isWithinLimit = expanded || matchingIndex < pageSize;

      card.hidden = !(matches && isWithinLimit);
    });

    const hiddenMatchingCount = matchingCards.filter(
      (card) => card.hidden
    ).length;

    if (loadMoreButton instanceof HTMLButtonElement) {
      loadMoreButton.hidden = hiddenMatchingCount === 0;

      loadMoreButton.setAttribute("aria-expanded", String(expanded));
    }

    if (loadMoreLabel) {
      loadMoreLabel.textContent =
        hiddenMatchingCount > 0
          ? `Load ${hiddenMatchingCount} More ${
              hiddenMatchingCount === 1 ? "Article" : "Articles"
            }`
          : "All Articles Shown";
    }

    if (status) {
      const visibleCount = matchingCards.filter((card) => !card.hidden).length;

      status.textContent = `${visibleCount} ${
        visibleCount === 1 ? "article" : "articles"
      } shown.`;
    }
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeCategory = button.dataset.blogFilter ?? "all";

      expanded = false;

      filterButtons.forEach((filterButton) => {
        filterButton.setAttribute(
          "aria-pressed",
          String(filterButton === button)
        );
      });

      updateArticles();
    });
  });

  if (loadMoreButton instanceof HTMLButtonElement) {
    loadMoreButton.addEventListener("click", () => {
      expanded = true;
      updateArticles();
    });
  }

  updateArticles();
</script>
