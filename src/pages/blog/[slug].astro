---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/layout/Container.astro";
import Icon from "../../components/icons/Icon.astro";
import SubpageHero from "../../components/layout/SubpageHero.astro";
import "./blog-article.css";

import { articles } from "../../data/blog";
import type { BlogArticle } from "../../data/blog";

export function getStaticPaths() {
  return articles.map((article) => ({
    params: {
      slug: article.slug,
    },
    props: {
      article,
    },
  }));
}

interface Props {
  article: BlogArticle;
}

const { article } = Astro.props as Props;

const { displayDate, readTime } = article;
---

<BaseLayout
  title={`${article.title} | Little Wise Kids`}
  description={article.excerpt}
>
  <article
    class="blog-article-page"
    itemscope
    itemtype="https://schema.org/BlogPosting"
  >
    <SubpageHero
      id="blog-article-title"
      eyebrow={`Blog / ${article.categoryLabel}`}
      tone="purple"
      itemprop="headline"
    >
      <Fragment slot="title">
        {article.title}
      </Fragment>

      <p itemprop="description">
        {article.excerpt}
      </p>
    </SubpageHero>

    <div class="blog-article-page__content">
      <Container size="wide">
        <div class="blog-article">
          <header class="blog-article__meta">
            <div class="blog-article__meta-item">
              <span aria-hidden="true">
                <Icon name="calendar" size={20} />
              </span>

              <time datetime={article.published} itemprop="datePublished">
                {displayDate}
              </time>
            </div>

            <span class="blog-article__meta-separator" aria-hidden="true"
            ></span>

            <div class="blog-article__meta-item">
              <span aria-hidden="true">
                <Icon name="clock" size={20} />
              </span>

              <span>
                {readTime}
              </span>
            </div>
          </header>

          <figure class="blog-article__image">
            {
              article.image ? (
                <img
                  src={article.image.src}
                  alt={article.image.alt}
                  width={article.image.width}
                  height={article.image.height}
                  loading="eager"
                  decoding="async"
                  itemprop="image"
                />
              ) : (
                <div class="blog-article__image-placeholder" aria-hidden="true">
                  <Icon name="image" size={54} />

                  <span>Main article image</span>
                </div>
              )
            }
          </figure>

          <div class="blog-article__prose" itemprop="articleBody">
            {
              article.content.map((block) => {
                if (block.type === "heading") {
                  return <h2 id={block.id}>{block.text}</h2>;
                }

                if (block.type === "list") {
                  return (
                    <ul>
                      {block.items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  );
                }

                return <p>{block.text}</p>;
              })
            }
          </div>
        </div>
      </Container>
    </div>
  </article>
</BaseLayout>
