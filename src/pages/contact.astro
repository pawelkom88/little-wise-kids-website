---
export const prerender = true;
import Icon from "../components/icons/Icon.astro";
import Container from "../components/layout/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getContactPage, getBusinessDetails } from "../utils/sanity";
import { formatTimeRange } from "../lib/formatters";
import "./contact.css";

const siteUrl = Astro.site ?? new URL("https://littlewisekids.co.uk");

const accessKey = import.meta.env.WEB3FORMS_ACCESS_KEY;

if (!accessKey) {
  throw new Error(
    "Missing WEB3FORMS_ACCESS_KEY environment variable. Add it to .env to enable the contact form."
  );
}
const thankYouUrl = new URL("/thank-you/", siteUrl).toString();

const contactPage = await getContactPage();
const businessDetails = await getBusinessDetails();

import type { SeoConfig } from "../lib/seo/types";
const seo: SeoConfig = {
  title: "Contact Little Wise Kids | Nursery in Bristol BS5",
  description: "Contact Little Wise Kids in Bristol BS5 to ask about nursery availability, book a visit, or register for our screen-free early years setting.",
  canonicalPath: "/contact",
};

const nextSteps = [
  {
    number: "01",
    title: contactPage.receiveEnquiryStep.title,
    copy: contactPage.receiveEnquiryStep.description,
  },
  {
    number: "02",
    title: contactPage.getInTouchStep.title,
    copy: contactPage.getInTouchStep.description,
  },
  {
    number: "03",
    title: contactPage.helpWithNextStepsStep.title,
    copy: contactPage.helpWithNextStepsStep.description,
  },
] as const;
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="contact-page">
    <SubpageHero 
      id="contact-page-title" 
      eyebrow={contactPage.heroEyebrow} 
      tone="blue"
      titleLineOne={contactPage.heroTitleLineOne}
      titleLineTwo={contactPage.heroTitleLineTwo}
    >

      <PortableContent value={contactPage.heroParagraphs} />
    </SubpageHero>

    <div class="contact-page__content">
      <Container size="wide">
        <div class="contact-page__stack">
          <section
            class="contact-form-card"
            id="contact-form"
            aria-labelledby="contact-form-title"
          >
            <header class="contact-section-heading">
              <p class="contact-section-heading__eyebrow">{contactPage.sectionLabel}</p>

              <h2 id="contact-form-title">{contactPage.sectionHeading}</h2>

              <PortableContent value={contactPage.introduction} />
            </header>

            <form
              class="contact-form"
              action="https://api.web3forms.com/submit"
              method="POST"
              novalidate
            >
              <!-- Web3Forms API Key -->
              <input type="hidden" name="access_key" value={accessKey} />

              <input
                id="contact-subject"
                type="hidden"
                name="subject"
                value="New Little Wise Kids website enquiry"
              />

              <input
                type="hidden"
                name="from_name"
                value="Little Wise Kids Website"
              />

              <input
                id="contact-redirect"
                type="hidden"
                name="redirect"
                value={thankYouUrl}
              />

              <input
                type="hidden"
                name="source"
                value="Little Wise Kids contact page"
              />

              <div
                id="contact-error-summary"
                class="contact-form__error-summary"
                role="alert"
                tabindex="-1"
                hidden
              >
                <h3>Please check the highlighted fields</h3>
                <ul></ul>
              </div>

              <div class="contact-form__grid">
                <div class="contact-field">
                  <label for="contact-name">
                    Parent / Carer Name
                    <span aria-hidden="true">*</span>
                  </label>

                  <input
                    id="contact-name"
                    name="name"
                    type="text"
                    autocomplete="name"
                    minlength="2"
                    maxlength="80"
                    placeholder="Your full name"
                    required
                    data-validate
                    data-label="Parent or carer name"
                    data-required-message="Enter your name."
                    aria-describedby="contact-name-error"
                  />

                  <p
                    id="contact-name-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-email">
                    Email Address
                    <span aria-hidden="true">*</span>
                  </label>

                  <input
                    id="contact-email"
                    name="email"
                    type="email"
                    autocomplete="email"
                    maxlength="160"
                    placeholder="you@example.com"
                    required
                    data-validate
                    data-label="Email address"
                    data-required-message="Enter your email address."
                    aria-describedby="contact-email-error"
                  />

                  <p
                    id="contact-email-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-phone">
                    Phone Number
                    <span class="contact-field__optional"> Optional </span>
                  </label>

                  <input
                    id="contact-phone"
                    name="phone"
                    type="tel"
                    autocomplete="tel"
                    inputmode="tel"
                    maxlength="30"
                    placeholder="Your phone number"
                    data-validate
                    data-label="Phone number"
                    aria-describedby="contact-phone-hint contact-phone-error"
                  />

                  <p id="contact-phone-hint" class="contact-field__hint">
                    Include the area or international dialling code.
                  </p>

                  <p
                    id="contact-phone-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-child-name">
                    Child’s Name
                    <span class="contact-field__optional"> Optional </span>
                  </label>

                  <input
                    id="contact-child-name"
                    name="child_name"
                    type="text"
                    autocomplete="name"
                    maxlength="80"
                    placeholder="Your child’s name"
                    data-validate
                    data-label="Child’s name"
                    aria-describedby="contact-child-name-error"
                  />

                  <p
                    id="contact-child-name-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-child-age">
                    Child’s Age or Date of Birth
                    <span class="contact-field__optional"> Optional </span>
                  </label>

                  <input
                    id="contact-child-age"
                    name="child_age"
                    type="text"
                    maxlength="60"
                    placeholder="For example, 2 years or DD/MM/YYYY"
                    data-validate
                    data-label="Child’s age or DOB"
                    aria-describedby="contact-child-age-error"
                  />

                  <p
                    id="contact-child-age-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-enquiry-type">
                    Enquiry Type
                    <span aria-hidden="true">*</span>
                  </label>

                  <select
                    id="contact-enquiry-type"
                    name="enquiry_type"
                    required
                    data-validate
                    data-label="Enquiry type"
                    data-required-message="Choose the type of enquiry."
                    aria-describedby="contact-enquiry-type-error"
                  >
                    <option value=""> Choose an option </option>
                    <option value="register-interest">
                      Register your interest
                    </option>
                    <option value="book-visit">
                      Arrange a nursery visit
                    </option>
                    <option value="availability"> Nursery availability </option>
                    <option value="fees-funding"> Fees and funding </option>
                    <option value="settling-in"> Settling in </option>
                    <option value="nutrition">
                      Nutrition or dietary needs
                    </option>
                    <option value="general"> General enquiry </option>
                  </select>

                  <p
                    id="contact-enquiry-type-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-start-date">
                    Preferred Start Date
                    <span class="contact-field__optional"> Optional </span>
                  </label>

                  <input
                    id="contact-start-date"
                    name="preferred_start_date"
                    type="date"
                    data-validate
                    data-label="Preferred start date"
                    aria-describedby="contact-start-date-error"
                  />

                  <p
                    id="contact-start-date-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field">
                  <label for="contact-preferred-days">
                    Preferred Days or Sessions
                    <span class="contact-field__optional"> Optional </span>
                  </label>

                  <input
                    id="contact-preferred-days"
                    name="preferred_days"
                    type="text"
                    maxlength="100"
                    placeholder="e.g. Full days Mon-Wed"
                    data-validate
                    data-label="Preferred days or sessions"
                    aria-describedby="contact-preferred-days-error"
                  />

                  <p
                    id="contact-preferred-days-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <div class="contact-field contact-field--full">
                  <div class="contact-field__label-row">
                    <label for="contact-message">
                      Message
                      <span aria-hidden="true">*</span>
                    </label>

                    <span
                      id="contact-message-count"
                      class="contact-field__count"
                      aria-live="polite"
                    >
                      0 / 1500
                    </span>
                  </div>

                  <textarea
                    id="contact-message"
                    name="message"
                    rows="7"
                    minlength="20"
                    maxlength="1500"
                    placeholder="Tell us a little about your child and how we can help."
                    required
                    data-validate
                    data-label="Message"
                    data-required-message="Tell us how we can help."
                    aria-describedby="contact-message-hint contact-message-error"
                  ></textarea>

                  <p id="contact-message-hint" class="contact-field__hint">
                    Please do not include confidential medical documents or
                    other highly sensitive information.
                  </p>

                  <p
                    id="contact-message-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>
              </div>

              <div id="contact-captcha" class="contact-captcha" tabindex="-1">
                <div class="h-captcha" data-captcha="true"></div>

                <p
                  id="contact-captcha-error"
                  class="contact-field__error"
                  aria-live="polite"
                >
                </p>
              </div>

              <div class="contact-form__footer">
                <div class="contact-consent">
                  <div class="contact-consent__control">
                    <input
                      id="contact-consent"
                      name="privacy_consent"
                      type="checkbox"
                      value="Consent provided"
                      required
                      data-validate
                      data-label="Privacy consent"
                      data-required-message="Confirm that we may use your information to respond."
                      aria-describedby="contact-consent-error"
                    />

                    <label for="contact-consent">
                      I consent to Little Wise Kids using my information to
                      respond to this enquiry. Read our
                      <a href="/parents-information#policies">
                        Privacy Policy
                      </a>.
                    </label>
                  </div>

                  <p
                    id="contact-consent-error"
                    class="contact-field__error"
                    aria-live="polite"
                  >
                  </p>
                </div>

                <button class="contact-form__submit" type="submit">
                  <span data-submit-label> Send Enquiry </span>
                  <span aria-hidden="true">→</span>
                </button>
              </div>

              <p
                id="contact-form-status"
                class="contact-form__status"
                role="status"
                aria-live="polite"
              >
              </p>
            </form>
          </section>

          <section class="contact-next" aria-labelledby="contact-next-title">
            <header class="contact-section-heading">
              <p class="contact-section-heading__eyebrow">{contactPage.nextStepsLabel}</p>

              <h2 id="contact-next-title">{contactPage.nextStepsHeading}</h2>
            </header>

            <ol class="contact-next__grid">
              {
                nextSteps.map((step) => (
                  <li class="contact-next__step">
                    <span class="contact-next__number" aria-hidden="true">
                      {step.number}
                    </span>

                    <div>
                      <h3>{step.title}</h3>
                      <p>{step.copy}</p>
                    </div>
                  </li>
                ))
              }
            </ol>
          </section>

          <section
            class="contact-location"
            aria-labelledby="contact-location-title"
          >
            <div class="contact-location__map" aria-hidden="true">
              <span
                class="contact-location__map-line contact-location__map-line--one"
              ></span>
              <span
                class="contact-location__map-line contact-location__map-line--two"
              ></span>
              <span
                class="contact-location__map-line contact-location__map-line--three"
              ></span>

              <span class="contact-location__pin">
                <Icon name="heart" size={32} />
              </span>
            </div>

            <div class="contact-location__details">
              <header
                class="contact-section-heading contact-section-heading--left"
              >
                <p class="contact-section-heading__eyebrow">{contactPage.locationLabel}</p>

                <h2 id="contact-location-title">{contactPage.locationHeading}</h2>
              </header>

              <div class="contact-location__item">
                <span class="contact-location__icon" aria-hidden="true">
                  <Icon name="heart" size={25} />
                </span>

                <address>
                  <strong>{businessDetails.address.organisation}</strong><br />
                  {businessDetails.address.line1}<br />
                  {businessDetails.address.city}, {businessDetails.address.postcode}
                </address>
              </div>

              <div class="contact-location__item">
                <span class="contact-location__icon" aria-hidden="true">
                  <Icon name="clock" size={25} />
                </span>

                <p>
                  <strong>Opening hours</strong><br />
                  {businessDetails.openingDays}<br />
                  {formatTimeRange(businessDetails.openingTime, businessDetails.closingTime)}
                </p>
              </div>
            </div>
          </section>
        </div>
      </Container>
    </div>
  </article>
</BaseLayout>

<script is:inline src="https://web3forms.com/client/script.js" async defer
></script>

<script>
  type ValidatedField =
    HTMLInputElement | HTMLSelectElement | HTMLTextAreaElement;

  const form = document.querySelector(".contact-form");

  if (form instanceof HTMLFormElement) {
    const fields = Array.from(
      form.querySelectorAll<ValidatedField>("[data-validate]")
    );

    const touchedFields = new WeakSet();
    const errorSummary = document.querySelector(
      "#contact-error-summary"
    ) as HTMLElement | null;
    const errorSummaryList = errorSummary?.querySelector("ul");

    const subjectInput = document.querySelector("#contact-subject");
    const redirectInput = document.querySelector("#contact-redirect");
    const submitButton = form.querySelector(".contact-form__submit");
    const submitLabel = form.querySelector("[data-submit-label]");
    const formStatus = document.querySelector("#contact-form-status");
    const messageField = document.querySelector("#contact-message");
    const messageCount = document.querySelector("#contact-message-count");
    const dateField = document.querySelector("#contact-start-date");
    const captchaContainer = document.querySelector("#contact-captcha");
    const captchaError = document.querySelector("#contact-captcha-error");

    const formatLocalDate = (date: Date) => {
      const adjustedDate = new Date(
        date.getTime() - date.getTimezoneOffset() * 60_000
      );

      return adjustedDate.toISOString().split("T")[0];
    };

    if (dateField instanceof HTMLInputElement) {
      dateField.min = formatLocalDate(new Date());
    }

    const updateCharacterCount = () => {
      if (messageField instanceof HTMLTextAreaElement && messageCount) {
        messageCount.textContent = `${messageField.value.length} / 1500`;
      }
    };

    updateCharacterCount();

    const getFieldContainer = (field: ValidatedField) => {
      return (
        field.closest(".contact-field") ?? field.closest(".contact-consent")
      );
    };

    const getErrorElement = (field: ValidatedField) => {
      if (!field.id) return null;

      return document.querySelector(`#${CSS.escape(field.id)}-error`);
    };

    const setFieldState = (field: ValidatedField, message: string) => {
      const container = getFieldContainer(field);
      const errorElement = getErrorElement(field);
      const hasError = Boolean(message);

      field.setAttribute("aria-invalid", String(hasError));

      field.setCustomValidity(message);

      container?.classList.toggle("is-invalid", hasError);

      container?.classList.toggle(
        "is-valid",
        !hasError && touchedFields.has(field)
      );

      if (errorElement) {
        errorElement.textContent = message;
      }

      return !hasError;
    };

    const validateField = (field: ValidatedField) => {
      const value = "value" in field ? field.value.trim() : "";

      let message = "";

      if (field instanceof HTMLInputElement && field.type === "checkbox") {
        if (field.required && !field.checked) {
          message = field.dataset.requiredMessage ?? "Complete this field.";
        }

        return setFieldState(field, message);
      }

      if (field.required && !value) {
        message = field.dataset.requiredMessage ?? "Complete this field.";

        return setFieldState(field, message);
      }

      switch (field.name) {
        case "name": {
          if (value && value.length < 2) {
            message = "Enter at least two characters.";
          }
          break;
        }

        case "email": {
          if (
            field instanceof HTMLInputElement &&
            value &&
            field.validity.typeMismatch
          ) {
            message = "Enter a valid email address, such as name@example.com.";
          }
          break;
        }

        case "phone": {
          const digits = value.replace(/\D/g, "");

          if (value && digits.length < 7) {
            message =
              "Enter a complete phone number, including its dialling code.";
          }
          break;
        }

        case "preferred_start_date": {
          if (value) {
            const today = formatLocalDate(new Date());

            if (value < today) {
              message = "Choose today or a future date.";
            }
          }
          break;
        }

        case "message": {
          if (value && value.length < 20) {
            message =
              "Add a little more detail so our team can help. Use at least 20 characters.";
          }
          break;
        }
      }

      return setFieldState(field, message);
    };

    const validateCaptcha = () => {
      const responseField = form.querySelector(
        'textarea[name="h-captcha-response"]'
      );

      const isComplete =
        responseField instanceof HTMLTextAreaElement &&
        Boolean(responseField.value.trim());

      captchaContainer?.classList.toggle("is-invalid", !isComplete);

      if (captchaError) {
        captchaError.textContent = isComplete
          ? ""
          : "Complete the anti-spam check before sending your enquiry.";
      }

      return isComplete;
    };

    const renderErrorSummary = (
      errors: { id: string; label: string; message: string }[]
    ) => {
      if (!errorSummary || !errorSummaryList) {
        return;
      }

      errorSummaryList.replaceChildren();

      for (const error of errors) {
        const listItem = document.createElement("li");
        const link = document.createElement("a");

        link.href = `#${error.id}`;
        link.textContent = `${error.label}: ${error.message}`;

        link.addEventListener("click", (event) => {
          event.preventDefault();

          const target = document.querySelector(`#${CSS.escape(error.id)}`);

          if (target instanceof HTMLElement) {
            target.focus();
            target.scrollIntoView({
              behavior: "smooth",
              block: "center",
            });
          }
        });

        listItem.append(link);
        errorSummaryList.append(listItem);
      }

      errorSummary.hidden = errors.length === 0;

      if (errors.length > 0) {
        errorSummary.focus();
      }
    };

    for (const field of fields) {
      field.addEventListener("blur", () => {
        touchedFields.add(field);
        validateField(field);
      });

      field.addEventListener("input", () => {
        if (touchedFields.has(field)) {
          validateField(field);
        }

        if (field === messageField) {
          updateCharacterCount();
        }
      });

      field.addEventListener("change", () => {
        if (touchedFields.has(field)) {
          validateField(field);
        }
      });
    }

    form.addEventListener("submit", (event) => {
      const errors = [];

      for (const field of fields) {
        touchedFields.add(field);

        const isValid = validateField(field);

        if (!isValid) {
          const errorElement = getErrorElement(field);

          errors.push({
            id: field.id,
            label: field.getAttribute("data-label") ?? "Field",
            message: errorElement?.textContent ?? "Check this field.",
          });
        }
      }

      const captchaValid = validateCaptcha();

      if (!captchaValid) {
        errors.push({
          id: "contact-captcha",
          label: "Anti-spam check",
          message: "Complete the anti-spam check.",
        });
      }

      if (errors.length > 0) {
        event.preventDefault();

        renderErrorSummary(errors);

        if (formStatus) {
          formStatus.textContent =
            "Your enquiry has not been sent yet. Correct the highlighted fields and try again.";
        }

        return;
      }

      renderErrorSummary([]);

      const nameField = form.elements.namedItem("name");

      const enquiryField = form.elements.namedItem("enquiry_type");

      const visitorName =
        nameField instanceof HTMLInputElement
          ? nameField.value.trim()
          : "Website visitor";

      let enquiryLabel = "General enquiry";

      if (enquiryField instanceof HTMLSelectElement) {
        enquiryLabel =
          enquiryField.options[enquiryField.selectedIndex]?.text ??
          enquiryLabel;
      }

      if (subjectInput instanceof HTMLInputElement) {
        subjectInput.value = `New Little Wise Kids enquiry — ${enquiryLabel} — ${visitorName}`;
      }

      if (redirectInput instanceof HTMLInputElement) {
        redirectInput.value = new URL(
          "/thank-you/",
          window.location.origin
        ).href;
      }

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
        submitButton.setAttribute("aria-busy", "true");
      }

      if (submitLabel) {
        submitLabel.textContent = "Sending…";
      }

      if (formStatus) {
        formStatus.textContent = "Sending your enquiry securely.";
      }
    });
  }
</script>
