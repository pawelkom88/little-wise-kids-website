---
export const prerender = true;
import "./about-us.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import SanityImage from "../components/media/SanityImage.astro";
import { Image } from "astro:assets";
import { getAboutPage, getBusinessDetails, urlFor } from "../utils/sanity";
import type { SeoConfig } from "../lib/seo/types";
import { buildPersonSchema } from "../lib/seo/buildPersonSchema";

import heroBg from "../assets/images/littlewisekids-outdoor-hero-image.webp";
import heroVideoMp4 from "../assets/videos/littlewisekids-hero-mobile.mp4?url";
import heroVideoWebm from "../assets/videos/littlewisekids-hero-mobile.webm?url";
import "../components/media/VideoModal.css";
import iconQuote from "../assets/images/icon-quote.png";
import iconPlay from "../assets/images/icon-play.png";
import iconRhythm from "../assets/images/icon-rhythm.png";
import iconOutdoor from "../assets/images/icon-outdoor.png";
import iconSensory from "../assets/images/icon-sensory.png";
import iconConfidence from "../assets/images/icon-confidence.png";
import iconRelationships from "../assets/images/icon-relationships.png";

import iconCommunication from "../assets/images/icon-communication.png";
import iconEmpathy from "../assets/images/icon-empathy.png";
import iconIndependence from "../assets/images/icon-independence.png";
import iconCreativity from "../assets/images/icon-creativity.png";
import iconCriticalThinking from "../assets/images/icon-critical-thinking.png";
import lukebaSignature from "../assets/images/lukeba-signature.webp";

const aboutPage = await getAboutPage();
const businessDetails = await getBusinessDetails();

const founderName = aboutPage.founderName || "Lukeba";
const founderRole = aboutPage.founderRole || "Founder & Early Years Educator";
const founderQuote = aboutPage.founderQuote || aboutPage.founderTestimonial || "Today, I bring together strategic thinking, emotional intelligence and a deep respect for children’s individuality. At Little Wise Kids, I blend structure with warmth, curiosity with care, and high expectations with a truly nurturing approach.";

const posterUrl = aboutPage.leadershipImage?.asset?._ref
  ? urlFor(aboutPage.leadershipImage).width(800).url()
  : "/images/littlewisekids-hero-poster.jpg";

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://littlewisekids.co.uk";
const canonicalUrl = `${siteUrl}/about-us`;
const seoTitle = `${aboutPage.heroTitleLineOne || "Child-Led Childcare"} ${aboutPage.heroTitleLineTwo || "in Easton"} | Little Wise Kids`;
const seoDescription = `Meet Lukeba and the team behind Little Wise Kids, a calm, home-from-home childcare setting in ${businessDetails.address?.shortLocation || "Easton, Bristol BS5"}, focused on child-led play.`;

const seo: SeoConfig = {
  title: seoTitle,
  description: seoDescription,
  canonicalPath: "/about-us",
  type: "website",
  schemas: [
    buildPersonSchema(siteUrl, founderName, founderRole, founderQuote),
  ],
};

const approachPoints = [
  { image: iconPlay, tone: "purple", text: aboutPage.approachChildLed, alt: "Child-led play icon" },
  { image: iconRhythm, tone: "green", text: aboutPage.approachCalmRhythm, alt: "Calm rhythm icon" },
  { image: iconOutdoor, tone: "blue", text: aboutPage.approachLearning, alt: "Outdoor learning icon" },
  { image: iconSensory, tone: "yellow", text: aboutPage.approachExploration, alt: "Sensory exploration icon" },
  { image: iconConfidence, tone: "purple", text: aboutPage.approachConfidence, alt: "Confidence icon" },
  { image: iconRelationships, tone: "green", text: aboutPage.approachRelationships, alt: "Relationships icon" },
] as const;

const learningFoundations = [
  { image: iconCommunication, tone: "purple", label: aboutPage.foundationCommunication, alt: "Communication icon" },
  { image: iconEmpathy, tone: "green", label: aboutPage.foundationEmpathy, alt: "Empathy icon" },
  { image: iconIndependence, tone: "blue", label: aboutPage.foundationIndependence, alt: "Independence icon" },
  { image: iconCreativity, tone: "yellow", label: aboutPage.foundationCreativity, alt: "Creativity icon" },
  { image: iconCriticalThinking, tone: "purple", label: aboutPage.foundationCriticalThinking, alt: "Critical thinking icon" },
] as const;
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="about-page">
    <section id="about-us" class="lwk-about" aria-labelledby="about-page-title">
      <SubpageHero 
        id="about-page-title" 
        eyebrow="About Us" 
        tone="purple"
        titleLineOne={aboutPage.heroTitleLineOne}
        titleLineTwo={aboutPage.heroTitleLineTwo}
        bgImage={heroBg}
      >
        <PortableContent value={aboutPage.heroParagraphs} />
      </SubpageHero>

      <div class="lwk-about__sections">
        <section
          id="our-leadership-team"
          class="lwk-about__section lwk-about__section--founder"
          aria-labelledby="founder-story-heading"
        >
          <Container size="wide">
            <div class="lwk-about__founder-story">
              <div class="lwk-about__founder-media-column" data-founder-video-modal>
                <div
                  class="video-card lwk-about__founder-video"
                  role="button"
                  aria-label="Play founder story video full screen"
                  tabindex="0"
                  data-video-trigger
                >
                  <video
                    class="hero-video-preview"
                    autoplay
                    loop
                    muted
                    playsinline
                    preload="metadata"
                    poster={posterUrl}
                    data-preview-video
                  >
                    <source src={heroVideoWebm} type="video/webm" />
                    <source src={heroVideoMp4} type="video/mp4" />
                  </video>
                  <div class="video-card__overlay"></div>
                  <div class="hero-play-btn" aria-hidden="true">
                    <span class="play-icon-pulse"></span>
                    <svg class="play-icon" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M8 5v14l11-7z"/>
                    </svg>
                  </div>
                </div>

                <dialog
                  id="about-video-dialog"
                  class="video-dialog"
                  aria-label="Founder video"
                  data-video-dialog
                >
                  <div class="video-dialog__content">
                    <button
                      class="video-dialog__close"
                      type="button"
                      aria-label="Close video"
                      data-video-close
                    >
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        aria-hidden="true"
                      >
                        <path d="M18 6L6 18M6 6l12 12" />
                      </svg>
                    </button>
                    <video
                      class="video-dialog__video"
                      controls
                      playsinline
                      preload="metadata"
                      data-modal-video
                    >
                      <source src={heroVideoWebm} type="video/webm" />
                      <source src={heroVideoMp4} type="video/mp4" />
                      Your browser does not support embedded video.
                    </video>
                  </div>
                </dialog>

                <div class="lwk-about__testimonial-container">
                  <div class="lwk-about__founder-callout-card">
                    <p class="lwk-about__founder-callout-text">
                      {founderQuote}
                    </p>
                  </div>

                  <div class="lwk-about__testimonial-meta">
                    <Image
                      src={lukebaSignature}
                      alt={founderName}
                      class="lwk-about__founder-signature-img"
                      height={48}
                    />
                    <span class="lwk-about__testimonial-divider" aria-hidden="true"></span>
                    <div class="lwk-about__founder-info">
                      <strong class="lwk-about__founder-title">{founderRole}</strong>
                      <span class="lwk-about__founder-org">Little Wise Kids</span>
                    </div>
                  </div>
                </div>
              </div>

              <div class="lwk-about__founder-content">
                <div class="lwk-about__founder-kicker">
                  <p class="lwk-about__label lwk-about__label--purple">
                    {aboutPage.leadershipLabel}
                  </p>
                </div>

                <h2 id="founder-story-heading">
                  {aboutPage.leadershipHeading}
                </h2>

                <div class="lwk-about__prose lwk-about__founder-prose">
                  <PortableContent value={aboutPage.leadershipParagraphs} />
                </div>
              </div>
            </div>
          </Container>
        </section>

        <section
          id="our-approach"
          class="lwk-about__section
        lwk-about__section--approach"
        >
          <Container size="wide">
            <div class="lwk-about__approach-grid">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  {aboutPage.approachLabel}
                </p>

                <h2>{aboutPage.approachHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.approachParagraphs} />
                </div>
              </div>

              <ul
                class="lwk-about__key-points"
                aria-label="Our approach key points"
              >
                {
                  approachPoints.map((point) => (
                    <li>
                      <span
                        class={`
                      lwk-about__point-icon
                      lwk-about__point-icon--${point.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Image
                          src={point.image}
                          alt={point.alt}
                          width={256}
                          height={256}
                          quality={100}
                        />
                      </span>

                      <span>{point.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-commitment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--green"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  {aboutPage.commitmentLabel}
                </p>

                <h2>{aboutPage.commitmentHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.commitmentParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {aboutPage.commitmentImage?.asset?._ref ? (
                  <SanityImage
                    image={aboutPage.commitmentImage}
                    alt={aboutPage.commitmentImage.altText ?? ""}
                    class="lwk-about__image"
                    widths={[320, 480, 640, 800]}
                    sizes="(min-width: 72rem) 560px, 100vw"
                    layout="constrained"
                  />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="heartSmile" size={44} />
                    <span>Home-from-home image</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>

        <section id="our-environment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--blue
            lwk-about__split-card--media-first"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--blue"
                >
                  {aboutPage.environmentLabel}
                </p>

                <h2>{aboutPage.environmentHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.environmentParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {aboutPage.environmentImage?.asset?._ref ? (
                  <SanityImage
                    image={aboutPage.environmentImage}
                    alt={aboutPage.environmentImage.altText ?? ""}
                    class="lwk-about__image"
                    widths={[320, 480, 640, 800]}
                    sizes="(min-width: 72rem) 560px, 100vw"
                    layout="constrained"
                  />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="image" size={44} />
                    <span>Environment image</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>

        <section id="our-learning-programmes" class="lwk-about__section">
          <Container size="wide">
            <div class="lwk-about__programme-card">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  {aboutPage.programmesLabel}
                </p>

                <h2>{aboutPage.programmesHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.programmesParagraphs} />
                </div>
              </div>

              <ul
                class="lwk-about__foundations"
                aria-label="Learning foundations"
              >
                {
                  learningFoundations.map((foundation) => (
                    <li>
                      <span
                        class={`
                      lwk-about__foundation-icon
                      lwk-about__foundation-icon--${foundation.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Image
                          src={foundation.image}
                          alt={foundation.alt}
                          width={256}
                          height={256}
                          quality={100}
                        />
                      </span>

                      <span>{foundation.label}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-educators" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--yellow"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  {aboutPage.educatorsLabel}
                </p>

                <h2>{aboutPage.educatorsHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.educatorsParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {aboutPage.educatorsImage?.asset?._ref ? (
                  <SanityImage
                    image={aboutPage.educatorsImage}
                    alt={aboutPage.educatorsImage.altText ?? ""}
                    class="lwk-about__image"
                    widths={[320, 480, 640, 800]}
                    sizes="(min-width: 72rem) 560px, 100vw"
                    layout="constrained"
                  />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="users" size={44} />
                    <span>Team photo to be supplied</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>


      </div>
    </section>
  </article>

  <script>
    import { initialiseVideoModal } from "../components/media/videoModal";

    const root = document.querySelector<HTMLElement>("[data-founder-video-modal]");

    if (root) {
      const trigger = root.querySelector<HTMLElement>("[data-video-trigger]");
      const dialog = root.querySelector<HTMLDialogElement>("[data-video-dialog]");
      const modalVideo = root.querySelector<HTMLVideoElement>("[data-modal-video]");
      const previewVideo = root.querySelector<HTMLVideoElement>("[data-preview-video]");
      const closeButton = root.querySelector<HTMLButtonElement>("[data-video-close]");

      if (trigger && dialog && modalVideo && previewVideo && closeButton) {
        initialiseVideoModal({
          trigger,
          dialog,
          modalVideo,
          previewVideo,
          closeButton,
        });
      }
    }
  </script>
</BaseLayout>
