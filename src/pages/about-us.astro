---
import "./about-us.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";

const approachPoints = [
  {
    icon: "users",
    tone: "purple",
    text: "Child-led, play-based learning",
  },
  {
    icon: "clock",
    tone: "green",
    text: "Calm and unhurried daily rhythms",
  },
  {
    icon: "heart",
    tone: "blue",
    text: "Indoor and outdoor learning opportunities",
  },
  {
    icon: "palette",
    tone: "yellow",
    text: "Sensory, imaginative and creative exploration",
  },
  {
    icon: "star",
    tone: "purple",
    text: "Support for confidence, focus and independence",
  },
  {
    icon: "users",
    tone: "green",
    text: "Strong relationships with children and families",
  },
] as const;

const learningFoundations = [
  {
    icon: "chat",
    tone: "purple",
    label: "Communication",
  },
  {
    icon: "heart",
    tone: "green",
    label: "Empathy",
  },
  {
    icon: "person",
    tone: "blue",
    label: "Independence",
  },
  {
    icon: "palette",
    tone: "yellow",
    label: "Creativity",
  },
  {
    icon: "star",
    tone: "purple",
    label: "Critical thinking",
  },
] as const;

const activityPhotos = [
  "Creative play",
  "Learning together",
  "Outdoor exploration",
  "Happy moments",
] as const;
---

<BaseLayout
  title="About Us | Little Wise Kids"
  description="Discover the values, approach, environment, educators and leadership behind Little Wise Kids."
>
  <article class="about-page">
    <section id="about-us" class="lwk-about" aria-labelledby="about-page-title">
      <header class="lwk-about-hero">
        <div class="lwk-about-hero__content">
          <p class="lwk-about__eyebrow">About Us</p>

          <h1 id="about-page-title">
            <span>Rooted in Curiosity,</span>
            <span>Rising in Confidence</span>
          </h1>

          <div class="lwk-about-hero__copy">
            <p>
              At Little Wise Kids, we believe every child is born wise: full of
              wonder, ready to explore and uniquely themselves. Our role is to
              nurture that natural brilliance through responsive, child-led
              learning in a loving, home-like environment.
            </p>

            <p>
              We honour each child’s individuality by offering meaningful
              experiences that meet them where they are developmentally,
              emotionally and culturally. Children aged 0–4 years are welcomed
              for now, with their wellbeing, confidence and curiosity guiding
              our practice.
            </p>
          </div>
        </div>

        <span class="lwk-about-hero__wave-highlight" aria-hidden="true"></span>

        <div class="lwk-about-hero__wave" aria-hidden="true">
          <svg viewBox="0 0 1440 220" preserveAspectRatio="none">
            <path
              d="M0 58C130 118 272 116 413 86C560 55 655 63 805 112C975 168 1102 119 1258 69C1330 46 1392 39 1440 52V220H0V58Z"
            ></path>
          </svg>
        </div>
      </header>

      <div class="lwk-about__sections">
        <section
          id="our-approach"
          class="lwk-about__section
        lwk-about__section--approach"
        >
          <Container size="wide">
            <div class="lwk-about__approach-grid">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  Our Approach
                </p>

                <h2>Child-Led Learning With Purpose</h2>

                <div class="lwk-about__prose">
                  <p>
                    Children flourish when they feel seen, safe and supported.
                    Our experienced educators thoughtfully create learning
                    experiences around children’s evolving interests,
                    curiosities and developmental milestones.
                  </p>

                  <p>
                    We believe play is the work of childhood. Children are given
                    time to explore, build, create, question and imagine without
                    being rushed. From planting seeds outdoors to role-playing
                    in our home corners, every experience is designed to support
                    cognitive, emotional, physical and social development.
                  </p>
                </div>
              </div>

              <ul
                class="lwk-about__key-points"
                aria-label="Our approach key points"
              >
                {
                  approachPoints.map((point) => (
                    <li>
                      <span
                        class={`
                      lwk-about__point-icon
                      lwk-about__point-icon--${point.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Icon name={point.icon} size={25} />
                      </span>

                      <span>{point.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-commitment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--green"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  Our Commitment
                </p>

                <h2>A True Home-from-Home</h2>

                <div class="lwk-about__prose">
                  <p>
                    At Little Wise Kids, we do things differently and
                    intentionally. We offer a calm, screen-free sanctuary where
                    childhood is honoured rather than hurried.
                  </p>

                  <p>
                    Our setting combines thoughtful early education with genuine
                    warmth and care. Children benefit from enriching play,
                    English and Portuguese exposure for now, nutritious food and
                    a family-style environment that supports them to feel secure
                    and capable.
                  </p>
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                <span class="lwk-about__media-placeholder">
                  <Icon name="heartSmile" size={44} />

                  <span>Home-from-home image</span>
                </span>
              </div>
            </div>
          </Container>
        </section>

        <section id="our-environment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--blue
            lwk-about__split-card--media-first"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--blue"
                >
                  Our Environment
                </p>

                <h2>Spaces Made for Wonder</h2>

                <div class="lwk-about__prose">
                  <p>
                    Our indoor and outdoor spaces are designed to feel like a
                    natural extension of home. Children can discover cosy
                    reading corners, imaginative play areas, sensory experiences
                    and outdoor adventures in a calm, inviting and screen-free
                    setting.
                  </p>

                  <p>
                    Every space is created to encourage exploration while
                    helping children feel safe, comfortable and free to be
                    themselves.
                  </p>
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                <span class="lwk-about__media-placeholder">
                  <Icon name="image" size={44} />

                  <span>Environment image</span>
                </span>
              </div>
            </div>
          </Container>
        </section>

        <section id="our-learning-programmes" class="lwk-about__section">
          <Container size="wide">
            <div class="lwk-about__programme-card">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  Our Learning Programmes
                </p>

                <h2>Learning That Grows With Your Child</h2>

                <div class="lwk-about__prose">
                  <p>
                    Learning at Little Wise Kids is a joyful journey led by
                    children’s interests. Our curriculum encourages children to
                    explore, question and create in their own time, while
                    educators provide gentle guidance and meaningful
                    opportunities to extend learning.
                  </p>

                  <p>
                    Through play, language, sensory exploration, creativity and
                    nature-based discovery, children develop foundations in
                    communication, independence, empathy and critical thinking.
                  </p>
                </div>
              </div>

              <ul
                class="lwk-about__foundations"
                aria-label="Learning foundations"
              >
                {
                  learningFoundations.map((foundation) => (
                    <li>
                      <span
                        class={`
                      lwk-about__foundation-icon
                      lwk-about__foundation-icon--${foundation.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Icon name={foundation.icon} size={27} />
                      </span>

                      <span>{foundation.label}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-educators" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--yellow"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  Our Educators
                </p>

                <h2>Caring People at the Heart of Our Nursery</h2>

                <div class="lwk-about__prose">
                  <p>
                    Our educators are the heart of Little Wise Kids. They do
                    more than supervise: they listen, guide, encourage and
                    inspire.
                  </p>

                  <p>
                    With a deep understanding of early years development and a
                    genuine love for working with children, our team builds
                    warm, respectful relationships with every child and family.
                    Each day, they bring care, insight and intention to make
                    learning meaningful and joyful.
                  </p>
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                <span class="lwk-about__media-placeholder">
                  <Icon name="users" size={44} />

                  <span>Team photo to be supplied</span>
                </span>
              </div>
            </div>
          </Container>
        </section>

        <section id="our-leadership-team" class="lwk-about__section">
          <Container size="wide">
            <div class="lwk-about__leadership-card">
              <div class="lwk-about__portrait" aria-hidden="true">
                <span class="lwk-about__media-placeholder">
                  <Icon name="person" size={48} />

                  <span>Leadership photo to be supplied</span>
                </span>
              </div>

              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--yellow"
                >
                  Our Leadership Team
                </p>

                <h2>
                  From Boardrooms to Building Blocks: A Journey of Purpose
                </h2>

                <div class="lwk-about__prose">
                  <p>
                    Hello, I’m Lukeba, the founder of Little Wise Kids and a
                    passionate early years educator.
                  </p>

                  <p>
                    Before entering early childhood education, I spent more than
                    a decade leading teams in corporate and academic settings,
                    including health, safety, environment, public transport,
                    food manufacturing, construction, housing safety management
                    and higher education.
                  </p>

                  <p>
                    Supporting young adults through important transitions showed
                    me the lasting impact of early emotional development and
                    educational foundations. I saw how childhood experiences
                    shape confidence, resilience and wellbeing far into
                    adulthood. That understanding inspired me to retrain as an
                    EYFS childminder and become part of building those
                    foundations from the very beginning.
                  </p>

                  <p>
                    Today, I bring together strategic thinking, emotional
                    intelligence and a deep respect for children’s
                    individuality. At Little Wise Kids, I blend structure with
                    warmth, curiosity with care, and high expectations with a
                    truly nurturing approach.
                  </p>

                  <p>
                    This is not just childcare. It is my calling, and I am
                    honoured to support the first chapter of every child’s
                    learning journey.
                  </p>
                </div>
              </div>
            </div>
          </Container>
        </section>

        <section
          class="lwk-about__section
        lwk-about__section--gallery"
          aria-labelledby="about-gallery-title"
        >
          <Container size="wide">
            <header class="lwk-about__gallery-heading">
              <p class="lwk-about__label
              lwk-about__label--purple">
                Life at Little Wise Kids
              </p>

              <h2 id="about-gallery-title">Little Moments, Big Discoveries</h2>
            </header>

            <div class="lwk-about__gallery-grid">
              {
                activityPhotos.map((label) => (
                  <div class="lwk-about__gallery-card" aria-hidden="true">
                    <span class="lwk-about__media-placeholder">
                      <Icon name="image" size={38} />

                      <span>{label}</span>
                    </span>
                  </div>
                ))
              }
            </div>
          </Container>
        </section>
      </div>
    </section>
  </article>
</BaseLayout>
