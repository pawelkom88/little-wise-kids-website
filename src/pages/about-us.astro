---
import "./about-us.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getAboutPage, getAboutGalleryPhotos } from "../utils/sanity";
import { getImageUrl } from "../lib/images";

const aboutPage = await getAboutPage();
const galleryPhotos = await getAboutGalleryPhotos();

const commitmentImg = getImageUrl(aboutPage.commitmentImage, 800);
const environmentImg = getImageUrl(aboutPage.environmentImage, 800);
const educatorsImg = getImageUrl(aboutPage.educatorsImage, 800);
const leadershipImg = getImageUrl(aboutPage.leadershipImage, 400);

const approachPoints = [
  { icon: "users", tone: "purple", text: aboutPage.approachChildLed },
  { icon: "clock", tone: "green", text: aboutPage.approachCalmRhythm },
  { icon: "heart", tone: "blue", text: aboutPage.approachLearning },
  { icon: "palette", tone: "yellow", text: aboutPage.approachExploration },
  { icon: "star", tone: "purple", text: aboutPage.approachConfidence },
  { icon: "users", tone: "green", text: aboutPage.approachRelationships },
] as const;

const learningFoundations = [
  { icon: "chat", tone: "purple", label: aboutPage.foundationCommunication },
  { icon: "heart", tone: "green", label: aboutPage.foundationEmpathy },
  { icon: "person", tone: "blue", label: aboutPage.foundationIndependence },
  { icon: "palette", tone: "yellow", label: aboutPage.foundationCreativity },
  { icon: "star", tone: "purple", label: aboutPage.foundationCriticalThinking },
] as const;
---

<BaseLayout
 
  title="About Us | Little Wise Kids"
  description="Discover the values, approach, environment, educators and leadership behind Little Wise Kids."
  description="Discover the values, approach, environment, educators and leadership behind Little Wise Kids."
>
  <article class="about-page">
    <section id="about-us" class="lwk-about" aria-labelledby="about-page-title">
      <SubpageHero id="about-page-title" eyebrow={aboutPage.heroEyebrow ?? "About Us"} tone="purple">
        <Fragment slot="title">
          <span>{aboutPage.heroTitleLineOne}</span>
          <span>{aboutPage.heroTitleLineTwo}</span>
        </Fragment>

        <PortableContent value={aboutPage.heroParagraphs} />
      </SubpageHero>

      <div class="lwk-about__sections">
        <section
          id="our-approach"
          class="lwk-about__section
        lwk-about__section--approach"
        >
          <Container size="wide">
            <div class="lwk-about__approach-grid">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  {aboutPage.approachLabel}
                </p>

                <h2>{aboutPage.approachHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.approachParagraphs} />
                </div>
              </div>

              <ul
                class="lwk-about__key-points"
                aria-label="Our approach key points"
              >
                {
                  approachPoints.map((point) => (
                    <li>
                      <span
                        class={`
                      lwk-about__point-icon
                      lwk-about__point-icon--${point.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Icon name={point.icon} size={25} />
                      </span>

                      <span>{point.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-commitment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--green"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  {aboutPage.commitmentLabel}
                </p>

                <h2>{aboutPage.commitmentHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.commitmentParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {commitmentImg ? (
                  <img src={commitmentImg} alt={aboutPage.commitmentImage.altText ?? ""} class="lwk-about__image" />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="heartSmile" size={44} />
                    <span>Home-from-home image</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>

        <section id="our-environment" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--blue
            lwk-about__split-card--media-first"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--blue"
                >
                  {aboutPage.environmentLabel}
                </p>

                <h2>{aboutPage.environmentHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.environmentParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {environmentImg ? (
                  <img src={environmentImg} alt={aboutPage.environmentImage.altText ?? ""} class="lwk-about__image" />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="image" size={44} />
                    <span>Environment image</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>

        <section id="our-learning-programmes" class="lwk-about__section">
          <Container size="wide">
            <div class="lwk-about__programme-card">
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--purple"
                >
                  {aboutPage.programmesLabel}
                </p>

                <h2>{aboutPage.programmesHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.programmesParagraphs} />
                </div>
              </div>

              <ul
                class="lwk-about__foundations"
                aria-label="Learning foundations"
              >
                {
                  learningFoundations.map((foundation) => (
                    <li>
                      <span
                        class={`
                      lwk-about__foundation-icon
                      lwk-about__foundation-icon--${foundation.tone}
                    `}
                        aria-hidden="true"
                      >
                        <Icon name={foundation.icon} size={27} />
                      </span>

                      <span>{foundation.label}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </Container>
        </section>

        <section id="our-educators" class="lwk-about__section">
          <Container size="wide">
            <div
              class="lwk-about__split-card
            lwk-about__split-card--yellow"
            >
              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--green"
                >
                  {aboutPage.educatorsLabel}
                </p>

                <h2>{aboutPage.educatorsHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.educatorsParagraphs} />
                </div>
              </div>

              <div class="lwk-about__media" aria-hidden="true">
                {educatorsImg ? (
                  <img src={educatorsImg} alt={aboutPage.educatorsImage.altText ?? ""} class="lwk-about__image" />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="users" size={44} />
                    <span>Team photo to be supplied</span>
                  </span>
                )}
              </div>
            </div>
          </Container>
        </section>

        <section id="our-leadership-team" class="lwk-about__section">
          <Container size="wide">
            <div class="lwk-about__leadership-card">
              <div class="lwk-about__portrait" aria-hidden="true">
                {leadershipImg ? (
                  <img src={leadershipImg} alt={aboutPage.leadershipImage.altText ?? ""} class="lwk-about__portrait-image" />
                ) : (
                  <span class="lwk-about__media-placeholder">
                    <Icon name="person" size={48} />
                    <span>Leadership photo to be supplied</span>
                  </span>
                )}
              </div>

              <div class="lwk-about__copy-block">
                <p
                  class="lwk-about__label
                lwk-about__label--yellow"
                >
                  {aboutPage.leadershipLabel}
                </p>

                <h2>{aboutPage.leadershipHeading}</h2>

                <div class="lwk-about__prose">
                  <PortableContent value={aboutPage.leadershipParagraphs} />
                </div>
              </div>
            </div>
          </Container>
        </section>

        <section
          class="lwk-about__section
        lwk-about__section--gallery"
          aria-labelledby="about-gallery-title"
        >
          <Container size="wide">
            <header class="lwk-about__gallery-heading">
              <p class="lwk-about__label
              lwk-about__label--purple">
                {aboutPage.gallerySectionLabel}
              </p>

              <h2 id="about-gallery-title">{aboutPage.gallerySectionHeading}</h2>
            </header>

            <div class="lwk-about__gallery-grid">
              {
                galleryPhotos.length > 0 ? (
                  galleryPhotos.map((photo) => {
                    const src = getImageUrl(photo.image, 600);
                    return src ? (
                    <figure class="lwk-about__gallery-card">
                      <img src={src} alt={photo.image.altText ?? ""} loading="lazy" decoding="async" />
                    </figure>
                    ) : null;
                  })
                ) : (
                  galleryPhotos.length === 0 && (
                    <p>Gallery photos coming soon.</p>
                  )
                )
              }
            </div>
          </Container>
        </section>
      </div>
    </section>
  </article>
</BaseLayout>
