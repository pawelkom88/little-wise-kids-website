---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getParentsPage, getPolicyDocuments, getBusinessDetails } from "../utils/sanity";
import { safeExternalUrl } from "../lib/urls.mjs";
import type { SeoConfig } from "../lib/seo/types";
import "./parents-information.css";

const parentsPage = await getParentsPage();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Parents' Information, Fees & Childcare Funding | Little Wise Kids",
  description: "Information for families joining our Easton childcare setting, covering settling in, daily fees, Tax-Free Childcare, and government funding.",
  canonicalPath: "/parents-information",
};

const schoolSupport = parentsPage.schoolSupport;

const fundingExamples = parentsPage.fundingExamples;

const feeRows = [
  {
    label: "Full-day rate",
    value: parentsPage.fullDayRate,
    field: "fullDayRate",
  },
  {
    label: "Half-day rate",
    value: parentsPage.halfDayRate,
    field: "halfDayRate",
  },
  {
    label: "Funded-hour deductions",
    value: parentsPage.fundedHourDeductions,
    field: "fundedHourDeductions",
  },
  {
    label: "Additional charges",
    value: parentsPage.additionalCharges,
    field: "additionalCharges",
  },
  {
    label: "Example weekly costs",
    value: parentsPage.exampleWeeklyCosts,
    field: "exampleWeeklyCosts",
  },
] as const;

const subsidyFaqs = parentsPage.subsidyFaqs;

const settlingStrategies = parentsPage.settlingStrategies;

const policyDocuments = await getPolicyDocuments();
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="parents-page">
    <SubpageHero
      id="parents-page-title"
      eyebrow={parentsPage.heroEyebrow}
      tone="blue"
      titleLineOne={parentsPage.heroTitleLineOne}
      titleLineTwo={parentsPage.heroTitleLineTwo}
    >

      <PortableContent value={parentsPage.heroParagraphs} />
    </SubpageHero>

    <div class="parents-page__content">
      <Container size="wide">
        <div class="parents-page__stack">
          <section
            id="starting-school"
            class="parents-card
              parents-card--purple"
            aria-labelledby="starting-school-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    01
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.startingSchoolLabel}</p>

                    <h2 id="starting-school-title">{parentsPage.startingSchoolHeading}</h2>
                  </div>
                </header>

                <div class="parents-card__prose">
                  <PortableContent value={parentsPage.startingSchoolParagraphs} />
                </div>
              </div>

              <aside class="parents-card__panel" aria-labelledby="school-support-title">
                <h3 id="school-support-title">We Support Children Through:</h3>

                <ul class="parents-check-list">
                  {schoolSupport.map((item: string) => <li>{item}</li>)}
                </ul>
              </aside>
            </div>
          </section>

          <section
            id="fees-funding"
            class="parents-card
              parents-card--green"
            aria-labelledby="fees-funding-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    02
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.feesFundingLabel}</p>

                    <h2 id="fees-funding-title">
                      {parentsPage.feesFundingHeading}
                    </h2>
                  </div>
                </header>

                <div class="parents-card__prose">
                  <PortableContent value={parentsPage.feesFundingParagraphs} />
                </div>
              </div>


            </div>
          </section>

          <section
            id="how-funding-works"
            class="parents-card
              parents-card--blue"
            aria-labelledby="funding-works-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    03
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.howFundingWorksLabel}</p>

                    <h2 id="funding-works-title">
                      {parentsPage.howFundingWorksHeading}
                    </h2>
                  </div>
                </header>

                <div class="parents-card__prose">
                  <PortableContent value={parentsPage.howFundingWorksParagraphs} />
                </div>
              </div>

              <aside class="parents-card__panel" aria-labelledby="funding-calculations-title">
                <h3 id="funding-calculations-title">Current Example Calculations</h3>

                <div class="parents-calculations">
                  {
                    fundingExamples.map((example: { entitlement: string; equivalent: string; }) => (
                      <article class="parents-calculation">
                        <p>{example.entitlement}</p>
                        <strong>{example.equivalent}</strong>
                      </article>
                    ))
                  }
                </div>
              </aside>
            </div>
          </section>

          <section
            id="funding-support"
            class="parents-card
              parents-card--purple"
            aria-labelledby="funding-support-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    04
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.fundingSupportLabel}</p>

                    <h2 id="funding-support-title">{parentsPage.fundingSupportHeading}</h2>
                  </div>
                </header>

                <div class="parents-card__prose">
                  <PortableContent value={parentsPage.fundingSupportParagraphs} />
                </div>
              </div>

              <aside class="parents-resource" aria-labelledby="childcare-guidance-label">
                <p id="childcare-guidance-label" class="parents-resource__label">
                  Current Government Guidance and Eligibility
                </p>

                <a
                  href="https://www.gov.uk/get-childcare"
                  target="_blank"
                  rel="noreferrer"
                  aria-label="Visit the Government childcare guidance website. Opens in a new tab."
                >
                  gov.uk/get-childcare
                  <span aria-hidden="true">↗</span>
                </a>
              </aside>
            </div>
          </section>

          <section
            id="tax-free-childcare"
            class="parents-card
              parents-card--green"
            aria-labelledby="tax-free-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    05
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.taxFreeLabel}</p>

                    <h2 id="tax-free-title">
                      {parentsPage.taxFreeHeading}
                    </h2>
                  </div>
                </header>

                <div class="parents-card__prose">
                  <PortableContent value={parentsPage.taxFreeParagraphs} />
                </div>
              </div>

              <aside class="parents-resource" aria-labelledby="tax-free-guidance-label">
                <p id="tax-free-guidance-label" class="parents-resource__label">
                  Current Details and Eligibility
                </p>

                <a
                  href="https://www.gov.uk/tax-free-childcare"
                  target="_blank"
                  rel="noreferrer"
                  aria-label="Visit the Government Tax-Free Childcare website. Opens in a new tab."
                >
                  gov.uk/tax-free-childcare
                  <span aria-hidden="true">↗</span>
                </a>
              </aside>
            </div>
          </section>

          <section
            id="weekly-fees-funding"
            class="parents-card
              parents-card--purple
              parents-card--table"
            aria-labelledby="weekly-fees-title"
          >
            <div class="parents-card__main">
              <header class="parents-card__heading">
                <span class="parents-card__number" aria-hidden="true">
                  06
                </span>

                <div>
                  <p class="parents-card__label">{parentsPage.weeklyFeesLabel}</p>

                  <h2 id="weekly-fees-title">
                    {parentsPage.weeklyFeesHeading}
                  </h2>
                </div>
              </header>

              <div class="parents-card__prose">
                  <PortableContent value={parentsPage.weeklyFeesParagraphs} />
              </div>
            </div>

            <div
              class="parents-fees-table-wrapper"
              tabindex="0"
              role="region"
              aria-label="Weekly fees and funding table"
            >
              <table class="parents-fees-table">
                  <caption class="sr-only">
                    Weekly childcare fee and funding values
                  </caption>

                  <thead>
                    <tr>
                      <th scope="col"> Fee or funding element </th>
                      <th scope="col"> Current rate </th>
                    </tr>
                  </thead>

                <tbody>
                  {
                    feeRows.map((row) => (
                      <tr>
                        <th scope="row">{row.label}</th>

                        <td data-cms-field={row.field}>
                          <em>{row.value}</em>
                        </td>
                      </tr>
                    ))
                  }
                </tbody>
              </table>
            </div>


          </section>

          <section
            id="childcare-subsidy-questions"
            class="parents-card
              parents-card--yellow
              parents-card--faq"
            aria-labelledby="subsidy-questions-title"
          >
            <div class="parents-card__main">
              <header class="parents-card__heading">
                <span class="parents-card__number" aria-hidden="true">
                  07
                </span>

                <div>
                  <p class="parents-card__label">{parentsPage.subsidyFaqsLabel}</p>

                  <h2 id="subsidy-questions-title">
                    {parentsPage.subsidyFaqsHeading}
                  </h2>
                </div>
              </header>

              <div class="parents-card__prose">
                <PortableContent value={parentsPage.subsidyFaqsParagraphs} />
              </div>
            </div>

            <div class="parents-faq-list">
              {
                subsidyFaqs.map((faq: { question: string; answer: string; }) => (
                  <details class="parents-faq">
                    <summary>
                      <span>{faq.question}</span>
                    </summary>

                    <div class="parents-faq__answer">
                      <p>{faq.answer}</p>
                    </div>
                  </details>
                ))
              }
            </div>
          </section>

          <section
            id="partnership-with-families"
            class="parents-card
              parents-card--blue"
            aria-labelledby="partnership-title"
          >
            <div class="parents-card__grid">
              <div class="parents-card__main">
                <header class="parents-card__heading">
                  <span class="parents-card__number" aria-hidden="true">
                    08
                  </span>

                  <div>
                    <p class="parents-card__label">{parentsPage.partnershipLabel}</p>

                    <h2 id="partnership-title">
                      {parentsPage.partnershipHeading}
                    </h2>
                  </div>
                </header>
              </div>

              <div class="parents-card__prose">
                <PortableContent value={parentsPage.partnershipParagraphs} />
              </div>
            </div>
          </section>

          <section
            id="settling-in"
            class="parents-card
              parents-card--green
              parents-card--settling"
            aria-labelledby="settling-title"
          >
            <div class="parents-card__main">
              <header class="parents-card__heading">
                <span class="parents-card__number" aria-hidden="true">
                  09
                </span>

                <div>
                  <p class="parents-card__label">{parentsPage.settlingInLabel}</p>

                  <h2 id="settling-title">
                    {parentsPage.settlingInHeading}
                  </h2>
                </div>
              </header>

              <div class="parents-card__prose">
                <PortableContent value={parentsPage.settlingInParagraphs} />
              </div>
            </div>

            <div class="parents-settling-grid">
              <article class="parents-settling-panel">
                <h3>Partnership From the First Day</h3>

                <p>
                  {parentsPage.partnershipText}
                </p>
              </article>

              <article class="parents-settling-panel">
                <h3>Tailored Transition Strategies</h3>

                <p>
                  Every child settles in differently. We use flexible strategies
                  that are agreed with families and shaped around the child’s
                  readiness.
                </p>

                <ul class="parents-check-list">
                  {settlingStrategies.map((item: string) => <li>{item}</li>)}
                </ul>
              </article>
            </div>
          </section>

          <section
            id="policies"
            class="parents-card
    parents-card--blue
    parents-card--policies"
            aria-labelledby="policies-title"
          >
            <div class="parents-card__main parents-card__main--policies">
              <header class="parents-card__heading">
                <span class="parents-card__number" aria-hidden="true">
                  10
                </span>

                <div>
                  <p class="parents-card__label">Policies</p>

                  <h2 id="policies-title">{parentsPage.policiesHeading}</h2>
                </div>
              </header>

              <div class="parents-card__prose">
                <PortableContent value={parentsPage.policiesIntro} />
              </div>
            </div>

             <nav
              class="parents-policy-links"
              aria-label="Download nursery policies"
            >
              {
                policyDocuments.map((doc) => safeExternalUrl(doc.fileUrl) ? (
                  <a href={safeExternalUrl(doc.fileUrl)} target="_blank" rel="noreferrer" class="parents-policy-link">
                    <span class="parents-policy-links__title">{doc.title}</span>
                    {doc.shortDescription && <span class="parents-policy-links__desc">{doc.shortDescription}</span>}
                    <span class="parents-policy-links__meta">
                      <span class="parents-policy-links__action">Download PDF</span>
                      {doc.lastReviewed && <span class="parents-policy-links__reviewed">Reviewed: {doc.lastReviewed}</span>}
                    </span>
                  </a>
                ) : null)
              }
            </nav>
          </section>
        </div>
      </Container>
    </div>
  </article>
</BaseLayout>
