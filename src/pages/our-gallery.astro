---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import SanityImage from "../components/media/SanityImage.astro";
import { getGalleryPage, getGalleryPhotos, getBusinessDetails } from "../utils/sanity";
import type { SeoConfig } from "../lib/seo/types";
import "./our-gallery.css";

const galleryPage = await getGalleryPage();
const allPhotos = await getGalleryPhotos();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Childcare Setting Photo Gallery | Little Wise Kids Easton",
  description: "View our indoor and outdoor learning environments in Easton, Bristol BS5. See how our setting supports child-led discovery and multilingual play.",
  canonicalPath: "/our-gallery",
};

const categoryMeta: Record<string, { title: string; icon: string; tone: string }> = {
  "outdoor-learning-experience": { title: "Outdoor Learning Experience", icon: "star", tone: "green" },
  "indoor-learning-experience": { title: "Indoor Learning Experience", icon: "book", tone: "blue" },
  "language-immersion": { title: "Language Immersion", icon: "chat", tone: "purple" },
  "nutrition-and-mealtimes": { title: "Nutrition and Mealtimes", icon: "heart", tone: "yellow" },
  "creative-play": { title: "Creative Play", icon: "palette", tone: "purple" },
  "sensory-exploration": { title: "Sensory Exploration", icon: "star", tone: "yellow" },
  "nature-and-gardening": { title: "Nature and Gardening", icon: "heart", tone: "green" },
  "celebrations-and-community": { title: "Celebrations and Community", icon: "person", tone: "blue" },
};

const categories = allPhotos.reduce((acc, photo) => {
  const cat = photo.category ?? "other";
  if (!acc[cat]) {
    acc[cat] = { photos: [], meta: categoryMeta[cat] ?? { title: cat, icon: "image", tone: "purple" } };
  }
  acc[cat].photos.push(photo);
  return acc;
}, {} as Record<string, { photos: typeof allPhotos; meta: { title: string; icon: string; tone: string } }>);

const categoryEntries = Object.entries(categories);
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="gallery-page">
    <SubpageHero 
      id="gallery-page-title" 
      eyebrow={galleryPage.heroEyebrow ?? "Our Gallery"} 
      tone="blue"
      titleLineOne={galleryPage.heroTitleLineOne}
      titleLineTwo={galleryPage.heroTitleLineTwo}
    >
      <PortableContent value={galleryPage.heroParagraphs} />
    </SubpageHero>

    <div class="gallery-page__content">
      <Container size="wide">
        <section
          class="gallery-page__main"
          aria-labelledby="explore-gallery-title"
        >
          <header class="gallery-page__heading">
            <p class="gallery-page__label">{galleryPage.galleryIntroLabel}</p>

            <h2 id="explore-gallery-title">{galleryPage.galleryIntroHeading}</h2>

            <PortableContent value={galleryPage.galleryIntroCopy} />
          </header>

          {categoryEntries.length > 0 && (
            <nav
              class="gallery-categories"
              aria-label="Browse gallery categories"
            >
              {
                categoryEntries.map(([id, { meta }]) => (
                  <a
                    class={`gallery-category gallery-category--${meta.tone}`}
                    href={`#${id}`}
                  >
                    <span class="gallery-category__icon" aria-hidden="true">
                      <Icon name={meta.icon as import("../components/icons/types").IconName} size={23} />
                    </span>

                    <span>{meta.title}</span>
                  </a>
                ))
              }
            </nav>
          )}

          <div class="gallery-grid">
            {
              categoryEntries.map(([id, { photos, meta }]) => (
                <section id={id} class="gallery-category-section" aria-labelledby={`${id}-heading`}>
                  <h3 id={`${id}-heading`} class="sr-only">{meta.title}</h3>
                  {photos.map((photo) => (
                    <figure class={`gallery-card gallery-card--${meta.tone}`}>
                      <div class="gallery-card__media">
                        <SanityImage
                          image={photo.image}
                          alt={photo.image.altText ?? ""}
                          widths={[320, 480, 640, 900]}
                          sizes="(min-width: 72rem) 280px, (min-width: 48rem) 33vw, 100vw"
                          layout="constrained"
                        />
                      </div>

                      <figcaption>
                        <span class="gallery-card__caption-icon" aria-hidden="true">
                          <Icon name={meta.icon as import("../components/icons/types").IconName} size={19} />
                        </span>

                        <span>{meta.title}</span>
                      </figcaption>
                    </figure>
                  ))}
                </section>
              ))
            }
          </div>
        </section>
      </Container>
    </div>
  </article>
</BaseLayout>
