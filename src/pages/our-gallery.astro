---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import SanityImage from "../components/media/SanityImage.astro";
import { getGalleryPage, getGalleryPhotos, getBusinessDetails } from "../utils/sanity";
import type { SeoConfig } from "../lib/seo/types";
import "./our-gallery.css";

const galleryPage = await getGalleryPage();
const allPhotos = await getGalleryPhotos();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Childcare Setting Photo Gallery | Little Wise Kids Easton",
  description: "View our indoor and outdoor learning environments in Easton, Bristol BS5. See how our setting supports child-led discovery and multilingual play.",
  canonicalPath: "/our-gallery",
};

const categoryMeta: Record<string, { title: string; icon: string; tone: string }> = {
  "outdoor-learning-experience": { title: "Outdoor Learning Experience", icon: "star", tone: "green" },
  "indoor-learning-experience": { title: "Indoor Learning Experience", icon: "book", tone: "blue" },
  "language-immersion": { title: "Language Immersion", icon: "chat", tone: "purple" },
  "nutrition-and-mealtimes": { title: "Nutrition and Mealtimes", icon: "heart", tone: "yellow" },
  "creative-play": { title: "Creative Play", icon: "palette", tone: "purple" },
  "sensory-exploration": { title: "Sensory Exploration", icon: "star", tone: "yellow" },
  "nature-and-gardening": { title: "Nature and Gardening", icon: "heart", tone: "green" },
  "celebrations-and-community": { title: "Celebrations and Community", icon: "person", tone: "blue" },
};

const categories = allPhotos.reduce((acc, photo) => {
  const cat = photo.category ?? "other";
  if (!acc[cat]) {
    acc[cat] = { photos: [], meta: categoryMeta[cat] ?? { title: cat, icon: "image", tone: "purple" } };
  }
  acc[cat].photos.push(photo);
  return acc;
}, {} as Record<string, { photos: typeof allPhotos; meta: { title: string; icon: string; tone: string } }>);

const categoryEntries = Object.entries(categories);
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="gallery-page">
    <SubpageHero 
      id="gallery-page-title" 
      eyebrow={galleryPage.heroEyebrow ?? "Our Gallery"} 
      tone="blue"
      titleLineOne={galleryPage.heroTitleLineOne}
      titleLineTwo={galleryPage.heroTitleLineTwo}
    >
      <PortableContent value={galleryPage.heroParagraphs} />
    </SubpageHero>

    <div class="gallery-page__content">
      <Container size="wide">
        <section
          class="gallery-page__main"
          aria-labelledby="explore-gallery-title"
        >
          <header class="gallery-page__heading">
            <p class="gallery-page__label">{galleryPage.galleryIntroLabel}</p>

            <h2 id="explore-gallery-title">{galleryPage.galleryIntroHeading}</h2>

            <PortableContent value={galleryPage.galleryIntroCopy} />
          </header>

          {categoryEntries.length > 0 && (
            <nav
              class="gallery-categories"
              aria-label="Browse gallery categories"
            >
              {
                categoryEntries.map(([id, { meta }]) => (
                  <a
                    class={`gallery-category gallery-category--${meta.tone}`}
                    href={`#${id}`}
                  >
                    <span class="gallery-category__icon" aria-hidden="true">
                      <Icon name={meta.icon as import("../components/icons/types").IconName} size={23} />
                    </span>

                    <span>{meta.title}</span>
                  </a>
                ))
              }
            </nav>
          )}

          <div class="gallery-grid">
            {
              categoryEntries.map(([id, { photos, meta }]) => (
                <section id={id} class="gallery-category-section" aria-labelledby={`${id}-heading`}>
                  <h3 id={`${id}-heading`} class="sr-only">{meta.title}</h3>
                  {photos.map((photo, index) => {
                    const globalIndex = id + "-" + index;
                    return (
                    <figure 
                      class={`gallery-card gallery-card--${meta.tone}`}
                      id={`gallery-card-${globalIndex}`}
                      data-lightbox-trigger
                      data-index={globalIndex}
                      tabindex="0"
                      role="button"
                      aria-label={`View ${meta.title} photo full screen`}
                    >
                      <div class="gallery-card__media">
                        <SanityImage
                          image={photo.image}
                          alt={photo.image.altText ?? ""}
                          widths={[320, 480, 640, 900]}
                          sizes="(min-width: 72rem) 280px, (min-width: 48rem) 33vw, 100vw"
                          layout="constrained"
                        />
                      </div>

                      <figcaption>
                        <span class="gallery-card__caption-icon" aria-hidden="true">
                          <Icon name={meta.icon as import("../components/icons/types").IconName} size={19} />
                        </span>

                        <span>{meta.title}</span>
                      </figcaption>
                    </figure>
                  )})}
                </section>
              ))
            }
          </div>
        </section>
      </Container>
    </div>
  </article>

  <!-- Lightbox Dialog -->
  <div id="gallery-lightbox" class="gallery-lightbox" role="dialog" aria-labelledby="lightbox-title" aria-modal="true" style="display: none;">
    <div class="gallery-lightbox__content" id="gallery-lightbox-content">
      <h2 id="lightbox-title" class="sr-only">Image Lightbox</h2>
      <button class="gallery-lightbox__close" aria-label="Close lightbox">
        <Icon name="close" size={24} />
      </button>
      
      <div class="gallery-lightbox__media" id="gallery-lightbox-media">
        <!-- Image will be injected here -->
      </div>
      
      <div class="gallery-lightbox__caption" id="gallery-lightbox-caption">
        <!-- Caption will be injected here -->
      </div>
      
      <div class="gallery-lightbox__controls">
        <button class="gallery-lightbox__arrow gallery-lightbox__arrow--prev" aria-label="Previous image">
          <Icon name="arrowRight" size={24} />
        </button>
        <button class="gallery-lightbox__arrow gallery-lightbox__arrow--next" aria-label="Next image">
          <Icon name="arrowRight" size={24} />
        </button>
      </div>
    </div>
  </div>

  <script>
    const dialog = document.getElementById('gallery-lightbox') as HTMLDivElement;
    
    // Move dialog to body to escape <main>'s stacking context (which causes the header to overlap)
    if (dialog && dialog.parentElement !== document.body) {
      document.body.appendChild(dialog);
    }

    const mediaContainer = document.getElementById('gallery-lightbox-media');
    const captionContainer = document.getElementById('gallery-lightbox-caption');
    const lightboxContent = document.getElementById('gallery-lightbox-content');
    const closeBtn = document.querySelector('.gallery-lightbox__close');
    const prevBtn = document.querySelector('.gallery-lightbox__arrow--prev');
    const nextBtn = document.querySelector('.gallery-lightbox__arrow--next');
    
    // Convert NodeList to Array for easy navigation
    const triggers = Array.from(document.querySelectorAll('[data-lightbox-trigger]')) as HTMLElement[];
    let currentIndex = 0;

    const controlsContainer = document.querySelector('.gallery-lightbox__controls') as HTMLElement | null;
    if (triggers.length <= 1 && controlsContainer) {
      controlsContainer.style.display = 'none';
    }

    const updateDialogContent = (trigger: HTMLElement) => {
      if (!mediaContainer || !captionContainer) return;
      
      // Clone image
      const img = trigger.querySelector('img');
      if (img) {
        const clonedImg = img.cloneNode(true) as HTMLImageElement;
        // remove any view-transition-name from the cloned image so it doesn't conflict
        clonedImg.style.viewTransitionName = 'none';
        
        // Ensure image transitions smoothly
        clonedImg.style.opacity = '0';
        clonedImg.style.transition = 'opacity 0.2s ease';
        
        mediaContainer.innerHTML = '';
        mediaContainer.appendChild(clonedImg);
        
        // Trigger reflow to animate opacity
        requestAnimationFrame(() => {
          clonedImg.style.opacity = '1';
        });
      }
      
      // Clone caption
      const caption = trigger.querySelector('figcaption');
      if (caption) {
        captionContainer.innerHTML = caption.innerHTML;
      }
    };

    const openLightbox = (index: number) => {
      if (!dialog || !mediaContainer) return;
      
      currentIndex = index;
      const trigger = triggers[currentIndex];
      
      // Step 1: Set transition name on trigger before starting view transition
      triggers.forEach(t => t.style.viewTransitionName = 'none');
      trigger.style.viewTransitionName = 'gallery-active-image';
      mediaContainer.style.viewTransitionName = 'none';
      
      const doOpen = () => {
        updateDialogContent(trigger);
        // Step 2: Swap transition name to mediaContainer inside callback
        trigger.style.viewTransitionName = 'none';
        mediaContainer.style.viewTransitionName = 'gallery-active-image';
        dialog.style.display = 'flex';
        document.body.style.overflow = 'hidden'; // Prevent background scrolling
      };

      if (document.startViewTransition) {
        const vt = document.startViewTransition(() => {
          doOpen();
        });
        vt.finished.then(() => {
          mediaContainer.style.viewTransitionName = 'none';
        });
      } else {
        doOpen();
      }
    };

    const closeLightbox = () => {
      if (!dialog || !mediaContainer) return;
      
      const trigger = triggers[currentIndex];

      // Step 1: Set transition name on mediaContainer before starting view transition
      triggers.forEach(t => t.style.viewTransitionName = 'none');
      mediaContainer.style.viewTransitionName = 'gallery-active-image';
      trigger.style.viewTransitionName = 'none';

      const doClose = () => {
        // Step 2: Swap transition name to trigger inside callback
        mediaContainer.style.viewTransitionName = 'none';
        trigger.style.viewTransitionName = 'gallery-active-image';
        dialog.style.display = 'none';
        document.body.style.overflow = '';
      };

      if (document.startViewTransition) {
        const vt = document.startViewTransition(() => {
          doClose();
        });
        vt.finished.then(() => {
          trigger.style.viewTransitionName = 'none';
        });
      } else {
        doClose();
      }
    };

    const navigate = (direction: 1 | -1) => {
      if (!dialog || !lightboxContent) return;
      
      const oldTrigger = triggers[currentIndex];
      const oldVtName = `gallery-img-${oldTrigger.dataset.index}`;
      
      let newIndex = currentIndex + direction;
      if (newIndex < 0) newIndex = triggers.length - 1;
      if (newIndex >= triggers.length) newIndex = 0;
      
      const newTrigger = triggers[newIndex];
      const newVtName = `gallery-img-${newTrigger.dataset.index}`;

      // Immediately swap content without view transitions to avoid cross-page flying animations
      currentIndex = newIndex;
      updateDialogContent(newTrigger);
    };

    // Event Listeners
    triggers.forEach((trigger, index) => {
      trigger.addEventListener('click', () => openLightbox(index));
      trigger.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openLightbox(index);
        }
      });
    });

    closeBtn?.addEventListener('click', () => closeLightbox());
    
    // Close on backdrop click
    dialog?.addEventListener('click', (e) => {
      if (e.target === dialog) {
        closeLightbox();
      }
    });

    prevBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(-1);
    });

    nextBtn?.addEventListener('click', (e) => {
      e.stopPropagation();
      navigate(1);
    });

    document.addEventListener('keydown', (e) => {
      if (dialog.style.display !== 'flex') return;
      
      if (e.key === 'Escape') {
        closeLightbox();
      } else if (e.key === 'ArrowLeft') {
        navigate(-1);
      } else if (e.key === 'ArrowRight') {
        navigate(1);
      }
    });
  </script>
</BaseLayout>
