---
export const prerender = true;
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getHoursNutritionPage, getBusinessDetails } from "../utils/sanity";
import { formatTimeRange, getAgeRangeDisplay } from "../lib/formatters";
import type { SeoConfig } from "../lib/seo/types";
import "./hours-nutrition.css";

const hoursNutritionPage = await getHoursNutritionPage();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Opening Hours & Nutrition in Easton | Little Wise Kids",
  description: `Operating from ${businessDetails.openingTime} to ${businessDetails.closingTime}, we offer flexible childcare in Easton with wholesome, home-cooked meals accommodating various dietary needs.`,
  canonicalPath: "/hours-nutrition",
};

const sessionDetails = [
  {
    icon: "clock",
    label: "Days",
    value: businessDetails.openingDays,
  },
  {
    icon: "calendar",
    label: "Full day",
    value: formatTimeRange(businessDetails.openingTime, businessDetails.closingTime),
  },
  {
    icon: "clock",
    label: "Half day",
    value: formatTimeRange(businessDetails.openingTime, businessDetails.morningSessionEnd),
  },
  {
    icon: "heart",
    label: "Age range",
    value: getAgeRangeDisplay(businessDetails),
  },
] as const;

const dailyRhythm = [
  {
    icon: "star",
    time: formatTimeRange(hoursNutritionPage.welcomeAndFreePlay.startTime, hoursNutritionPage.welcomeAndFreePlay.endTime),
    title: hoursNutritionPage.welcomeAndFreePlay.title,
    copy: hoursNutritionPage.welcomeAndFreePlay.description,
  },
  {
    icon: "book",
    time: formatTimeRange(hoursNutritionPage.learningAndExploration.startTime, hoursNutritionPage.learningAndExploration.endTime),
    title: hoursNutritionPage.learningAndExploration.title,
    copy: hoursNutritionPage.learningAndExploration.description,
  },
  {
    icon: "heart",
    time: formatTimeRange(hoursNutritionPage.morningSnack.startTime, hoursNutritionPage.morningSnack.endTime),
    title: hoursNutritionPage.morningSnack.title,
    copy: hoursNutritionPage.morningSnack.description,
  },
  {
    icon: "star",
    time: formatTimeRange(hoursNutritionPage.outdoorAdventures.startTime, hoursNutritionPage.outdoorAdventures.endTime),
    title: hoursNutritionPage.outdoorAdventures.title,
    copy: hoursNutritionPage.outdoorAdventures.description,
  },
  {
    icon: "heart",
    time: formatTimeRange(hoursNutritionPage.lunch.startTime, hoursNutritionPage.lunch.endTime),
    title: hoursNutritionPage.lunch.title,
    copy: hoursNutritionPage.lunch.description,
  },
  {
    icon: "clock",
    time: formatTimeRange(hoursNutritionPage.restAndQuietTime.startTime, hoursNutritionPage.restAndQuietTime.endTime),
    title: hoursNutritionPage.restAndQuietTime.title,
    copy: hoursNutritionPage.restAndQuietTime.description,
  },
  {
    icon: "star",
    time: formatTimeRange(hoursNutritionPage.afternoonPlayAndHome.startTime, hoursNutritionPage.afternoonPlayAndHome.endTime),
    title: hoursNutritionPage.afternoonPlayAndHome.title,
    copy: hoursNutritionPage.afternoonPlayAndHome.description,
  },
] as const;
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="hours-page">
    <SubpageHero
      id="hours-page-title"
      eyebrow={hoursNutritionPage.heroEyebrow}
      tone="green"
      titleLineOne={hoursNutritionPage.heroTitleLineOne}
      titleLineTwo={hoursNutritionPage.heroTitleLineTwo}
    >

      <PortableContent value={hoursNutritionPage.heroParagraphs} />
    </SubpageHero>

    <div class="hours-page__content">
      <Container size="wide">
        <div class="hours-page__stack">
          <section
            id="operating-hours"
            class="hours-card
              hours-card--green"
            aria-labelledby="operating-hours-title"
          >
            <div class="hours-card__split">
              <div class="hours-card__main">
                <header class="hours-card__heading">
                  <span class="hours-card__number" aria-hidden="true">
                    01
                  </span>

                  <div>
                    <h2 id="operating-hours-title">
                      {hoursNutritionPage.operatingHoursHeading}
                    </h2>
                  </div>
                </header>

                <div class="hours-card__prose">
                  <PortableContent value={hoursNutritionPage.operatingHoursParagraphs} />

                  <h3>Flexible Sessions</h3>
                  <p>We offer both full-day and half-day sessions to suit your family’s routine. While we recommend a minimum attendance to help children settle and build relationships, we are happy to discuss flexible arrangements.</p>

                  <h3>Holidays & Closures</h3>
                  <p>We are open year-round, closing only for Bank Holidays and for a short period between Christmas and New Year. Exact closure dates are shared with parents well in advance.</p>
                </div>
              </div>

              <dl class="hours-schedule">
                {
                  sessionDetails.map((detail) => (
                    <div class="hours-schedule__row">
                      <span class="hours-schedule__icon" aria-hidden="true">
                        <Icon name={detail.icon} size={25} />
                      </span>

                      <dt>{detail.label}</dt>
                      <dd>{detail.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>

            <aside class="hours-card__note" aria-labelledby="min-attendance-title">
              <span class="hours-card__note-icon" aria-hidden="true">
                <Icon name="heart" size={30} />
              </span>

              <div class="hours-card__note-copy">
                <h3 id="min-attendance-title">{hoursNutritionPage.minAttendancePanelTitle}</h3>

                <p>
                  {hoursNutritionPage.minAttendancePanelCopy}
                </p>
              </div>

              <a class="hours-card__note-link" href="/contact#contact-form">
                Contact Us About Availability
                <span aria-hidden="true">→</span>
              </a>
            </aside>
          </section>

          <section
            id="nutrition"
            class="hours-card
              hours-card--purple"
            aria-labelledby="nutrition-title"
          >


            <div class="hours-card__split">
              <div class="hours-card__main">
                <header class="hours-card__heading">
                  <span class="hours-card__number" aria-hidden="true">
                    02
                  </span>

                  <div>
                    <h2 id="nutrition-title">
                      {hoursNutritionPage.nutritionHeading}
                    </h2>
                  </div>
                </header>

                <div class="hours-card__prose">
                  <PortableContent value={hoursNutritionPage.nutritionParagraphs} />

                  <h3>Allergies & Dietary Requirements</h3>
                  <p>We take dietary requirements very seriously. All meals are prepared in a dedicated, clean environment, and we work closely with parents to ensure all allergies and intolerances are safely accommodated.</p>

                  <h3>Sample Menu</h3>
                  <p>Our home-cooked meals vary daily. A typical day might include porridge or fresh fruit for breakfast, a hot lunch like mild vegetable curry with rice, and a healthy afternoon snack such as hummus with carrot sticks.</p>
                </div>
              </div>

              <aside class="nutrition-checklist" aria-labelledby="nutrition-checklist-title">
                <h3 id="nutrition-checklist-title">What We Provide</h3>

                <ul>
                  {
                    hoursNutritionPage.nutritionChecklist.map((point: string) => (
                      <li>
                        <span aria-hidden="true">✓</span>
                        <p>{point}</p>
                      </li>
                    ))
                  }
                </ul>
              </aside>
            </div>

            <div
              class="hours-card__prose fresh-food-block"
            >
              <h3 class="fresh-food-title">
                {hoursNutritionPage.freshlyPreparedHeading}
              </h3>
              <p>
                {hoursNutritionPage.chefNote}
              </p>
            </div>
          </section>

          <section
            id="typical-day"
            class="hours-card
              hours-card--blue
              hours-day"
            aria-labelledby="typical-day-title"
          >
            <header class="hours-day__header">
              <span class="hours-day__header-icon" aria-hidden="true">
                <Icon name="clock" size={30} />
              </span>

              <div>
                <h2 id="typical-day-title">{hoursNutritionPage.typicalDayHeading}</h2>

                <p class="hours-day__lead">
                  {hoursNutritionPage.typicalDayLead}
                </p>
              </div>
            </header>

            <ol
              class="hours-day__timeline"
              aria-label="Example daily childcare schedule"
            >
              {
                dailyRhythm.map((event) => (
                  <li class="hours-day__item">
                    <article class="hours-day__event">
                      <p class="hours-day__time">{event.time}</p>

                      <h3>{event.title}</h3>

                      <p>{event.copy}</p>
                    </article>

                    <span class="hours-day__marker" aria-hidden="true">
                      <Icon name={event.icon} size={25} />
                    </span>
                  </li>
                ))
              }
            </ol>
          </section>
        </div>
      </Container>
    </div>
  </article>
</BaseLayout>
