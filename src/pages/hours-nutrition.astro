---
export const prerender = true;

import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getHoursNutritionPage, getBusinessDetails } from "../lib/queries";
import { formatTimeRange } from "../lib/formatters";
import "./hours-nutrition.css";

// Green section icons
import calendarIcon from "../assets/icons/hours-nutrition/calendar.png";
import fullDaySunIcon from "../assets/icons/hours-nutrition/full-day-sun.png";
import halfDaySunriseIcon from "../assets/icons/hours-nutrition/half-day-sunrise.png";
import attendanceHeartIcon from "../assets/icons/hours-nutrition/attendance-heart.png";

// Purple section icons
import wellbeingHeartIcon from "../assets/icons/hours-nutrition/wellbeing-heart.png";
import energyLightningIcon from "../assets/icons/hours-nutrition/energy-lightning.png";
import mealtimeSmileIcon from "../assets/icons/hours-nutrition/mealtime-smile.png";
import wholesomeLeafIcon from "../assets/icons/hours-nutrition/wholesome-leaf.png";
import socialGroupIcon from "../assets/icons/hours-nutrition/social-group.png";

// Yellow section icons
import tryTastesBowlIcon from "../assets/icons/hours-nutrition/try-tastes-bowl.png";
import developIndependenceIcon from "../assets/icons/hours-nutrition/develop-independence.png";
import positiveSocialMomentsIcon from "../assets/icons/hours-nutrition/positive-social-moments.png";
import dietaryInformationIcon from "../assets/icons/hours-nutrition/dietary-information.png";

// Blue typical day icons
import welcomeStarIcon from "../assets/icons/hours-nutrition/welcome-star.png";
import learningBookIcon from "../assets/icons/hours-nutrition/learning-book.png";
import snackAppleIcon from "../assets/icons/hours-nutrition/snack-apple.png";
import outdoorsTreeIcon from "../assets/icons/hours-nutrition/outdoors-tree.png";
import lunchCutleryIcon from "../assets/icons/hours-nutrition/lunch-cutlery.png";
import restMoonIcon from "../assets/icons/hours-nutrition/rest-moon.png";
import playBallIcon from "../assets/icons/hours-nutrition/play-ball.png";

const hoursNutritionPage = await getHoursNutritionPage();
const businessDetails = await getBusinessDetails();

const sessionDetails = [
  {
    icon: calendarIcon,
    label: "Days",
    value: businessDetails.openingDays,
  },
  {
    icon: fullDaySunIcon,
    label: "Full day",
    value: formatTimeRange(
      businessDetails.openingTime,
      businessDetails.closingTime,
    ),
  },
  {
    icon: halfDaySunriseIcon,
    label: "Half day",
    value: formatTimeRange(
      businessDetails.openingTime,
      businessDetails.morningSessionEnd,
    ),
  },
] as const;

const nutritionHighlights = [
  {
    icon: wellbeingHeartIcon,
    title: "Wellbeing",
    text: "Food that supports growing bodies and minds.",
  },
  {
    icon: energyLightningIcon,
    title: "Energy",
    text: "Nutritious meals to keep children energised.",
  },
  {
    icon: mealtimeSmileIcon,
    title: "Enjoyment of mealtimes",
    text: "Delicious meals in a calm, positive environment.",
  },
  {
    icon: wholesomeLeafIcon,
    title: "Varied and wholesome diet",
    text: "Freshly prepared with a balance of key nutrients.",
  },
  {
    icon: socialGroupIcon,
    title: "Social time with friends",
    text: "Sharing meals and building friendships.",
  },
];

const chefHighlights = [
  {
    icon: tryTastesBowlIcon,
    title: "Try new tastes",
    text: "A chance to explore different flavours and textures.",
  },
  {
    icon: developIndependenceIcon,
    title: "Develop independence",
    text: "Encouraging children to make choices and build confidence.",
  },
  {
    icon: positiveSocialMomentsIcon,
    title: "Enjoy positive social moments",
    text: "Mealtimes are a time to connect, chat and share with friends.",
  },
];

const dailyRhythm = [
  {
    icon: welcomeStarIcon,
    time: formatTimeRange(
      hoursNutritionPage.welcomeAndFreePlay.startTime,
      hoursNutritionPage.welcomeAndFreePlay.endTime,
    ),
    title: hoursNutritionPage.welcomeAndFreePlay.title,
    copy: hoursNutritionPage.welcomeAndFreePlay.description,
  },
  {
    icon: learningBookIcon,
    time: formatTimeRange(
      hoursNutritionPage.learningAndExploration.startTime,
      hoursNutritionPage.learningAndExploration.endTime,
    ),
    title: hoursNutritionPage.learningAndExploration.title,
    copy: hoursNutritionPage.learningAndExploration.description,
  },
  {
    icon: snackAppleIcon,
    time: formatTimeRange(
      hoursNutritionPage.morningSnack.startTime,
      hoursNutritionPage.morningSnack.endTime,
    ),
    title: hoursNutritionPage.morningSnack.title,
    copy: hoursNutritionPage.morningSnack.description,
  },
  {
    icon: outdoorsTreeIcon,
    time: formatTimeRange(
      hoursNutritionPage.outdoorAdventures.startTime,
      hoursNutritionPage.outdoorAdventures.endTime,
    ),
    title: hoursNutritionPage.outdoorAdventures.title,
    copy: hoursNutritionPage.outdoorAdventures.description,
  },
  {
    icon: lunchCutleryIcon,
    time: formatTimeRange(
      hoursNutritionPage.lunch.startTime,
      hoursNutritionPage.lunch.endTime,
    ),
    title: hoursNutritionPage.lunch.title,
    copy: hoursNutritionPage.lunch.description,
  },
  {
    icon: restMoonIcon,
    time: formatTimeRange(
      hoursNutritionPage.restAndQuietTime.startTime,
      hoursNutritionPage.restAndQuietTime.endTime,
    ),
    title: hoursNutritionPage.restAndQuietTime.title,
    copy: hoursNutritionPage.restAndQuietTime.description,
  },
  {
    icon: playBallIcon,
    time: formatTimeRange(
      hoursNutritionPage.afternoonPlayAndHome.startTime,
      hoursNutritionPage.afternoonPlayAndHome.endTime,
    ),
    title: hoursNutritionPage.afternoonPlayAndHome.title,
    copy: hoursNutritionPage.afternoonPlayAndHome.description,
  },
] as const;
---

<BaseLayout
  seo={{
    title: "Opening Hours & Nutrition in Easton | Little Wise Kids",
    description: `Little Wise Kids is open ${businessDetails.openingDays}, with full-day and half-day childcare sessions and nutritious meals prepared with children’s needs in mind.`,
    canonicalPath: "/hours-nutrition",
  }}
  businessDetails={businessDetails}
>
  <article class="hours-page">
    <SubpageHero
      id="hours-page-title"
      eyebrow={hoursNutritionPage.heroEyebrow}
      tone="green"
      titleLineOne={hoursNutritionPage.heroTitleLineOne}
      titleLineTwo={hoursNutritionPage.heroTitleLineTwo}
    >
      <PortableContent value={hoursNutritionPage.heroParagraphs} />
    </SubpageHero>

    <div class="hours-page__content">
      <Container size="wide">
        <div class="hours-page__stack">
          <section
            id="operating-hours"
            class="hours-section hours-section--green"
            aria-labelledby="operating-hours-title"
          >
            <div class="hours-section__layout">
              <div class="hours-section__intro">
                <header class="hours-section__heading">
                  <span class="hours-section__number" aria-hidden="true"
                    >01</span
                  >

                  <div>
                    <p class="hours-section__eyebrow">
                      {hoursNutritionPage.operatingHoursLabel}
                    </p>

                    <h2 id="operating-hours-title">
                      {hoursNutritionPage.operatingHoursHeading}
                    </h2>
                  </div>
                </header>

                <div class="hours-section__prose">
                  <PortableContent
                    value={hoursNutritionPage.operatingHoursParagraphs}
                  />
                </div>
              </div>

              <dl class="session-list">
                {
                  sessionDetails.map((detail) => (
                    <div class="session-list__row">
                      <span class="session-list__icon" aria-hidden="true">
                        <Image
                          src={detail.icon}
                          alt=""
                          width={48}
                          height={48}
                          decoding="async"
                        />
                      </span>

                      <dt>{detail.label}</dt>
                      <dd>{detail.value}</dd>
                    </div>
                  ))
                }
              </dl>
            </div>

            <aside
              class="attendance-strip"
              aria-labelledby="minimum-attendance-title"
            >
              <span class="attendance-strip__icon" aria-hidden="true">
                <Image
                  src={attendanceHeartIcon}
                  alt=""
                  width={56}
                  height={56}
                  decoding="async"
                />
              </span>

              <div class="attendance-strip__copy">
                <h3 id="minimum-attendance-title">
                  {hoursNutritionPage.minAttendancePanelTitle}
                </h3>

                <p>{hoursNutritionPage.minAttendancePanelCopy}</p>
              </div>

              <a class="attendance-strip__link" href="/contact#contact-form">
                {hoursNutritionPage.availabilityCtaLabel}
                <span aria-hidden="true">→</span>
              </a>
            </aside>
          </section>

          <section
            id="nutrition"
            class="hours-section hours-section--purple nutrition-section"
            aria-labelledby="nutrition-title"
          >
            <div class="nutrition-section__layout">
              <div class="nutrition-section__copy">
                <header class="hours-section__heading">
                  <span class="hours-section__number" aria-hidden="true"
                    >02</span
                  >

                  <div>
                    <p class="hours-section__eyebrow">
                      {hoursNutritionPage.nutritionLabel}
                    </p>

                    <h2 id="nutrition-title" class="nutrition-section__heading">
                      Thriving minds start with <span>nourished bodies.</span>
                    </h2>
                  </div>
                </header>

                <div class="hours-section__prose">
                  <PortableContent
                    value={hoursNutritionPage.nutritionParagraphs}
                  />
                </div>
              </div>

              <ul
                class="nutrition-path"
                aria-label="How food supports children at Little Wise Kids"
              >
                {
                  nutritionHighlights.map((item) => (
                    <li>
                      <span class="nutrition-path__icon" aria-hidden="true">
                        <Image
                          src={item.icon}
                          alt=""
                          width={48}
                          height={48}
                          decoding="async"
                        />
                      </span>

                      <div class="nutrition-path__content">
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                      </div>
                    </li>
                  ))
                }
              </ul>
            </div>
          </section>

          <section
            id="nursery-chef"
            class="hours-section hours-section--yellow chef-section"
            aria-labelledby="nursery-chef-title"
          >
            <div class="chef-section__layout">
              <div class="chef-section__copy">
                <header class="hours-section__heading">
                  <span class="hours-section__number" aria-hidden="true"
                    >03</span
                  >

                  <div>
                    <p class="hours-section__eyebrow">
                      {hoursNutritionPage.nurseryChefLabel}
                    </p>

                    <h2 id="nursery-chef-title">
                      {hoursNutritionPage.freshlyPreparedHeading}
                    </h2>
                  </div>
                </header>

                <div class="hours-section__prose">
                  <p>{hoursNutritionPage.chefNote}</p>
                </div>
              </div>

              <ol
                class="chef-journey"
                aria-label="Food experiences for children"
              >
                {
                  chefHighlights.map((item, index) => (
                    <li>
                      <span class="chef-journey__number" aria-hidden="true">
                        {String(index + 1).padStart(2, "0")}
                      </span>

                      <span class="chef-journey__icon-wrapper" aria-hidden="true">
                        <Image
                          class="chef-journey__icon"
                          src={item.icon}
                          alt=""
                          width={64}
                          height={64}
                          decoding="async"
                        />
                      </span>

                      <div class="chef-journey__content">
                        <h3>{item.title}</h3>
                        <p>{item.text}</p>
                      </div>
                    </li>
                  ))
                }
              </ol>
            </div>

            <aside class="dietary-note">
              <span class="dietary-note__icon" aria-hidden="true">
                <Image
                  src={dietaryInformationIcon}
                  alt=""
                  width={48}
                  height={48}
                  decoding="async"
                />
              </span>

              <p>{hoursNutritionPage.dietaryContactCopy}</p>

              <a href="/contact#contact-form">
                {hoursNutritionPage.dietaryContactCtaLabel}
                <span aria-hidden="true">→</span>
              </a>
            </aside>
          </section>

          <!--
            Existing scroll-driven timeline structure and behaviour are preserved.
            The content remains Sanity-driven through the existing fixed time slots.
          -->
          <section
            id="typical-day"
            class="hours-card hours-card--blue hours-day"
            aria-labelledby="typical-day-title"
          >
            <header class="hours-day__header">
              <span class="hours-day__header-icon" aria-hidden="true">
                <Icon name="clock" size={30} />
              </span>

              <div>
                <p class="hours-card__label">
                  {hoursNutritionPage.typicalDayLabel}
                </p>

                <h2 id="typical-day-title">
                  {hoursNutritionPage.typicalDayHeading}
                </h2>

                <p class="hours-day__lead">
                  {hoursNutritionPage.typicalDayLead}
                </p>
              </div>
            </header>

            <ol
              class="hours-day__timeline"
              aria-label="Example daily childcare schedule"
            >
              {
                dailyRhythm.map((event) => (
                  <li class="hours-day__item">
                    <article class="hours-day__event">
                      <p class="hours-day__time">{event.time}</p>

                      <h3>{event.title}</h3>

                      <p>{event.copy}</p>

                      <Image
                        src={event.icon}
                        alt=""
                        width={72}
                        height={72}
                        aria-hidden="true"
                        decoding="async"
                        class="hours-day__event-watermark"
                      />
                    </article>

                    <span class="hours-day__marker" aria-hidden="true">
                      <Image
                        src={event.icon}
                        alt=""
                        width={48}
                        height={48}
                        aria-hidden="true"
                        decoding="async"
                        class="hours-day__marker-img"
                      />
                    </span>
                  </li>
                ))
              }
            </ol>
          </section>
        </div>
      </Container>
    </div>
  </article>
</BaseLayout>
