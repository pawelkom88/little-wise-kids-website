---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import { PortableText } from "astro-portabletext";
import { getMultilingualPage, getBusinessDetails, urlFor } from "../utils/sanity";
import "./multilingual-learning.css";

const formatLanguages = (languages: readonly string[] | undefined) => {
  if (!languages || languages.length === 0) return "";
  if (languages.length === 1) return languages[0];
  return `${languages.slice(0, -1).join(", ")} and ${languages[languages.length - 1]}`;
};

const multilingualPage = await getMultilingualPage();
const businessDetails = await getBusinessDetails();

const langImage = multilingualPage.languageConnectionImage ? urlFor(multilingualPage.languageConnectionImage).width(800).height(800).url() : undefined;

const philosophyPoints = [
  {
    tone: "purple",
    text: multilingualPage.philosophyPoints[0],
  },
  {
    tone: "green",
    text: multilingualPage.philosophyPoints[1],
  },
  {
    tone: "blue",
    text: multilingualPage.philosophyPoints[2],
  },
] as const;

const eyfsAreas = [
  {
    icon: "chat",
    tone: "purple",
    title: multilingualPage.eyfsCommunication.title,
  },
  {
    icon: "person",
    tone: "green",
    title: multilingualPage.eyfsPhysical.title,
  },
  {
    icon: "heart",
    tone: "blue",
    title: multilingualPage.eyfsPersonal.title,
  },
  {
    icon: "book",
    tone: "yellow",
    title: multilingualPage.eyfsLiteracy.title,
  },
  {
    icon: "calendar",
    tone: "green",
    title: multilingualPage.eyfsMaths.title,
  },
  {
    icon: "star",
    tone: "purple",
    title: multilingualPage.eyfsUnderstanding.title,
  },
  {
    icon: "palette",
    tone: "blue",
    title: multilingualPage.eyfsArts.title,
  },
] as const;

const screenFreeBenefits = [
  {
    tone: "purple",
    text: multilingualPage.screenFreeBenefits[0],
  },
  {
    tone: "green",
    text: multilingualPage.screenFreeBenefits[1],
  },
  {
    tone: "blue",
    text: multilingualPage.screenFreeBenefits[2],
  },
  {
    tone: "yellow",
    text: multilingualPage.screenFreeBenefits[3],
  },
  {
    tone: "purple",
    text: multilingualPage.screenFreeBenefits[4],
  },
] as const;
---

<BaseLayout
  title="Multilingual Learning | Little Wise Kids"
  description="Explore the multilingual, child-led, screen-free learning philosophy at Little Wise Kids."
>
  <article class="lwk-multilingual">
    <SubpageHero
      id="multilingual-page-title"
      eyebrow={multilingualPage.heroEyebrow}
      tone="purple"
    >
      <Fragment slot="title">
        <span>{multilingualPage.heroTitleLineOne}</span>
        <span>{multilingualPage.heroTitleLineTwo}</span>
      </Fragment>

      <PortableText value={multilingualPage.heroParagraphs} />
    </SubpageHero>

    <div class="lwk-multilingual__sections">
      <section
        id="our-learning-philosophy"
        class="lwk-multilingual__section
          lwk-multilingual__section--philosophy"
        aria-labelledby="learning-philosophy-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__philosophy-card">
            <div class="lwk-multilingual__copy-block">
              <p
                class="lwk-multilingual__label
                  lwk-multilingual__label--purple"
              >
                {multilingualPage.philosophyLabel}
              </p>

              <h2 id="learning-philosophy-title">
                {multilingualPage.philosophyHeading}
              </h2>

              <div class="lwk-multilingual__prose">
                <PortableText value={multilingualPage.philosophyParagraphs} />
              </div>

              <aside class="lwk-multilingual__discovery-note">
                <span
                  class="lwk-multilingual__discovery-icon"
                  aria-hidden="true"
                >
                  <Icon name="heart" size={30} />
                </span>

                <p>
                  Every day can bring a new discovery: a word in Portuguese, an
                  insect in the garden, a new way to solve a problem or a story
                  that sparks a child’s imagination.
                </p>
              </aside>
            </div>

            <div class="lwk-multilingual__list-panel">
              <h3>{multilingualPage.childrenEnjoyHeading}</h3>

              <ul class="lwk-multilingual__check-list">
                {
                  philosophyPoints.map((point) => (
                    <li>
                      <span
                        class={`
                          lwk-multilingual__check
                          lwk-multilingual__check--${point.tone}
                        `}
                        aria-hidden="true"
                      >
                        ✓
                      </span>

                      <span>{point.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </Container>
      </section>

      <section
        id="english-and-portuguese"
        class="lwk-multilingual__section"
        aria-labelledby="languages-title"
      >
        <Container size="wide">
          <div
            class="lwk-multilingual__split-card
              lwk-multilingual__split-card--green"
          >
            <div class="lwk-multilingual__copy-block">
              <p
                class="lwk-multilingual__label
                  lwk-multilingual__label--green"
              >
                {multilingualPage.languageConnectionLabel}
              </p>

              <h2 id="languages-title">{multilingualPage.languageConnectionHeading}</h2>

              <div class="lwk-multilingual__prose">
                <PortableText value={multilingualPage.languageConnectionParagraphs} />
              </div>

              <aside class="lwk-multilingual__cms-note">
                <span class="lwk-multilingual__cms-icon" aria-hidden="true">
                  <Icon name="chat" size={24} />
                </span>

                <p>
                  <strong>CMS note:</strong>
                  {formatLanguages(businessDetails.languages)} are the current languages offered.
                  This may change and must be easy to update.
                </p>
              </aside>
            </div>

            <div
              class="lwk-multilingual__media
                lwk-multilingual__media--languages"
              aria-hidden="true"
            >
              {langImage ? (
                <img src={langImage} alt="" class="lwk-multilingual__image" />
              ) : (
                <span class="lwk-multilingual__media-placeholder">
                  <Icon name="book" size={48} />
                  <span>Language-learning image</span>
                </span>
              )}
            </div>
          </div>
        </Container>
      </section>

      <section
        id="eyfs"
        class="lwk-multilingual__section"
        aria-labelledby="eyfs-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__eyfs-card">
            <div class="lwk-multilingual__copy-block">
              <p
                class="lwk-multilingual__label
                  lwk-multilingual__label--purple"
              >
                {multilingualPage.eyfsLabel}
              </p>

              <h2 id="eyfs-title">{multilingualPage.eyfsHeading}</h2>

              <div class="lwk-multilingual__prose">
                <PortableText value={multilingualPage.eyfsParagraphs} />
              </div>
            </div>

            <ul
              class="lwk-multilingual__eyfs-grid"
              aria-label="The seven areas of the Early Years Foundation Stage"
            >
              {
                eyfsAreas.map((area) => (
                  <li>
                    <span
                      class={`
                        lwk-multilingual__area-icon
                        lwk-multilingual__area-icon--${area.tone}
                      `}
                      aria-hidden="true"
                    >
                      <Icon name={area.icon} size={28} />
                    </span>

                    <span>{area.title}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </Container>
      </section>

      <section
        id="screen-free-learning"
        class="lwk-multilingual__section
          lwk-multilingual__section--screen-free"
        aria-labelledby="screen-free-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__screen-free-card">
            <div class="lwk-multilingual__copy-block">
              <p
                class="lwk-multilingual__label
                  lwk-multilingual__label--blue"
              >
                {multilingualPage.screenFreeLabel}
              </p>

              <h2 id="screen-free-title">
                {multilingualPage.screenFreeHeading}
              </h2>

              <div class="lwk-multilingual__prose">
                <PortableText value={multilingualPage.screenFreeParagraphs} />
              </div>
            </div>

            <div class="lwk-multilingual__list-panel">
              <h3>Screen-Free Learning Supports:</h3>

              <ul class="lwk-multilingual__check-list">
                {
                  screenFreeBenefits.map((benefit) => (
                    <li>
                      <span
                        class={`
                          lwk-multilingual__check
                          lwk-multilingual__check--${benefit.tone}
                        `}
                        aria-hidden="true"
                      >
                        ✓
                      </span>

                      <span>{benefit.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>

            <aside class="lwk-multilingual__closing-note">
              <span class="lwk-multilingual__closing-icon" aria-hidden="true">
                <Icon name="heart" size={32} />
              </span>

              <p>
                {multilingualPage.closingNote}
              </p>
            </aside>
          </div>
        </Container>
      </section>
    </div>
  </article>
</BaseLayout>
