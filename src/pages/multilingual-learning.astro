---
export const prerender = true;
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import Icon from "../components/icons/Icon.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
import PortableContent from "../components/content/PortableContent.astro";
import { getMultilingualPage, getBusinessDetails } from "../utils/sanity";
import type { SeoConfig } from "../lib/seo/types";
import flowerImage from "../assets/images/flower-image.webp";
import languageConnectionImage from "../assets/images/planet-english-portuguese-words.webp";
import heroBg from "../assets/images/littlewisekids-outdoor-hero-image.webp";
import "./multilingual-learning.css";

import iconCommunication from "../assets/images/icon-communication.png";
import iconPhysical from "../assets/images/icon-physical.png";
import iconRelationships from "../assets/images/icon-relationships.png";
import iconLiteracy from "../assets/images/icon-literacy.png";
import iconMaths from "../assets/images/icon-maths.png";
import iconOutdoor from "../assets/images/icon-outdoor.png";
import iconCreativity from "../assets/images/icon-creativity.png";

const multilingualPage = await getMultilingualPage();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Multilingual Early Years Learning | Little Wise Kids",
  description:
    "Our child-led approach combines English and Portuguese exposure with screen-free play, nurturing confidence and creativity.",
  canonicalPath: "/multilingual-learning",
};

const pointTones = [
  "purple",
  "green",
  "blue",
  "yellow",
  "purple",
  "green",
] as const;

const philosophyPoints = multilingualPage.philosophyPoints.map(
  (text, index) => ({
    tone: pointTones[index % pointTones.length] ?? "purple",
    text,
  }),
);

const eyfsAreas = [
  {
    image: iconCommunication,
    tone: "purple",
    title: multilingualPage.eyfsCommunication.title,
    alt: "Communication & Language icon",
  },
  {
    image: iconPhysical,
    tone: "green",
    title: multilingualPage.eyfsPhysical.title,
    alt: "Physical Development icon",
  },
  {
    image: iconRelationships,
    tone: "blue",
    title: multilingualPage.eyfsPersonal.title,
    alt: "Personal, Social & Emotional Development icon",
  },
  {
    image: iconLiteracy,
    tone: "yellow",
    title: multilingualPage.eyfsLiteracy.title,
    alt: "Literacy icon",
  },
  {
    image: iconMaths,
    tone: "green",
    title: multilingualPage.eyfsMaths.title,
    alt: "Mathematics icon",
  },
  {
    image: iconOutdoor,
    tone: "purple",
    title: multilingualPage.eyfsUnderstanding.title,
    alt: "Understanding the World icon",
  },
  {
    image: iconCreativity,
    tone: "blue",
    title: multilingualPage.eyfsArts.title,
    alt: "Expressive Arts & Design icon",
  },
] as const;

const screenFreeTones = [
  "purple",
  "green",
  "blue",
  "yellow",
  "purple",
] as const;

const screenFreeBenefits = multilingualPage.screenFreeBenefits.map(
  (text, index) => ({
    tone: screenFreeTones[index % screenFreeTones.length] ?? "purple",
    text,
  }),
);
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="lwk-multilingual">
    <SubpageHero
      id="multilingual-page-title"
      eyebrow={multilingualPage.heroEyebrow}
      tone="purple"
      titleLineOne={multilingualPage.heroTitleLineOne}
      titleLineTwo={multilingualPage.heroTitleLineTwo}
      bgImage={heroBg}
    >
      <PortableContent value={multilingualPage.heroParagraphs} />
    </SubpageHero>

    <div class="lwk-multilingual__sections">
      <section
        id="our-learning-philosophy"
        class="lwk-multilingual__section lwk-multilingual__section--philosophy"
        aria-labelledby="learning-philosophy-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__philosophy-layout">
            <div class="lwk-multilingual__copy-block">
              <h2 id="learning-philosophy-title">
                {multilingualPage.philosophyHeading}
              </h2>

              <div class="lwk-multilingual__prose">
                <PortableContent
                  value={multilingualPage.philosophyParagraphs}
                />
              </div>
            </div>

            <div class="lwk-multilingual__philosophy-side">
              <div class="lwk-multilingual__list-block">
                <h3>{multilingualPage.childrenEnjoyHeading}</h3>

                <ul class="lwk-multilingual__check-list">
                  {
                    philosophyPoints.map((point) => (
                      <li>
                        <span
                          class={`lwk-multilingual__check lwk-multilingual__check--${point.tone}`}
                          aria-hidden="true"
                        >
                          ✓
                        </span>

                        <span>{point.text}</span>
                      </li>
                    ))
                  }
                </ul>
              </div>

              <figure
                class="lwk-multilingual__philosophy-art"
                aria-hidden="true"
              >
                <Image
                  src={flowerImage}
                  alt=""
                  width={flowerImage.width}
                  height={flowerImage.height}
                  loading="lazy"
                  decoding="async"
                />
              </figure>
            </div>
          </div>
        </Container>
      </section>

      <section
        id="english-and-portuguese"
        class="lwk-multilingual__section lwk-multilingual__section--languages"
        aria-labelledby="languages-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__language-layout">
            <figure class="lwk-multilingual__language-art" aria-hidden="true">
              <Image
                src={languageConnectionImage}
                alt=""
                width={languageConnectionImage.width}
                height={languageConnectionImage.height}
                loading="lazy"
                decoding="async"
              />
            </figure>

            <div class="lwk-multilingual__copy-block">
              <h2 id="languages-title">
                {multilingualPage.languageConnectionHeading}
              </h2>

              <div class="lwk-multilingual__prose">
                <PortableContent
                  value={multilingualPage.languageConnectionParagraphs}
                />
              </div>
            </div>
          </div>
        </Container>
      </section>

      <section
        id="eyfs"
        class="lwk-multilingual__section lwk-multilingual__section--eyfs"
        aria-labelledby="eyfs-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__eyfs-layout">
            <div class="lwk-multilingual__copy-block lwk-multilingual__eyfs-header">
              <p class="lwk-multilingual__label lwk-multilingual__label--blue">
                {multilingualPage.eyfsLabel}
              </p>

              <h2 id="eyfs-title">{multilingualPage.eyfsHeading}</h2>

              <div class="lwk-multilingual__prose">
                <PortableContent value={multilingualPage.eyfsParagraphs} />
              </div>
            </div>

            <div class="lwk-multilingual__eyfs-journey-wrapper">
              <svg
                class="lwk-multilingual__eyfs-path-svg"
                viewBox="0 0 1000 480"
                preserveAspectRatio="none"
                aria-hidden="true"
              >
                <defs>
                  <linearGradient id="eyfsPathGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="var(--color-purple)" stop-opacity="0.4" />
                    <stop offset="35%" stop-color="var(--color-green)" stop-opacity="0.5" />
                    <stop offset="70%" stop-color="var(--color-blue)" stop-opacity="0.5" />
                    <stop offset="100%" stop-color="var(--color-yellow)" stop-opacity="0.6" />
                  </linearGradient>
                </defs>
                <path
                  d="M 70 80 C 220 20, 320 180, 470 100 C 620 20, 780 140, 910 180 C 980 270, 850 380, 710 390 C 520 400, 340 320, 180 400"
                  fill="none"
                  stroke="url(#eyfsPathGrad)"
                  stroke-width="4"
                  stroke-dasharray="8 8"
                  class="lwk-multilingual__eyfs-path-line"
                />
              </svg>

              <ol
                class="lwk-multilingual__eyfs-journey"
                aria-label="The seven areas of the Early Years Foundation Stage"
              >
                {
                  eyfsAreas.map((area, index) => (
                    <li class={`lwk-multilingual__eyfs-node lwk-multilingual__eyfs-node--${index + 1} lwk-multilingual__eyfs-node--${area.tone}`}>
                      <div class="lwk-multilingual__node-card">
                          <span
                            class={`lwk-multilingual__area-icon lwk-multilingual__area-icon--${area.tone}`}
                            aria-hidden="true"
                          >
                          <Image
                            src={area.image}
                            alt={area.alt}
                            width={256}
                            height={256}
                            quality={100}
                          />
                        </span>
                        <span class="lwk-multilingual__area-title">{area.title}</span>
                      </div>
                    </li>
                  ))
                }
              </ol>
            </div>
          </div>
        </Container>
      </section>

      <section
        id="screen-free-learning"
        class="lwk-multilingual__section lwk-multilingual__section--screen-free"
        aria-labelledby="screen-free-title"
      >
        <Container size="wide">
          <div class="lwk-multilingual__screen-free-layout">
            <div class="lwk-multilingual__copy-block">
              <p class="lwk-multilingual__label lwk-multilingual__label--blue">
                {multilingualPage.screenFreeLabel}
              </p>

              <h2 id="screen-free-title">
                {multilingualPage.screenFreeHeading}
              </h2>

              <div class="lwk-multilingual__prose">
                <PortableContent
                  value={multilingualPage.screenFreeParagraphs}
                />
              </div>
            </div>

            <div class="lwk-multilingual__list-block">
              <h3>{multilingualPage.screenFreeBenefitsHeading}</h3>

              <ul class="lwk-multilingual__check-list">
                {
                  screenFreeBenefits.map((benefit) => (
                    <li>
                      <span
                        class={`lwk-multilingual__check lwk-multilingual__check--${benefit.tone}`}
                        aria-hidden="true"
                      >
                        ✓
                      </span>

                      <span>{benefit.text}</span>
                    </li>
                  ))
                }
              </ul>
            </div>
          </div>
        </Container>
      </section>
    </div>
  </article>
</BaseLayout>
