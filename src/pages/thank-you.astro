---
import "./contact.css";
import Icon from "../components/icons/Icon.astro";
import Container from "../components/layout/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import SubpageHero from "../components/layout/SubpageHero.astro";
---

<BaseLayout
  title="Thank You | Little Wise Kids"
  description="Thank you for contacting Little Wise Kids. Our nursery team will review your enquiry and respond as soon as possible."
>
  <article class="contact-success">
    <SubpageHero
      id="thank-you-title"
      eyebrow="Message Received"
      tone="blue"
      class="contact-hero--success"
    >
      <Fragment slot="title">
        <span>Thank You for</span>
        <span>Getting in Touch</span>
      </Fragment>

      <p>Your enquiry has been sent to the Little Wise Kids team.</p>
    </SubpageHero>

    <section class="contact-success__content">
      <Container size="wide">
        <div class="contact-success__card">
          <span class="contact-success__icon" aria-hidden="true">
            <Icon name="heart" size={44} />
          </span>

          <p class="contact-section-heading__eyebrow">What Happens Next</p>

          <h2>We’ll Be in Touch Soon</h2>

          <p>
            A member of our team will review your message and usually respond
            within one working day. We look forward to learning more about your
            family and how Little Wise Kids may be able to support your child.
          </p>

          <div class="contact-success__actions">
            <a class="contact-button contact-button--primary" href="/">
              Return to Home
              <span aria-hidden="true">→</span>
            </a>

            <a
              class="contact-button contact-button--secondary"
              href="/our-gallery"
            >
              Explore Our Gallery
            </a>
          </div>
        </div>
      </Container>
    </section>
  </article>
</BaseLayout>
