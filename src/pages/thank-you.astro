---
export const prerender = true;
import "./contact.css";
import Container from "../components/layout/Container.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import PortableContent from "../components/content/PortableContent.astro";
import AnimatedThankYouLogo from "../components/ui/AnimatedThankYouLogo.astro";
import { getThankYouPage, getBusinessDetails } from "../utils/sanity";
import type { SeoConfig } from "../lib/seo/types";

const thankYouPage = await getThankYouPage();
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Thank You | Little Wise Kids",
  description: "Thank you for contacting Little Wise Kids. Our childcare team will review your enquiry and respond as soon as possible.",
  canonicalPath: "omit",
};
---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="contact-success">
    <header class="thank-you-header">
      <Container size="wide">
        {thankYouPage.heroEyebrow && (
          <p class="thank-you-header__eyebrow">{thankYouPage.heroEyebrow}</p>
        )}

        <AnimatedThankYouLogo class="thank-you-header__logo" />

        {thankYouPage.heroParagraphs && (
          <div class="thank-you-header__copy">
            <PortableContent value={thankYouPage.heroParagraphs} />
          </div>
        )}
      </Container>
    </header>

    <section class="contact-success__content">
      <Container size="wide">
        <div class="contact-success__card">
          {thankYouPage.nextStepsEyebrow && (
            <p class="contact-section-heading__eyebrow">{thankYouPage.nextStepsEyebrow}</p>
          )}

          <h2>{thankYouPage.nextStepsHeading}</h2>

          <PortableContent value={thankYouPage.nextStepsBody} />

          <div class="contact-success__actions">
            <a class="contact-button contact-button--primary" href="/">
              {thankYouPage.primaryCtaLabel}
              <span aria-hidden="true">→</span>
            </a>

            <a
              class="contact-button contact-button--secondary"
              href="/our-gallery"
            >
              {thankYouPage.secondaryCtaLabel}
            </a>
          </div>
        </div>
      </Container>
    </section>
  </article>
</BaseLayout>
