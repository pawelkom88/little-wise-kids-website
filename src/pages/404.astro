---
export const prerender = true;
import { getImage } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/layout/Container.astro";
import explorerImg from "../assets/images/404-explorer.png";
import { getBusinessDetails } from "../lib/queries";
import type { SeoConfig } from "../lib/seo/types";
import "./404.css";

const optimizedExplorer = await getImage({ src: explorerImg, width: 600, format: "webp" });
const businessDetails = await getBusinessDetails();

const seo: SeoConfig = {
  title: "Page Not Found | Little Wise Kids",
  description: "The page you were looking for could not be found. Return to the Little Wise Kids homepage or explore another part of our website.",
  robots: "noindex, nofollow",
  canonicalPath: "omit",
};

---

<BaseLayout seo={seo} businessDetails={businessDetails}>
  <article class="not-found-page" aria-labelledby="not-found-title">
    <section class="not-found">
      <Container size="wide" class="not-found__container">
        <div class="not-found__hero">
          <figure class="not-found__illustration">
            <img
              src={optimizedExplorer.src}
              alt="Explorer character lost in the woods"
              width={optimizedExplorer.attributes.width}
              height={optimizedExplorer.attributes.height}
              loading="eager"
              decoding="sync"
              fetchpriority="high"
            />
          </figure>

          <div class="not-found__content">
            <p class="not-found__code" aria-hidden="true">
              <span>4</span>
              <span>0</span>
              <span>4</span>
            </p>

            <p class="not-found__eyebrow">Page Not Found</p>

            <h1 id="not-found-title">Oops! We Can’t Find That Page</h1>

            <p class="not-found__lead">
              It looks like this page has wandered off on an adventure. Let’s
              help you find your way back.
            </p>

            <div class="not-found__actions">
              <a class="not-found__button not-found__button--primary" href="/">
                <span aria-hidden="true">←</span>
                <span>Back to Home</span>
              </a>
            </div>
          </div>
        </div>
      </Container>
    </section>
  </article>
</BaseLayout>
