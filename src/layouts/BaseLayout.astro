---
import { ClientRouter } from "astro:transitions";
import "../styles/site.css";
import { getBusinessDetails } from "../lib/queries";
import SiteHeader from "../components/layout/SiteHeader.astro";
import SiteFooter from "../components/layout/SiteFooter.astro";
import SeoHead from "../components/seo/SeoHead.astro";
import JsonLd from "../components/seo/JsonLd.astro";
import type { BusinessDetails } from "../lib/types";
import type { SeoConfig } from "../lib/seo/types";
import { buildBusinessSchema } from "../lib/seo/buildBusinessSchema";
import { buildPageSchema } from "../lib/seo/buildPageSchema";

interface Props {
  seo: SeoConfig;
  businessDetails?: BusinessDetails;
}

const businessDetails = Astro.props.businessDetails ?? await getBusinessDetails();
const { seo } = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString().replace(/\/$/, "") : "https://littlewisekids.co.uk";
let canonicalUrl: string | undefined = `${siteUrl}${seo.canonicalPath}`;
if (canonicalUrl.length > siteUrl.length + 1 && canonicalUrl.endsWith("/")) {
  canonicalUrl = canonicalUrl.slice(0, -1);
}
if (seo.canonicalPath === "omit") {
  canonicalUrl = undefined;
}

const businessSchema = buildBusinessSchema(businessDetails, siteUrl);
const pageSchema = buildPageSchema(siteUrl, canonicalUrl, seo.title, seo.description, seo.type === "article" ? "ItemPage" : "WebPage");
const schemaGraph = [businessSchema, ...pageSchema, ...(seo.schemas || [])];
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <ClientRouter />
    <SeoHead seo={seo} businessDetails={businessDetails} />
    <JsonLd data={schemaGraph} />
    <link
      rel="preload"
      href="/assets/fonts/Quicksand/Quicksand-Bold.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href="/assets/fonts/Roboto/Roboto-Regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    {Astro.url.pathname === "/" && (
      <link
        rel="preload"
        href="/images/littlewisekids-hero-poster.jpg"
        as="image"
        type="image/jpeg"
        fetchpriority="high"
      />
    )}
    <script is:inline>
      // Suppress harmless InvalidStateError caused by aborted view transitions when rapid navigation occurs
      window.addEventListener('unhandledrejection', (event) => {
        if (
          event.reason &&
          (event.reason.name === 'InvalidStateError' ||
            (typeof event.reason.message === 'string' && event.reason.message.includes('Transition was aborted')))
        ) {
          event.preventDefault();
        }
      });

      // Prevent rapid double clicking during page transitions
      document.addEventListener('astro:before-preparation', () => {
        document.body.style.pointerEvents = 'none';
      });
      document.addEventListener('astro:page-load', () => {
        document.body.style.pointerEvents = '';
      });

      const modelCtx = (typeof document !== 'undefined' && document.modelContext) || (typeof navigator !== 'undefined' && navigator.modelContext);
      if (modelCtx && typeof modelCtx.provideContext === 'function') {
        modelCtx.provideContext({
          tools: [
            {
              name: "getBusinessInfo",
              description: "Get information about Little Wise Kids business.",
              inputSchema: {
                type: "object",
                properties: {}
              },
              execute: async () => {
                return {
                  text: "Little Wise Kids is a childcare provider in Easton, Bristol."
                };
              }
            }
          ]
        });
      }
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <SiteHeader businessDetails={businessDetails} />
    <main id="main-content" transition:animate="fade">
      <slot />
    </main>
    <SiteFooter businessDetails={businessDetails} />
  </body>
</html>
