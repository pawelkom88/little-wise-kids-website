{
  "name": "little-wise-kids",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npm run build && wrangler dev",
    "check:architecture": "node scripts/check-architecture.mjs",
    "test:security": "node --test src/lib/urls.test.mjs workers/sanity-deploy-gateway/index.test.mjs",
    "check:gateway": "wrangler deploy --config wrangler.sanity-gateway.jsonc --dry-run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "generate-types": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "lighthouse": "unlighthouse --site http://localhost:4321",
    "test:a11y": "playwright test",
    "test:a11y:headed": "playwright test --headed",
    "test:a11y:report": "playwright show-report test-results/accessibility/html-report",
    "test:a11y:chromium": "playwright test --project=chromium",
    "test:a11y:manual": "echo 'Run manual checks per docs/accessibility/MANUAL-TEST-PLAN.md'"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/react": "^6.0.1",
    "@sanity/astro": "^3.4.2",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^6.5.0",
    "@sanity/webhook": "^4.0.4",
    "astro": "^7.0.9",
    "astro-portabletext": "^0.13.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sanity": "^6.5.0",
    "sharp": "^0.35.3",
    "styled-components": "^6.4.3",
    "typescript": "^7.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@sanity/cli": "^6.5.0",
    "html-validate": "^11.5.6",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "unlighthouse": "^0.18.0",
    "wrangler": "^4.111.0"
  }
}
